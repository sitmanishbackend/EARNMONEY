<header class="topbar">
  <div class="topbar-left">
    <button class="sidebar-toggle" onclick="toggleSidebar()"><i class="bi bi-list"></i></button>
    <span style="font-size:0.85rem;font-weight:600;color:var(--text2)"><%= typeof title !== 'undefined' ? title : 'Dashboard' %></span>
  </div>
  <div class="topbar-right">
    <button class="topbar-btn"><i class="bi bi-bell"></i><span class="notif-dot"></span></button>
    <a href="/" target="_blank" class="topbar-btn" title="View Site"><i class="bi bi-globe"></i></a>
    <a href="/admin/profile" class="topbar-btn"><i class="bi bi-person-circle"></i></a>
    <a href="/admin/logout" class="btn btn-danger btn-sm"><i class="bi bi-box-arrow-right"></i> Logout</a>
  </div>
</header>
