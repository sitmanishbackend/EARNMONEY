<%# This is included at the top of every admin page %>
<style>
  :root {
    --primary: <%= theme.primary_color || '#1a7a4a' %>;
    --secondary: <%= theme.secondary_color || '#e8a020' %>;
    --accent-dark: <%= theme.accent_dark || '#125c36' %>;
    --accent-light: <%= theme.accent_light || '#e8f5ee' %>;
    --sidebar-bg: <%= theme.sidebar_bg || '#1a2332' %>;
    --sidebar-text: <%= theme.sidebar_text || '#ffffff' %>;
    --nav-bg: <%= theme.nav_bg || '#ffffff' %>;
    --btn-color: <%= theme.btn_color || '#1a7a4a' %>;
    --bg:#f0f4f8; --card-bg:#ffffff; --border:#e0e8f0;
    --text:#1a2332; --text2:#4a5568; --text3:#8a97a8;
    --radius:12px; --shadow:0 2px 12px rgba(0,0,0,0.08);
    --sidebar-width:260px;
    --sidebar-width-collapsed:68px;
    --topbar-height:68px;
    --page-pad: clamp(1rem, 3vw, 1.5rem);
  }
  *{margin:0;padding:0;box-sizing:border-box;}
  html{-webkit-text-size-adjust:100%;text-size-adjust:100%;}
  body{font-family:'Poppins',sans-serif;background:var(--bg);color:var(--text);display:flex;min-height:100vh;min-height:100dvh;overflow-x:hidden;}
  a{text-decoration:none;color:inherit;}
  img{max-width:100%;height:auto;}
  button,input,select,textarea{font:inherit;}
  ::-webkit-scrollbar{width:4px;height:4px;}
  ::-webkit-scrollbar-thumb{background:var(--primary);border-radius:4px;}

  /* ── SIDEBAR ── */
  .sidebar{
    width:var(--sidebar-width);background:var(--sidebar-bg);color:var(--sidebar-text);
    display:flex;flex-direction:column;position:fixed;top:0;left:0;height:100vh;height:100dvh;
    z-index:200;transition:width 0.3s, transform 0.3s;overflow:visible;
  }
  .sidebar.collapsed{width:var(--sidebar-width-collapsed);}
  .sidebar-logo{padding:1.25rem 1.1rem;display:flex;align-items:center;gap:0.75rem;border-bottom:1px solid rgba(255,255,255,0.08);min-height:var(--topbar-height);flex-shrink:0;}
  .logo-icon{width:38px;height:38px;background:var(--primary);border-radius:10px;display:flex;align-items:center;justify-content:center;font-size:1.1rem;font-weight:800;color:#fff;flex-shrink:0;}
  .logo-text{font-weight:800;font-size:1rem;line-height:1.2;white-space:nowrap;overflow:hidden;}
  .logo-text small{display:block;font-size:0.6rem;font-weight:400;opacity:0.6;}
  .sidebar-nav{
    flex:1 1 0;min-height:0;overflow-y:auto;overflow-x:hidden;padding:0.75rem 0;
    scrollbar-width:thin;scrollbar-color:rgba(255,255,255,0.18) transparent;
    -webkit-overflow-scrolling:touch;
  }
  .sidebar-nav::-webkit-scrollbar{width:3px;}
  .sidebar-nav::-webkit-scrollbar-thumb{background:rgba(255,255,255,0.2);border-radius:3px;}
  .nav-section-title{padding:0.6rem 1.2rem 0.25rem;font-size:0.6rem;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;opacity:0.4;white-space:nowrap;overflow:hidden;}
  .nav-link{display:flex;align-items:center;gap:0.85rem;padding:0.65rem 1.2rem;font-size:0.83rem;font-weight:500;color:rgba(255,255,255,0.75);cursor:pointer;border-radius:0;transition:all 0.2s;position:relative;white-space:nowrap;border:none;background:none;width:100%;text-align:left;min-height:44px;}
  .nav-link:hover{background:rgba(255,255,255,0.08);color:#fff;}
  .nav-link.active{background:var(--primary);color:#fff;font-weight:600;}
  .nav-link .nav-icon{font-size:1.1rem;flex-shrink:0;width:20px;}
  .nav-link .nav-label{white-space:nowrap;overflow:hidden;}
  .nav-badge{margin-left:auto;font-size:0.6rem;font-weight:700;padding:2px 7px;border-radius:10px;background:var(--secondary);color:#fff;flex-shrink:0;}
  .sidebar-footer{padding:1rem 1.1rem;border-top:1px solid rgba(255,255,255,0.08);flex-shrink:0;}
  .sidebar-user{display:flex;align-items:center;gap:0.75rem;}
  .user-avatar{width:36px;height:36px;border-radius:50%;background:var(--primary);display:flex;align-items:center;justify-content:center;font-size:1rem;font-weight:700;color:#fff;flex-shrink:0;}
  .user-info{min-width:0;}
  .user-info .uname{font-size:0.82rem;font-weight:600;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
  .user-info .urole{font-size:0.65rem;opacity:0.6;text-transform:uppercase;}

  .sidebar.collapsed .logo-text,.sidebar.collapsed .nav-label,.sidebar.collapsed .nav-badge,.sidebar.collapsed .nav-section-title,.sidebar.collapsed .user-info{display:none;}
  .sidebar.collapsed .nav-link{justify-content:center;padding:0.65rem;}
  .sidebar.collapsed .sidebar-user{justify-content:center;}

  /* Backdrop shown behind the sidebar when it's opened as an overlay on small screens */
  .sidebar-overlay{position:fixed;inset:0;background:rgba(0,0,0,0.5);z-index:190;display:none;}
  .sidebar-overlay.show{display:block;}

  /* ── MAIN CONTENT ── */
  .main-content{flex:1;min-width:0;margin-left:var(--sidebar-width);display:flex;flex-direction:column;min-height:100vh;min-height:100dvh;transition:margin 0.3s;}
  .main-content.expanded{margin-left:var(--sidebar-width-collapsed);}

  /* ── TOPBAR ── */
  .topbar{background:var(--nav-bg);border-bottom:1px solid var(--border);padding:0 var(--page-pad);height:var(--topbar-height);display:flex;align-items:center;justify-content:space-between;position:sticky;top:0;z-index:100;box-shadow:0 1px 6px rgba(0,0,0,0.06);gap:0.75rem;}
  .topbar-left{display:flex;align-items:center;gap:1rem;min-width:0;}
  .sidebar-toggle{width:36px;height:36px;border:1.5px solid var(--border);border-radius:8px;background:transparent;display:flex;align-items:center;justify-content:center;cursor:pointer;font-size:1.1rem;color:var(--text2);transition:all 0.2s;flex-shrink:0;}
  .sidebar-toggle:hover{border-color:var(--primary);color:var(--primary);}
  .topbar-right{display:flex;align-items:center;gap:0.75rem;flex-shrink:0;}
  .topbar-btn{width:36px;height:36px;border-radius:50%;border:1.5px solid var(--border);background:transparent;display:flex;align-items:center;justify-content:center;cursor:pointer;font-size:1rem;color:var(--text2);transition:all 0.2s;position:relative;}
  .topbar-btn:hover{border-color:var(--primary);color:var(--primary);}
  .notif-dot{position:absolute;top:6px;right:6px;width:7px;height:7px;background:#dc2626;border-radius:50%;}

  .page-content{flex:1;padding:var(--page-pad);}
  .card{background:var(--card-bg);border:1px solid var(--border);border-radius:var(--radius);box-shadow:var(--shadow);min-width:0;}
  .card-header{padding:1rem 1.25rem;border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between;gap:0.75rem;flex-wrap:wrap;}
  .card-title{font-size:0.9rem;font-weight:700;color:var(--text);}
  .card-body{padding:clamp(0.9rem, 3vw, 1.25rem);}

  .stat-card{background:var(--card-bg);border-radius:var(--radius);padding:clamp(1rem, 3vw, 1.25rem);display:flex;align-items:center;gap:1rem;box-shadow:var(--shadow);border:1px solid var(--border);min-width:0;}
  .stat-icon{width:52px;height:52px;border-radius:12px;display:flex;align-items:center;justify-content:center;font-size:1.4rem;flex-shrink:0;}
  .stat-info{min-width:0;}
  .stat-info .stat-val{font-size:clamp(1.3rem, 3vw, 1.6rem);font-weight:800;line-height:1;}
  .stat-info .stat-lbl{font-size:0.72rem;color:var(--text3);margin-top:0.2rem;font-weight:500;text-transform:uppercase;letter-spacing:0.04em;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
  .stat-info .stat-change{font-size:0.72rem;margin-top:0.25rem;font-weight:600;}
  .text-success{color:#16a34a;}.text-danger{color:#dc2626;}.text-warning{color:#d97706;}.text-info{color:#0891b2;}
  .bg-success-soft{background:#dcfce7;color:#16a34a;}
  .bg-primary-soft{background:var(--accent-light);color:var(--primary);}
  .bg-warning-soft{background:#fef9c3;color:#ca8a04;}
  .bg-danger-soft{background:#fee2e2;color:#dc2626;}
  .bg-info-soft{background:#e0f2fe;color:#0369a1;}
  .bg-purple-soft{background:#f3e8ff;color:#7c3aed;}

  /* ── TABLES ── */
  .table-wrap{overflow-x:auto;-webkit-overflow-scrolling:touch;}
  table{width:100%;border-collapse:collapse;font-size:0.83rem;}
  th{background:#f8fafc;padding:0.75rem 1rem;text-align:left;font-size:0.72rem;font-weight:700;text-transform:uppercase;letter-spacing:0.05em;color:var(--text3);border-bottom:2px solid var(--border);white-space:nowrap;}
  td{padding:0.85rem 1rem;border-bottom:1px solid var(--border);vertical-align:middle;}
  tr:hover td{background:#fafbfc;}
  tr:last-child td{border-bottom:none;}

  .btn{display:inline-flex;align-items:center;gap:0.4rem;padding:0.5rem 1.1rem;border-radius:8px;font-size:0.82rem;font-weight:600;border:none;cursor:pointer;transition:all 0.2s;font-family:inherit;min-height:38px;}
  .btn-sm{padding:0.3rem 0.75rem;font-size:0.75rem;min-height:32px;}.btn-xs{padding:0.2rem 0.5rem;font-size:0.7rem;min-height:26px;}
  .btn-primary{background:var(--primary);color:#fff;}.btn-primary:hover{background:var(--accent-dark);transform:translateY(-1px);}
  .btn-secondary{background:#f0f4f8;color:var(--text2);border:1px solid var(--border);}.btn-secondary:hover{background:#e0e8f0;}
  .btn-danger{background:#dc2626;color:#fff;}.btn-danger:hover{background:#b91c1c;}
  .btn-warning{background:#d97706;color:#fff;}.btn-success{background:#16a34a;color:#fff;}
  .btn-outline{background:transparent;border:1.5px solid var(--primary);color:var(--primary);}.btn-outline:hover{background:var(--primary);color:#fff;}

  .form-group{margin-bottom:1rem;}
  label{display:block;font-size:0.78rem;font-weight:600;color:var(--text2);margin-bottom:0.35rem;}
  .form-control{width:100%;padding:0.55rem 0.9rem;border:1.5px solid var(--border);border-radius:8px;font-size:16px;font-family:inherit;color:var(--text);background:var(--card-bg);transition:border 0.2s;}
  .form-control:focus{outline:none;border-color:var(--primary);}
  textarea.form-control{resize:vertical;min-height:100px;}
  .badge{display:inline-block;padding:0.2rem 0.6rem;border-radius:20px;font-size:0.68rem;font-weight:700;}
  .badge-success{background:#dcfce7;color:#16a34a;}.badge-danger{background:#fee2e2;color:#dc2626;}
  .badge-warning{background:#fef9c3;color:#ca8a04;}.badge-info{background:#e0f2fe;color:#0369a1;}
  .badge-secondary{background:#f1f5f9;color:#64748b;}.badge-primary{background:var(--accent-light);color:var(--primary);}

  /* ── TABS ── */
  .tabs{display:flex;gap:0;border-bottom:2px solid var(--border);margin-bottom:1.25rem;overflow-x:auto;-webkit-overflow-scrolling:touch;scrollbar-width:none;}
  .tabs::-webkit-scrollbar{display:none;}
  .tab-btn{padding:0.65rem 1.25rem;font-size:0.82rem;font-weight:600;border:none;background:none;cursor:pointer;color:var(--text2);border-bottom:2px solid transparent;margin-bottom:-2px;transition:all 0.2s;white-space:nowrap;flex-shrink:0;min-height:44px;}
  .tab-btn.active{color:var(--primary);border-bottom-color:var(--primary);}
  .tab-content{display:none;}.tab-content.active{display:block;}

  .grid{display:grid;gap:1.25rem;}
  .grid-2{grid-template-columns:1fr 1fr;}.grid-3{grid-template-columns:1fr 1fr 1fr;}.grid-4{grid-template-columns:repeat(4,1fr);}.grid-stats{grid-template-columns:repeat(4,1fr);}

  /* ── MODAL ── */
  .modal-overlay{position:fixed;inset:0;background:rgba(0,0,0,0.5);z-index:1000;display:none;align-items:center;justify-content:center;padding:1rem;}
  .modal-overlay.show{display:flex;}
  .modal{background:var(--card-bg);border-radius:var(--radius);width:100%;max-width:600px;max-height:90vh;max-height:90dvh;overflow-y:auto;-webkit-overflow-scrolling:touch;box-shadow:0 20px 60px rgba(0,0,0,0.3);}
  .modal-header{padding:1.25rem;border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between;gap:0.75rem;position:sticky;top:0;background:var(--card-bg);z-index:1;}
  .modal-title{font-size:1rem;font-weight:700;}
  .modal-close{width:32px;height:32px;border-radius:50%;border:none;background:#f0f4f8;cursor:pointer;display:flex;align-items:center;justify-content:center;font-size:1rem;flex-shrink:0;}
  .modal-body{padding:1.25rem;}
  .modal-footer{padding:1rem 1.25rem;border-top:1px solid var(--border);display:flex;gap:0.75rem;justify-content:flex-end;flex-wrap:wrap;position:sticky;bottom:0;background:var(--card-bg);}

  .alert{padding:0.85rem 1.1rem;border-radius:8px;font-size:0.83rem;margin-bottom:1rem;display:flex;align-items:center;gap:0.6rem;}
  .alert-success{background:#dcfce7;color:#166534;border:1px solid #bbf7d0;}
  .alert-danger{background:#fee2e2;color:#991b1b;border:1px solid #fecaca;}
  .alert-warning{background:#fef9c3;color:#854d0e;border:1px solid #fef08a;}

  .breadcrumb{display:flex;align-items:center;gap:0.4rem;font-size:0.78rem;color:var(--text3);margin-bottom:1rem;flex-wrap:wrap;}
  .breadcrumb a{color:var(--primary);}.breadcrumb .sep{color:var(--border);}
  .page-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:1.5rem;flex-wrap:wrap;gap:1rem;}
  .page-title{font-size:clamp(1.1rem, 3vw, 1.35rem);font-weight:800;}
  .page-subtitle{font-size:0.8rem;color:var(--text3);margin-top:0.2rem;}
  .w-100{width:100%;}.text-center{text-align:center;}.text-right{text-align:right;}
  .d-flex{display:flex;}.align-center{align-items:center;}.justify-between{justify-content:space-between;}
  .gap-1{gap:0.25rem;}.gap-2{gap:0.5rem;}.gap-3{gap:1rem;}
  .mt-1{margin-top:0.25rem;}.mt-2{margin-top:0.5rem;}.mt-3{margin-top:1rem;}.mt-4{margin-top:1.5rem;}
  .mb-1{margin-bottom:0.25rem;}.mb-2{margin-bottom:0.5rem;}.mb-3{margin-bottom:1rem;}.mb-4{margin-bottom:1.5rem;}
  .p-3{padding:1rem;}.p-4{padding:1.5rem;}
  .rounded{border-radius:8px;}.rounded-full{border-radius:50%;}
  .empty-state{text-align:center;padding:clamp(1.5rem, 6vw, 3rem);color:var(--text3);}
  .empty-state i{font-size:3rem;margin-bottom:1rem;opacity:0.4;display:block;}
  .tag{display:inline-block;padding:0.2rem 0.6rem;border-radius:20px;font-size:0.7rem;font-weight:600;background:var(--accent-light);color:var(--primary);margin:2px;}
  .input-group{display:flex;}.input-group .form-control{border-radius:8px 0 0 8px;min-width:0;}.input-group .btn{border-radius:0 8px 8px 0;flex-shrink:0;}
  .divider{border:none;border-top:1px solid var(--border);margin:1rem 0;}
  .text-muted{color:var(--text3);}
  .form-check{display:flex;align-items:center;gap:0.5rem;}
  .form-check input{width:16px;height:16px;cursor:pointer;flex-shrink:0;}

  /* ============================================================
     RESPONSIVE BREAKPOINTS
     Large desktop → Laptop → Tablet landscape → Tablet portrait →
     Mobile → Small mobile, plus touch + landscape-phone tweaks
     ============================================================ */

  /* ── Large desktop (≥1600px): a little breathing room ── */
  @media (min-width:1600px){
    .page-content{padding:clamp(1.5rem, 2.5vw, 2rem);}
    .grid{gap:1.5rem;}
  }

  /* ── Laptop / small desktop (1025px–1279px): trim sidebar slightly ── */
  @media (max-width:1279px) and (min-width:1025px){
    :root{--sidebar-width:230px;}
  }

  /* ── Tablet landscape (901px–1024px): auto-collapse sidebar to icons ── */
  @media (max-width:1024px) and (min-width:901px){
    .sidebar:not(.mobile-open){width:var(--sidebar-width-collapsed);}
    .sidebar:not(.mobile-open) .logo-text,
    .sidebar:not(.mobile-open) .nav-label,
    .sidebar:not(.mobile-open) .nav-badge,
    .sidebar:not(.mobile-open) .nav-section-title,
    .sidebar:not(.mobile-open) .user-info{display:none;}
    .sidebar:not(.mobile-open) .nav-link{justify-content:center;padding:0.65rem;}
    .sidebar:not(.mobile-open) .sidebar-user{justify-content:center;}
    .main-content{margin-left:var(--sidebar-width-collapsed);}
    .grid-4,.grid-stats{grid-template-columns:repeat(3,1fr);}
  }

  /* ── Tablet portrait & below (≤900px): sidebar becomes an off-canvas drawer ── */
  @media (max-width:900px){
    .sidebar{transform:translateX(-100%);width:min(var(--sidebar-width), 82vw);}
    .sidebar.mobile-open{transform:translateX(0);box-shadow:6px 0 24px rgba(0,0,0,.2);}
    .sidebar.collapsed{width:min(var(--sidebar-width), 82vw);}
    .sidebar.collapsed.mobile-open .logo-text,
    .sidebar.collapsed.mobile-open .nav-label,
    .sidebar.collapsed.mobile-open .nav-badge,
    .sidebar.collapsed.mobile-open .nav-section-title,
    .sidebar.collapsed.mobile-open .user-info{display:block;}
    .sidebar.collapsed.mobile-open .nav-link{justify-content:flex-start;padding:0.65rem 1.2rem;}
    .sidebar.collapsed.mobile-open .sidebar-user{justify-content:flex-start;}
    .main-content, .main-content.expanded{margin-left:0;}
    .grid-4,.grid-stats{grid-template-columns:1fr 1fr;}
    .grid-3{grid-template-columns:1fr 1fr;}
    .grid-2{grid-template-columns:1fr 1fr;}
    .topbar{padding:0 1rem;}
    .page-content{padding:1rem;}
  }

  /* ── Mobile (≤600px) ── */
  @media (max-width:600px){
    .grid-2,.grid-3,.grid-4,.grid-stats{grid-template-columns:1fr;}
    .page-header{flex-direction:column;align-items:flex-start;gap:0.5rem;}
    .card-header{flex-direction:column;align-items:flex-start;}
    .stat-card{padding:1rem;}
    .stat-icon{width:44px;height:44px;font-size:1.15rem;}
    .modal{max-width:100%;width:100%;border-radius:var(--radius) var(--radius) 0 0;align-self:flex-end;margin-top:auto;max-height:85dvh;}
    .modal-overlay{align-items:flex-end;padding:0;}
    .modal-footer{flex-direction:column-reverse;}
    .modal-footer .btn{width:100%;justify-content:center;}
    .input-group{flex-direction:column;}
    .input-group .form-control{border-radius:8px;}
    .input-group .btn{border-radius:8px;margin-top:0.5rem;justify-content:center;}
    th,td{padding:0.6rem 0.75rem;font-size:0.78rem;}
    .btn{padding:0.55rem 1rem;}
  }

  /* ── Small mobile (≤480px) ── */
  @media (max-width:480px){
    body{font-size:14px;}
    .topbar{height:60px;padding:0 0.85rem;}
    .page-content{padding:0.85rem;}
    .sidebar-logo{padding:1rem 0.85rem;min-height:60px;}
    .stat-card{flex-direction:row;align-items:center;}
    .page-title{font-size:1.05rem;}
    .empty-state i{font-size:2.25rem;}
    .tab-btn{padding:0.6rem 1rem;font-size:0.78rem;}
    .breadcrumb{font-size:0.72rem;}
  }

  /* ── Extra-small devices (≤360px) ── */
  @media (max-width:360px){
    .logo-text{font-size:0.9rem;}
    .logo-icon{width:34px;height:34px;font-size:1rem;}
    .stat-info .stat-val{font-size:1.2rem;}
    .btn{font-size:0.78rem;padding:0.5rem 0.85rem;}
  }

  /* ── Short / landscape phones ── */
  @media (max-height:480px) and (orientation:landscape){
    .sidebar{width:min(240px, 70vw);}
    .topbar{height:56px;}
    .modal{max-height:95dvh;}
  }

  /* ── Touch devices: bigger tap targets, drop hover-only transforms ── */
  @media (hover:none) and (pointer:coarse){
    .btn,.topbar-btn,.sidebar-toggle,.tab-btn,.nav-link{min-height:44px;}
    .btn-primary:hover,tr:hover td{transform:none;}
  }

  /* ── Print ── */
  @media print{
    .sidebar,.sidebar-overlay,.topbar,.modal-overlay,.tabs{display:none!important;}
    .main-content{margin-left:0!important;}
    body{background:#fff;color:#000;}
  }

/*
 ═══════════════════════════════
  COLLAPSED STATE (kept as-is — desktop manual toggle)
 ═══════════════════════════════
*/
</style>
