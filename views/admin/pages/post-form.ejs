<script>
// ────────────────────────────────────────
// STATE
// ────────────────────────────────────────
var _tags = [];
var _revisions = [];
var _mediaFiles = [];
var _cfCount = 0;
var _autoSaveTimer = null;
var _activePanel = 'write';

// ── INIT ──────────────────────────────
document.addEventListener('DOMContentLoaded', function(){
  buildTablePickerGrid();
  generateSchema();
  onTitleInput(document.getElementById('titleInput').value);
  onDescInput(document.getElementById('descInput').value);
  onEditorChange();
  updateSERP();
  // load existing tags
  var existingTags = document.getElementById('tagsHidden').value;
  if(existingTags){ existingTags.split(',').forEach(function(t){ t=t.trim(); if(t) addTag(t); }); }
  addRevision('Initial load');
});

// ── PANEL SWITCH ───────────────────────
function switchPanel(name, iconBtn, tabId){
  document.querySelectorAll('.post-panel').forEach(function(p){ p.classList.remove('active'); });
  document.querySelectorAll('.ptab').forEach(function(b){ b.classList.remove('active'); });
  document.querySelectorAll('.pin-btn').forEach(function(b){ b.classList.remove('active'); });
  var panel = document.getElementById('panel-'+name);
  if(panel) panel.classList.add('active');
  if(tabId) document.getElementById(tabId).classList.add('active');
  if(iconBtn) iconBtn.classList.add('active');
  _activePanel = name;
}

function switchRTab(name, btn){
  document.querySelectorAll('.rpanel-c').forEach(function(p){ p.classList.remove('active'); });
  document.querySelectorAll('.rtab-btn').forEach(function(b){ b.classList.remove('active'); });
  document.getElementById('rp-'+name).classList.add('active');
  btn.classList.add('active');
}

function toggleSection(hdr){
  var body = hdr.nextElementSibling;
  var ic = hdr.querySelector('i:last-child');
  var col = body.classList.contains('collapsed');
  body.classList.toggle('collapsed', !col);
  if(ic){ ic.className = col ? 'bi bi-chevron-down' : 'bi bi-chevron-up'; ic.style.cssText='font-size:12px;color:var(--text3)'; }
}

// ── RICH EDITOR ────────────────────────
function execRich(cmd, val){
  var activeEd = document.getElementById(_activePanel==='write' ? 'richEditorEN' : 'richEditorEN');
  activeEd.focus();
  document.execCommand(cmd, false, val || null);
  onEditorChange();
}
function insertLink(){
  var url = prompt('Enter URL (include https://):', 'https://');
  if(url){ document.getElementById('richEditorEN').focus(); document.execCommand('createLink', false, url); }
}
function insertBlockquote(){ execRich('formatBlock','blockquote'); }
function insertHR(){
  document.getElementById('richEditorEN').focus();
  document.execCommand('insertHTML', false, '<hr style="border:none;border-top:2px solid var(--border);margin:1.5em 0"><p></p>');
}
function insertCodeBlock(){
  document.getElementById('richEditorEN').focus();
  document.execCommand('insertHTML', false, '<pre><code>// paste code here</code></pre><p></p>');
}

function onEditorChange(){
  var ed = document.getElementById('richEditorEN');
  var text = ed.innerText || '';
  var words = text.trim().split(/\s+/).filter(function(w){ return w.length > 0; });
  var wc = words.length;
  var chars = text.replace(/\s/g,'').length;
  var paras = ed.querySelectorAll('p,h1,h2,h3,h4,li').length || 1;
  var imgs = ed.querySelectorAll('img').length;
  var rt = Math.max(1, Math.round(wc / 200));
  document.getElementById('wcWords').textContent = wc + ' words';
  document.getElementById('wcChars').textContent = chars.toLocaleString() + ' chars';
  document.getElementById('wcParas').textContent = paras + ' paras';
  document.getElementById('wcRead').textContent = rt + ' min read';
  document.getElementById('wcImgs').textContent = imgs + ' images';
  document.getElementById('readTimeTop').textContent = rt + ' min';
  document.getElementById('lastModifiedField').value = new Date().toLocaleString('en-IN');
  scheduleAutoSave();
}

// ── TITLE ──────────────────────────────
function onTitleInput(v){
  var slug = v.toLowerCase().replace(/[^a-z0-9\s-]/g,'').trim().replace(/\s+/g,'-').substring(0,80);
  document.getElementById('slugPreview').textContent = slug || 'post-slug';
  document.getElementById('serpTitle').textContent = (v||'Post Title Here').substring(0,60);
  document.getElementById('ogTitle').textContent = v || 'Post Title';
  var pct = Math.min(100, v.length/70*100);
  var fill = document.getElementById('titleCharFill');
  fill.style.width = pct+'%';
  fill.style.background = pct>100?'#dc2626':pct>85?'#b45309':'#16a34a';
  document.getElementById('titleCharCount').textContent = v.length+'/70';
  document.getElementById('serpSlug').textContent = slug;
  generateSchema();
  scheduleAutoSave();
}
function editSlug(){
  var cur = document.getElementById('slugPreview').textContent;
  var ns = prompt('Edit slug (lowercase, hyphens only):', cur);
  if(ns){ document.getElementById('slugPreview').textContent = ns.toLowerCase().replace(/[^a-z0-9-]/g,'-'); }
}

// ── DESC ───────────────────────────────
function onDescInput(v){
  var pct = Math.min(100, v.length/160*100);
  var fill = document.getElementById('descCharFill');
  fill.style.width = pct+'%';
  fill.style.background = pct>100?'#dc2626':pct>85?'#b45309':'#16a34a';
  document.getElementById('descCharCount').textContent = v.length+'/160';
  document.getElementById('serpDesc').textContent = v || 'Your meta description will appear here.';
  document.getElementById('ogDesc').textContent = v || 'Post description...';
}

// ── LANG ───────────────────────────────
function switchTitleLang(l, btn){
  document.getElementById('titleEN-wrap').style.display = l==='en'?'block':'none';
  document.getElementById('titleHI-wrap').style.display = l==='hi'?'block':'none';
  btn.parentElement.querySelectorAll('button').forEach(function(b){ b.classList.remove('active'); });
  btn.classList.add('active');
}
function switchDescLang(l, btn){
  document.getElementById('descEN-wrap').style.display = l==='en'?'block':'none';
  document.getElementById('descHI-wrap').style.display = l==='hi'?'block':'none';
  btn.parentElement.querySelectorAll('button').forEach(function(b){ b.classList.remove('active'); });
  btn.classList.add('active');
}
function switchContentLang(l){
  document.getElementById('editorEN-wrap').style.display = l==='en'?'block':'none';
  document.getElementById('editorHI-wrap').style.display = l==='hi'?'block':'none';
  document.getElementById('contentLangEN').classList.toggle('active', l==='en');
  document.getElementById('contentLangHI').classList.toggle('active', l==='hi');
}

// ── SERP ───────────────────────────────
function updateSERP(){
  var t = document.getElementById('metaTitle').value || document.getElementById('titleInput').value || 'Post Title Here';
  var d = document.getElementById('metaDesc').value || document.getElementById('descInput').value || 'Your description...';
  document.getElementById('serpTitle').textContent = t.substring(0,60);
  document.getElementById('serpDesc').textContent = d.substring(0,160);
  document.getElementById('ogTitle').textContent = t;
  document.getElementById('ogDesc').textContent = d;
