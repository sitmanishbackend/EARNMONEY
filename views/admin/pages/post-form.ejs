// ── SEO ANALYSIS ───────────────────────
function runSEOAnalysis(){
  var title = document.getElementById('titleInput').value;
  var desc = document.getElementById('descInput').value || document.getElementById('metaDesc').value;
  var kw = (document.getElementById('focusKw').value||'').toLowerCase().trim();
  var ed = document.getElementById('richEditorEN');
  var text = ed.innerText || '';
  var wc = text.trim().split(/\s+/).filter(function(w){ return w.length>0; }).length;
  var hasH = ed.querySelector('h1,h2,h3') !== null;
  var hasImg = ed.querySelector('img') !== null;
  var hasLinks = ed.querySelectorAll('a').length > 0;

  var checks = [
    {l:'Title length (50-70 chars)', ok:title.length>=50&&title.length<=70, warn:title.length>0&&(title.length<50||title.length>70), info:title.length+' chars'},
    {l:'Meta description present', ok:desc.length>0, info:desc.length>0?'✓':'Missing'},
    {l:'Meta desc length (120-160)', ok:desc.length>=120&&desc.length<=160, warn:desc.length>0&&(desc.length<120||desc.length>160), info:desc.length+' chars'},
    {l:'Focus keyword set', ok:kw.length>0, info:kw||'Not set'},
    {l:'Keyword in title', ok:kw&&title.toLowerCase().includes(kw), info:kw?'':'Set keyword first'},
    {l:'Keyword in description', ok:kw&&desc.toLowerCase().includes(kw), info:kw?'':'Set keyword first'},
    {l:'Content 300+ words', ok:wc>=300, warn:wc>0&&wc<300, info:wc+' words'},
    {l:'Has headings (H2/H3)', ok:hasH, info:hasH?'✓':'Add structure'},
    {l:'Has images', ok:hasImg, info:hasImg?'✓':'Add visuals'},
    {l:'Has internal links', ok:hasLinks, info:hasLinks?'✓':'Add links'},
  ];

  var good = checks.filter(function(c){ return c.ok; }).length;
  var pct = Math.round(good / checks.length * 100);
  var circ = 100.5;
  var offset = circ - (circ * pct / 100);
  var ring = document.getElementById('seoRing');
  ring.style.strokeDashoffset = offset;
  ring.style.stroke = pct>=70?'#16a34a':pct>=40?'#b45309':'#dc2626';
  document.getElementById('seoRingNum').textContent = pct;

  var badge = document.getElementById('seoBadge');
  if(pct>=70){ badge.style.background='#f0fdf4';badge.style.color='#16a34a';badge.style.border='1px solid #16a34a';badge.textContent='Good'; }
  else if(pct>=40){ badge.style.background='#fffbeb';badge.style.color='#b45309';badge.style.border='1px solid #b45309';badge.textContent='Needs Work'; }
  else{ badge.style.background='#fef2f2';badge.style.color='#dc2626';badge.style.border='1px solid #dc2626';badge.textContent='Poor'; }

  document.getElementById('seoCheckList').innerHTML = checks.map(function(c){
    var ic, cls;
    if(c.ok){ ic='bi-check-circle-fill';cls='color:#16a34a'; }
    else if(c.warn){ ic='bi-exclamation-circle-fill';cls='color:#b45309'; }
    else{ ic='bi-x-circle-fill';cls='color:#dc2626'; }
    return '<div class="seo-check-row"><i class="bi '+ic+'" style="font-size:14px;flex-shrink:0;margin-top:1px;'+cls+'"></i><div><div>'+c.l+'</div><div style="font-size:11px;color:var(--text3)">'+c.info+'</div></div></div>';
  }).join('');
}

// ── TABLE PICKER ───────────────────────
function buildTablePickerGrid(){
  var g = document.getElementById('tablePickerGrid');
  for(var r=1;r<=5;r++){
    for(var c=1;c<=6;c++){
      var cell = document.createElement('div');
      cell.className='tpc';
      cell.dataset.r=r; cell.dataset.c=c;
      cell.addEventListener('mouseover', (function(er,ec){
        return function(){
          document.querySelectorAll('.tpc').forEach(function(tc){
            tc.classList.toggle('hov', +tc.dataset.r<=er && +tc.dataset.c<=ec);
          });
          document.getElementById('tablePickerSize').textContent = er+' × '+ec;
        };
      })(r,c));
      cell.addEventListener('click', (function(er,ec){ return function(){ doInsertTable(er,ec); }; })(r,c));
      g.appendChild(cell);
    }
  }
}
function showTablePicker(){
  var popup = document.getElementById('tablePickerPopup');
  var btn = document.getElementById('tablePickerBtn');
  var rect = btn.getBoundingClientRect();
  var isOpen = popup.style.display==='block';
  popup.style.display = isOpen ? 'none' : 'block';
  if(!isOpen){
    popup.style.position='fixed'; popup.style.top=(rect.bottom+4)+'px'; popup.style.left=rect.left+'px';
    setTimeout(function(){
      document.addEventListener('click', function h(e){
        if(!popup.contains(e.target)&&e.target!==btn){ popup.style.display='none'; document.removeEventListener('click',h); }
      });
    },10);
  }
}
function doInsertTable(rows, cols){
  document.getElementById('tablePickerPopup').style.display='none';
  var thead='<thead><tr>'+Array(cols).fill().map(function(_,i){ return '<th>Header '+(i+1)+'</th>'; }).join('')+'</tr></thead>';
  var tbody='<tbody>'+Array(rows).fill().map(function(){ return '<tr>'+Array(cols).fill('<td>Cell</td>').join('')+'</tr>'; }).join('')+'</tbody>';
  document.getElementById('richEditorEN').focus();
  document.execCommand('insertHTML', false, '<table>'+thead+tbody+'</table><p></p>');
}

// ── IMAGE UPLOAD ───────────────────────
function handleImgUpload(input){
  var f=input.files[0]; if(!f)return;
  var reader=new FileReader();
  reader.onload=function(e){ showImagePreview(e.target.result, f); };
  reader.readAsDataURL(f);
}
function handleImgDrop(e){
  e.preventDefault();
  document.getElementById('imgDropzone').classList.remove('dragover');
  var f=e.dataTransfer.files[0];
  if(!f||!f.type.startsWith('image/'))return;
  var reader=new FileReader();
  reader.onload=function(ev){ showImagePreview(ev.target.result, f); };
  reader.readAsDataURL(f);
}
function showImagePreview(src, file){
  var prev=document.getElementById('featImgPreview');
  prev.src=src; prev.classList.add('show');
  document.getElementById('imgDropMsg').style.display='none';
  document.getElementById('imgMetaSection').style.display='block';
  document.getElementById('imgFileSize').value=(file.size/1024).toFixed(1)+' KB';
  document.getElementById('imgFormat').value=file.type.split('/')[1].toUpperCase();
  var img=new Image();
  img.onload=function(){ document.getElementById('imgW').value=this.width+'px'; document.getElementById('imgH').value=this.height+'px'; };
  img.src=src;
  var ogBox=document.getElementById('ogImgBox');
  ogBox.innerHTML='<img src="'+src+'" style="width:100%;height:100%;object-fit:cover">';
  _mediaFiles.push({src:src, name:file.name});
  renderMediaLib();
  showNotif('Image uploaded!','success');
}
function removeFeatImg(){
  document.getElementById('featImgPreview').classList.remove('show');
  document.getElementById('featImgPreview').src='';
  document.getElementById('imgDropMsg').style.display='block';
  document.getElementById('imgMetaSection').style.display='none';
  document.getElementById('ogImgBox').innerHTML='<i class="bi bi-image" style="font-size:32px"></i>';
}
function insertFeatImgIntoContent(){
  var src=document.getElementById('featImgPreview').src;
  var alt=document.getElementById('imgAlt').value||'';
  var cap=document.getElementById('imgCaption').value||'';
  var html='<figure><img src="'+src+'" alt="'+alt+'" style="max-width:100%;border-radius:8px"><figcaption>'+cap+'</figcaption></figure><p></p>';
  document.getElementById('richEditorEN').focus();
  document.execCommand('insertHTML', false, html);
  switchPanel('write', null, 'tab-write');
  showNotif('Image inserted into content','success');
}
function renderMediaLib(){
  var g=document.getElementById('mediaLibGrid');
  document.getElementById('mediaLibEmpty').style.display=_mediaFiles.length?'none':'block';
  g.innerHTML=_mediaFiles.map(function(f,i){
    return '<div class="media-item" onclick="this.classList.toggle(\'sel\')"><img src="'+f.src+'" alt="'+f.name+'"><div class="media-check"><i class="bi bi-check"></i></div></div>';
  }).join('');
}

// ── CUSTOM FIELDS ──────────────────────
function addCustomField(){
  _cfCount++;
  document.getElementById('cfEmpty').style.display='none';
  var d=document.createElement('div');
  d.className='cf-row'; d.id='cf-'+_cfCount;
  d.innerHTML='<i class="bi bi-grip-vertical cf-grip"></i>'+
    '<input type="text" name="custom_labels[]" class="form-control" placeholder="Label" oninput="renderCFPreview()" style="font-size:12px">'+
    '<select name="custom_types[]" class="form-control" style="font-size:12px"><option>Text</option><option>Number</option><option>URL</option><option>Date</option><option>Textarea</option></select>'+
    '<input type="text" name="custom_values[]" class="form-control" placeholder="Value" oninput="renderCFPreview()" style="font-size:12px">'+
    '<button type="button" class="btn btn-xs btn-danger" style="padding:0;width:28px;height:28px;justify-content:center" onclick="this.closest(\'.cf-row\').remove();renderCFPreview()"><i class="bi bi-trash"></i></button>';
  document.getElementById('cfContainer').appendChild(d);
  renderCFPreview();
  if(window.Sortable) Sortable.create(document.getElementById('cfContainer'),{handle:'.cf-grip'});
}
function renderCFPreview(){
  var rows=document.querySelectorAll('.cf-row');
  if(!rows.length){ document.getElementById('cfLivePreview').innerHTML='<span style="color:var(--text3)">No fields yet</span>'; return; }
  var html='<table style="width:100%;border-collapse:collapse;font-size:13px">';
  rows.forEach(function(row){
    var ins=row.querySelectorAll('input[type=text]');
    var label=ins[0]?ins[0].value:'', val=ins[1]?ins[1].value:'';
    if(!label&&!val) return;
    html+='<tr><td style="padding:6px 0;color:var(--text3);font-weight:600;width:40%;border-bottom:1px solid var(--border)">'+label+'</td><td style="padding:6px 0;border-bottom:1px solid var(--border)">'+val+'</td></tr>';
  });
  html+='</table>';
  document.getElementById('cfLivePreview').innerHTML=html;
}

// ── TAGS ───────────────────────────────
function handleTagInput(e){
  if(e.key!=='Enter'&&e.key!==',') return;
  e.preventDefault();
  var v=e.target.value.trim().replace(/,$/,'');
  if(v) addTag(v);
  e.target.value='';
}
function addTag(name){
  if(_tags.includes(name)) return;
  _tags.push(name);
  renderTags();
}
function removeTag(i){ _tags.splice(i,1); renderTags(); }
function renderTags(){
  document.getElementById('tagsHidden').value=_tags.join(',');
  document.getElementById('tagDisplay').innerHTML=_tags.map(function(t,i){
    return '<span class="tag-chip">'+t+'<button type="button" onclick="removeTag('+i+')">×</button></span>';
  }).join('');
}

// ── REVISIONS ──────────────────────────
function addRevision(label){
  var snap={time:new Date(),label:label,title:document.getElementById('titleInput').value,content:document.getElementById('richEditorEN').innerHTML};
  _revisions.unshift(snap);
  if(_revisions.length>25) _revisions.pop();
  renderRevisions();
}
function renderRevisions(){
  document.getElementById('revisionList').innerHTML=_revisions.map(function(r,i){
    return '<div class="rev-item" onclick="restoreRev('+i+')">'+
      '<div class="rev-dot'+(i===0?' current':'')+'"></div>'+
      '<div style="flex:1;font-size:12px"><strong style="color:var(--text1)">'+r.label+'</strong><br><span style="color:var(--text3)">'+r.time.toLocaleTimeString('en-IN')+'</span></div>'+
      '<i class="bi bi-arrow-counterclockwise" style="color:var(--text3);font-size:13px"></i></div>';
  }).join('');
}
function restoreRev(i){
  if(!confirm('Restore this revision? Current content will be replaced.')) return;
  var r=_revisions[i];
  document.getElementById('richEditorEN').innerHTML=r.content;
  document.getElementById('titleInput').value=r.title;
  onTitleInput(r.title);
  onEditorChange();
  showNotif('Revision restored','success');
}

// ── AUTO SAVE ──────────────────────────
function scheduleAutoSave(){
  clearTimeout(_autoSaveTimer);
  document.getElementById('autoSaveDot').style.background='#f59e0b';
  document.getElementById('autoSaveLabel').textContent='Saving...';
  _autoSaveTimer=setTimeout(function(){
    addRevision('Auto-save');
    document.getElementById('autoSaveDot').style.background='#16a34a';
    document.getElementById('autoSaveLabel').textContent='Saved';
    setTimeout(function(){ document.getElementById('autoSaveDot').style.background='var(--border)'; document.getElementById('autoSaveLabel').textContent='All changes saved'; },2000);
  },2000);
}
function saveDraft(){
  addRevision('Manual save');
  showNotif('Draft saved!','success');
  document.getElementById('autoSaveDot').style.background='#16a34a';
  document.getElementById('autoSaveLabel').textContent='Saved';
}

function publishPost(){
  var title = document.getElementById('titleInput').value;
  if(!title){ showNotif('Please add a title first','info'); return; }
  
  // Saari values copy karo hidden form mein
  document.getElementById('hiddenContent').value = document.getElementById('richEditorEN').innerHTML;
  document.getElementById('hiddenContentHI').value = document.getElementById('richEditorHI').innerHTML;
  document.getElementById('hTitle').value = document.getElementById('titleInput').value;
  document.getElementById('hTitleHi').value = document.getElementById('titleHiInput').value;
  document.getElementById('hDesc').value = document.getElementById('descInput').value;
  document.getElementById('hMetaTitle').value = document.getElementById('metaTitle').value;
  document.getElementById('hMetaDesc').value = document.getElementById('metaDesc').value;
  document.getElementById('hMetaKw').value = document.getElementById('metaKw').value;
  document.getElementById('hStatus').value = document.getElementById('postStatus').value;
  document.getElementById('hLanguage').value = document.querySelector('select[name="language"]').value;
  document.getElementById('hCategory').value = document.querySelector('select[name="category_id"]').value;
  document.getElementById('hTags').value = document.getElementById('tagsHidden').value;
  document.getElementById('hAuthor').value = document.querySelector('input[name="author"]').value;
  document.getElementById('hCoAuthor').value = document.querySelector('input[name="co_author"]').value;
  document.getElementById('hCanonical').value = document.querySelector('input[name="canonical_url"]').value;
  document.getElementById('hFeatured').value = document.querySelector('input[name="is_featured"]').checked ? '1' : '';
  document.getElementById('hBreaking').value = document.querySelector('input[name="is_breaking"]').checked ? '1' : '';
  
  addRevision('Published');
  showNotif('Post published!','success');
  document.getElementById('postForm').submit();
}

// ── STATUS ─────────────────────────────
function onStatusChange(v){
  document.getElementById('scheduleRow').style.display = v==='scheduled'?'block':'none';
}

// ── FOCUS MODE ─────────────────────────
function toggleFocusMode(){
  document.getElementById('focusArea').innerHTML=document.getElementById('richEditorEN').innerHTML;
  document.getElementById('focusOverlay').classList.add('show');
  document.getElementById('focusArea').focus();
}
function closeFocus(){ document.getElementById('focusOverlay').classList.remove('show'); }
function applyFocusContent(){
  document.getElementById('richEditorEN').innerHTML=document.getElementById('focusArea').innerHTML;
  onEditorChange();
  closeFocus();
  showNotif('Content updated','success');
}

// ── SCHEMA ─────────────────────────────
function generateSchema(){
  var type=document.getElementById('schemaTypeSelect').value;
  var title=document.getElementById('titleInput').value||'Post Title';
  var schema={'@context':'https://schema.org','@type':type,'headline':title,'datePublished':new Date().toISOString().split('T')[0],'dateModified':new Date().toISOString().split('T')[0],'author':{'@type':'Person','name':'Admin'},'publisher':{'@type':'Organization','name':'Dreams'},'inLanguage':'en'};
  document.getElementById('schemaOutput').textContent=JSON.stringify(schema,null,2);
}
function copySchema(){
  navigator.clipboard.writeText(document.getElementById('schemaOutput').textContent);
  showNotif('Schema copied!','success');
}

// ── AI ─────────────────────────────────
function aiQuick(prefix){ document.getElementById('aiPromptInput').value=prefix; switchPanel('ai',null,'tab-ai'); document.getElementById('aiPromptInput').focus(); }
function runAIWrite(){
  var prompt=document.getElementById('aiPromptInput').value.trim();
  if(!prompt)return;
  document.getElementById('aiResultCard').style.display='block';
  document.getElementById('aiResultText').innerHTML='<span style="color:var(--text3)">Generating...</span>';
  // Simulate - replace with actual API call
  setTimeout(function(){
    document.getElementById('aiResultText').textContent='Here is AI-generated content based on your prompt: "'+prompt.substring(0,60)+'...". Connect to the AI API in your controller to get real responses. This placeholder shows where the result appears.';
  },1200);
}
function copyAI(){ navigator.clipboard.writeText(document.getElementById('aiResultText').textContent); showNotif('Copied!','success'); }
function insertAIToEditor(){
  var txt=document.getElementById('aiResultText').textContent;
  document.getElementById('richEditorEN').focus();
  document.execCommand('insertText',false,txt);
  switchPanel('write',null,'tab-write');
  showNotif('Inserted into editor','success');
}

// ── NOTIFY ─────────────────────────────
function showNotif(msg, type){
  var n=document.getElementById('pnotif');
  n.className='pnotif pnotif-'+(type||'success')+' show';
  document.getElementById('pnotifMsg').textContent=msg;
  n.querySelector('i').className='bi bi-'+(type==='success'?'check-circle-fill':'info-circle-fill');
  setTimeout(function(){ n.classList.remove('show'); },3000);
}
</script>
