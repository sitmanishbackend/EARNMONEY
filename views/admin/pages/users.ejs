<!DOCTYPE html>
<html lang="en"><head><meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1.0">
<title><%= title %> – Dreams Admin</title>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
<%- include('../partials/head') %>
</head><body>
<%- include('../partials/sidebar', { currentRoute: '/admin/users' }) %>
<div class="main-content" id="mainContent">
<%- include('../partials/topbar') %>
<main class="page-content">
<%- include('../partials/flash') %>
<div class="page-header">
  <div><div class="page-title">Users Management</div><div class="page-subtitle">Manage all users and their roles</div></div>
  <button class="btn btn-primary" onclick="openModal('addUserModal')"><i class="bi bi-person-plus"></i> Add User</button>
</div>

<!-- STATS -->
<div class="grid grid-4 mb-4">
  <% const roleCount = {}; users.forEach(u=>{ const rn = u.role?u.role.slug:'user'; roleCount[rn]=(roleCount[rn]||0)+1; }); %>
  <div class="stat-card"><div class="stat-icon bg-primary-soft"><i class="bi bi-people"></i></div><div class="stat-info"><div class="stat-val"><%= users.length %></div><div class="stat-lbl">Total Users</div></div></div>
  <div class="stat-card"><div class="stat-icon bg-danger-soft"><i class="bi bi-shield-fill"></i></div><div class="stat-info"><div class="stat-val"><%= roleCount['super_admin']||0 %></div><div class="stat-lbl">Super Admins</div></div></div>
  <div class="stat-card"><div class="stat-icon bg-warning-soft"><i class="bi bi-person-badge"></i></div><div class="stat-info"><div class="stat-val"><%= (roleCount['admin']||0)+(roleCount['developer']||0) %></div><div class="stat-lbl">Admins/Devs</div></div></div>
  <div class="stat-card"><div class="stat-icon bg-success-soft"><i class="bi bi-person-check"></i></div><div class="stat-info"><div class="stat-val"><%= users.filter(u=>u.is_active).length %></div><div class="stat-lbl">Active Users</div></div></div>
</div>

<div class="card">
  <div class="card-header"><div class="card-title"><i class="bi bi-list-ul"></i> All Users</div></div>
  <div class="table-wrap">
    <table>
      <thead><tr><th>#</th><th>User</th><th>Contact</th><th>Role</th><th>Salary</th><th>Joined</th><th>Status</th><th>Last Login</th><th>Actions</th></tr></thead>
      <tbody>
        <% users.forEach((user,i)=>{ %>
        <tr>
          <td style="color:var(--text3);font-size:0.75rem"><%= i+1 %></td>
          <td>
            <div style="display:flex;align-items:center;gap:0.75rem">
              <div style="width:36px;height:36px;border-radius:50%;background:var(--primary);color:#fff;display:flex;align-items:center;justify-content:center;font-weight:700;flex-shrink:0"><%= user.name.charAt(0).toUpperCase() %></div>
              <div><div style="font-weight:600;font-size:0.85rem"><%= user.name %></div><div style="font-size:0.7rem;color:var(--text3)"><%= user.email %></div></div>
            </div>
          </td>
          <td style="font-size:0.78rem"><%= user.phone||'—' %></td>
          <td>
            <% const roleColors = {super_admin:'danger',admin:'warning',developer:'info',user:'secondary'}; %>
            <span class="badge badge-<%= user.role ? (roleColors[user.role.slug]||'secondary') : 'secondary' %>">
              <%= user.role ? user.role.name : 'No Role' %>
            </span>
          </td>
          <td style="font-size:0.8rem">₹<%= parseFloat(user.salary_amount||0).toLocaleString() %>/<%= user.salary_type||'day' %></td>
          <td style="font-size:0.75rem;color:var(--text3)"><%= user.joining_date ? new Date(user.joining_date).toLocaleDateString('en-IN') : '—' %></td>
          <td><span class="badge badge-<%= user.is_active?'success':'danger' %>"><%= user.is_active?'Active':'Inactive' %></span></td>
          <td style="font-size:0.72rem;color:var(--text3)"><%= user.last_login ? new Date(user.last_login).toLocaleDateString('en-IN') : 'Never' %></td>
          <td>
            <div style="display:flex;gap:0.3rem">
              <a href="/admin/attendance/<%= user.id %>" class="btn btn-xs btn-secondary" title="Attendance"><i class="bi bi-calendar-check"></i></a>
              <button class="btn btn-xs btn-outline" onclick='openEditUser(<%- JSON.stringify({id:user.id,name:user.name,email:user.email,phone:user.phone||"",role_id:user.role_id,salary_type:user.salary_type,salary_amount:user.salary_amount,joining_date:user.joining_date||"",is_active:user.is_active}) %>)' title="Edit"><i class="bi bi-pencil"></i></button>
              <% if(user.id !== (authUser ? authUser.id : 0)){ %>
              <form method="POST" action="/admin/users/<%= user.id %>?_method=DELETE" onsubmit="return confirm('Delete user '+`<%= user.name %>`+'?')">
                <button class="btn btn-xs btn-danger" title="Delete"><i class="bi bi-trash"></i></button>
              </form>
              <% } %>
            </div>
          </td>
        </tr>
        <% }) %>
        <% if(!users.length){ %><tr><td colspan="9"><div class="empty-state"><i class="bi bi-people"></i><h3>No users found</h3></div></td></tr><% } %>
      </tbody>
    </table>
  </div>
</div>

<!-- ADD USER MODAL -->
<div class="modal-overlay" id="addUserModal">
  <div class="modal">
    <div class="modal-header"><div class="modal-title"><i class="bi bi-person-plus"></i> Add New User</div><button class="modal-close" onclick="closeModal('addUserModal')"><i class="bi bi-x"></i></button></div>
    <div class="modal-body">
      <form method="POST" action="/admin/users">
        <div class="grid grid-2">
          <div class="form-group"><label>Full Name *</label><input type="text" name="name" class="form-control" placeholder="Rahul Sharma" required></div>
          <div class="form-group"><label>Email *</label><input type="email" name="email" class="form-control" placeholder="rahul@email.com" required></div>
          <div class="form-group"><label>Phone</label><input type="text" name="phone" class="form-control" placeholder="98765 43210"></div>
          <div class="form-group"><label>Password *</label><input type="password" name="password" class="form-control" placeholder="Min 8 characters" required></div>
          <div class="form-group"><label>Role *</label>
            <select name="role_id" class="form-control" required>
              <% roles.forEach(r=>{ %><option value="<%= r.id %>"><%= r.name %></option><% }) %>
            </select>
          </div>
          <div class="form-group"><label>Joining Date</label><input type="date" name="joining_date" class="form-control"></div>
          <div class="form-group"><label>Salary Type</label>
            <select name="salary_type" class="form-control">
              <option value="daily">Daily</option><option value="monthly">Monthly</option><option value="hourly">Hourly</option>
            </select>
          </div>
          <div class="form-group"><label>Salary Amount (₹)</label><input type="number" name="salary_amount" class="form-control" placeholder="0" step="0.01"></div>
        </div>
        <div class="modal-footer" style="padding:0;border:none;margin-top:0.5rem">
          <button type="button" class="btn btn-secondary" onclick="closeModal('addUserModal')">Cancel</button>
          <button type="submit" class="btn btn-primary"><i class="bi bi-person-plus"></i> Add User</button>
        </div>
      </form>
    </div>
  </div>
</div>

<!-- EDIT USER MODAL -->
<div class="modal-overlay" id="editUserModal">
  <div class="modal">
    <div class="modal-header"><div class="modal-title"><i class="bi bi-pencil"></i> Edit User</div><button class="modal-close" onclick="closeModal('editUserModal')"><i class="bi bi-x"></i></button></div>
    <div class="modal-body">
      <form method="POST" id="editUserForm">
        <div class="grid grid-2">
          <div class="form-group"><label>Full Name *</label><input type="text" name="name" id="eu_name" class="form-control" required></div>
          <div class="form-group"><label>Email *</label><input type="email" name="email" id="eu_email" class="form-control" required></div>
          <div class="form-group"><label>Phone</label><input type="text" name="phone" id="eu_phone" class="form-control"></div>
          <div class="form-group"><label>New Password</label><input type="password" name="password" class="form-control" placeholder="Leave blank to keep current"></div>
          <div class="form-group"><label>Role *</label>
            <select name="role_id" id="eu_role" class="form-control">
              <% roles.forEach(r=>{ %><option value="<%= r.id %>"><%= r.name %></option><% }) %>
            </select>
          </div>
          <div class="form-group"><label>Joining Date</label><input type="date" name="joining_date" id="eu_joining" class="form-control"></div>
          <div class="form-group"><label>Salary Type</label>
            <select name="salary_type" id="eu_salary_type" class="form-control">
              <option value="daily">Daily</option><option value="monthly">Monthly</option><option value="hourly">Hourly</option>
            </select>
          </div>
          <div class="form-group"><label>Salary Amount (₹)</label><input type="number" name="salary_amount" id="eu_salary" class="form-control" step="0.01"></div>
        </div>
        <div class="form-check mb-3"><input type="checkbox" name="is_active" id="eu_active" value="1"><label for="eu_active">Active User</label></div>
        <div class="modal-footer" style="padding:0;border:none">
          <button type="button" class="btn btn-secondary" onclick="closeModal('editUserModal')">Cancel</button>
          <button type="submit" class="btn btn-primary"><i class="bi bi-check"></i> Update User</button>
        </div>
      </form>
    </div>
  </div>
</div>

<script>
function openEditUser(u){
  document.getElementById('editUserForm').action='/admin/users/'+u.id+'?_method=PUT';
  document.getElementById('eu_name').value=u.name||'';
  document.getElementById('eu_email').value=u.email||'';
  document.getElementById('eu_phone').value=u.phone||'';
  document.getElementById('eu_role').value=u.role_id||'';
  document.getElementById('eu_joining').value=u.joining_date||'';
  document.getElementById('eu_salary_type').value=u.salary_type||'daily';
  document.getElementById('eu_salary').value=u.salary_amount||'';
  document.getElementById('eu_active').checked=!!u.is_active;
  openModal('editUserModal');
}
</script>
<%- include('../partials/scripts') %>
</body></html>
