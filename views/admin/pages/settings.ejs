<!DOCTYPE html>
<html lang="en"><head><meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1.0">
<title><%= title %> – Dreams Admin</title>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
<%- include('../partials/head') %>
</head><body>
<%- include('../partials/sidebar', { currentRoute: '/admin/settings' }) %>
<div class="main-content" id="mainContent">
<%- include('../partials/topbar') %>
<main class="page-content">
<%- include('../partials/flash') %>
<div class="page-header">
  <div><div class="page-title">Site Settings</div><div class="page-subtitle">Configure your website settings</div></div>
</div>

<form method="POST" action="/admin/settings">
<div class="grid grid-2" style="align-items:start">
  <!-- GENERAL -->
  <div class="card">
    <div class="card-header"><div class="card-title"><i class="bi bi-gear"></i> General Settings</div></div>
    <div class="card-body">
      <div class="form-group"><label>Site Name</label><input type="text" name="site_name" class="form-control" value="<%= settingsMap.site_name||'' %>"></div>
      <div class="form-group"><label>Tagline</label><input type="text" name="site_tagline" class="form-control" value="<%= settingsMap.site_tagline||'' %>"></div>
      <div class="form-group"><label>Description</label><textarea name="site_description" class="form-control" rows="2"><%= settingsMap.site_description||'' %></textarea></div>
      <div class="form-group"><label>Email</label><input type="email" name="site_email" class="form-control" value="<%= settingsMap.site_email||'' %>"></div>
      <div class="form-group"><label>Phone</label><input type="text" name="site_phone" class="form-control" value="<%= settingsMap.site_phone||'' %>"></div>
      <div class="form-group"><label>Default Language</label>
        <select name="default_language" class="form-control">
          <option value="hi" <%= settingsMap.default_language==='hi'?'selected':'' %>>Hindi</option>
          <option value="en" <%= settingsMap.default_language==='en'?'selected':'' %>>English</option>
          <option value="both" <%= settingsMap.default_language==='both'?'selected':'' %>>Both</option>
        </select>
      </div>
    </div>
  </div>

  <!-- BLOG -->
  <div class="card">
    <div class="card-header"><div class="card-title"><i class="bi bi-file-earmark-text"></i> Blog Settings</div></div>
    <div class="card-body">
      <div class="form-group"><label>Posts Per Page</label><input type="number" name="posts_per_page" class="form-control" value="<%= settingsMap.posts_per_page||12 %>"></div>
      <div class="form-group"><label>Google Analytics ID</label><input type="text" name="google_analytics" class="form-control" placeholder="G-XXXXXXXXXX" value="<%= settingsMap.google_analytics||'' %>"></div>
      <div class="form-group"><label>AdSense Publisher ID</label><input type="text" name="adsense_code" class="form-control" placeholder="ca-pub-XXXXXXXXXX" value="<%= settingsMap.adsense_code||'' %>"></div>
    </div>
  </div>

  <!-- SOCIAL -->
  <div class="card">
    <div class="card-header"><div class="card-title"><i class="bi bi-share"></i> Social Media Links</div></div>
    <div class="card-body">
      <div class="form-group"><label><i class="bi bi-facebook" style="color:#1877f2"></i> Facebook URL</label><input type="url" name="facebook_url" class="form-control" placeholder="https://facebook.com/yourpage" value="<%= settingsMap.facebook_url||'' %>"></div>
      <div class="form-group"><label><i class="bi bi-youtube" style="color:#ff0000"></i> YouTube URL</label><input type="url" name="youtube_url" class="form-control" placeholder="https://youtube.com/@yourchannel" value="<%= settingsMap.youtube_url||'' %>"></div>
      <div class="form-group"><label><i class="bi bi-telegram" style="color:#0088cc"></i> Telegram URL</label><input type="url" name="telegram_url" class="form-control" placeholder="https://t.me/yourchannel" value="<%= settingsMap.telegram_url||'' %>"></div>
      <div class="form-group"><label><i class="bi bi-whatsapp" style="color:#25d366"></i> WhatsApp Group</label><input type="url" name="whatsapp_url" class="form-control" placeholder="https://chat.whatsapp.com/..." value="<%= settingsMap.whatsapp_url||'' %>"></div>
      <div class="form-group"><label><i class="bi bi-instagram" style="color:#e4405f"></i> Instagram URL</label><input type="url" name="instagram_url" class="form-control" placeholder="https://instagram.com/yourprofile" value="<%= settingsMap.instagram_url||'' %>"></div>
    </div>
  </div>

  <!-- FOOTER -->
  <div class="card">
    <div class="card-header"><div class="card-title"><i class="bi bi-type"></i> Footer & Copyright</div></div>
    <div class="card-body">
      <div class="form-group"><label>Copyright Text</label><input type="text" name="copyright_text" class="form-control" placeholder="© 2024 Dreams Technology. All rights reserved." value="<%= settingsMap.copyright_text||'' %>"></div>
      <div class="form-group"><label>Footer About Text</label><textarea name="footer_about" class="form-control" rows="3" placeholder="About your website..."><%= settingsMap.footer_about||'' %></textarea></div>
      <div class="form-group"><label>Google Search Console Code</label><textarea name="gsc_code" class="form-control" rows="2" placeholder="<meta name='google-site-verification' ...>"><%= settingsMap.gsc_code||'' %></textarea></div>
      <div class="form-group"><label>Header Script</label><textarea name="header_script" class="form-control" rows="2" placeholder="Scripts to add in <head>..."><%= settingsMap.header_script||'' %></textarea></div>
      <div class="form-group"><label>Footer Script</label><textarea name="footer_script" class="form-control" rows="2" placeholder="Scripts to add before </body>..."><%= settingsMap.footer_script||'' %></textarea></div>
    </div>
  </div>
</div>

<div style="margin-top:1.25rem;text-align:right">
  <button type="submit" class="btn btn-primary" style="padding:0.75rem 2rem;font-size:0.95rem"><i class="bi bi-save"></i> Save All Settings</button>
</div>
</form>
</main></div>
<%- include('../partials/scripts') %>
</body></html>
