<!DOCTYPE html>
<html lang="en"><head><meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1.0">
<title><%= title %> – Dreams Admin</title>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
<%- include('../partials/head') %>
</head><body>
<%- include('../partials/sidebar', { currentRoute: '/admin/attendance' }) %>
<div class="main-content" id="mainContent">
<%- include('../partials/topbar') %>
<main class="page-content">
<%- include('../partials/flash') %>

<div class="page-header">
  <div>
    <div class="breadcrumb"><a href="/admin/attendance">Attendance</a><span class="sep">/</span><span><%= user.name %></span></div>
    <div class="page-title"><%= user.name %></div>
    <div class="page-subtitle"><%= user.role ? user.role.name : 'Employee' %> • Joined: <%= user.joining_date || 'N/A' %></div>
  </div>
  <div class="d-flex gap-2">
    <form method="GET" style="display:flex;gap:0.5rem">
      <select name="month" class="form-control" style="height:36px;font-size:0.8rem">
        <% ['January','February','March','April','May','June','July','August','September','October','November','December'].forEach((m,i)=>{ %>
          <option value="<%= i+1 %>" <%= month==i+1?'selected':'' %>><%= m %></option>
        <% }) %>
      </select>
      <select name="year" class="form-control" style="height:36px;font-size:0.8rem">
        <% for(let y=2023;y<=2027;y++){ %><option value="<%= y %>" <%= year==y?'selected':'' %>><%= y %></option><% } %>
      </select>
      <button class="btn btn-primary btn-sm">Go</button>
    </form>
    <a href="/admin/attendance" class="btn btn-secondary"><i class="bi bi-arrow-left"></i> Back</a>
  </div>
</div>

<!-- SUMMARY STATS -->
<div class="grid grid-stats mb-4">
  <div class="stat-card"><div class="stat-icon bg-success-soft"><i class="bi bi-check-circle"></i></div><div class="stat-info"><div class="stat-val text-success"><%= totalPresent %></div><div class="stat-lbl">Total Present</div></div></div>
  <div class="stat-card"><div class="stat-icon bg-danger-soft"><i class="bi bi-x-circle"></i></div><div class="stat-info"><div class="stat-val text-danger"><%= totalAbsent %></div><div class="stat-lbl">Total Absent</div></div></div>
  <div class="stat-card"><div class="stat-icon bg-purple-soft"><i class="bi bi-clock-history"></i></div><div class="stat-info"><div class="stat-val" style="color:#7c3aed"><%= totalOT %></div><div class="stat-lbl">Overtime Days</div></div></div>
  <div class="stat-card"><div class="stat-icon bg-warning-soft"><i class="bi bi-cash-stack"></i></div><div class="stat-info"><div class="stat-val text-warning">₹<%= totalAdvance.toLocaleString() %></div><div class="stat-lbl">Total Advance</div></div></div>
</div>

<div class="grid grid-2">
  <!-- ATTENDANCE TABLE -->
  <div class="card">
    <div class="card-header">
      <div class="card-title"><i class="bi bi-table"></i> Daily Records</div>
      <span class="badge badge-primary"><%= new Date(year,month-1).toLocaleString('en-IN',{month:'long'}) %> <%= year %></span>
    </div>
    <div class="table-wrap" style="max-height:500px;overflow-y:auto">
      <table>
        <thead><tr><th>Date</th><th>Day</th><th>Status</th><th>Advance</th><th>Notes</th></tr></thead>
        <tbody>
          <% for(let d=1; d<=daysInMonth; d++) { %>
            <% const dateStr = `${year}-${String(month).padStart(2,'0')}-${String(d).padStart(2,'0')}`; %>
            <% const rec = byDate[dateStr]; %>
            <% const dow = ['Sun','Mon','Tue','Wed','Thu','Fri','Sat'][new Date(dateStr).getDay()]; %>
            <tr <% if(dow==='Sun'){ %>style="background:#fef9c3"<% } %>>
              <td style="font-weight:600"><%= d %></td>
              <td style="color:var(--text3);font-size:0.75rem"><%= dow %></td>
              <td>
                <% if(rec){ %>
                  <span class="badge badge-<%= rec.status==='P'?'success':rec.status==='A'?'danger':rec.status==='OT'?'info':'warning' %>"><%= rec.status %></span>
                <% } else { %>
                  <span class="badge badge-secondary" style="opacity:0.5">—</span>
                <% } %>
              </td>
              <td style="color:#dc2626;font-size:0.8rem"><% if(rec&&rec.advance_amount>0){ %>₹<%= rec.advance_amount %><% } %></td>
              <td style="font-size:0.75rem;color:var(--text3)"><%= rec ? (rec.notes||'') : '' %></td>
            </tr>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>

  <!-- SALARY CALCULATION -->
  <div style="display:flex;flex-direction:column;gap:1.25rem">
    <div class="card">
      <div class="card-header"><div class="card-title"><i class="bi bi-calculator"></i> Salary Calculation</div></div>
      <div class="card-body">
        <% const dailyRate = user.salary_type === 'daily' ? user.salary_amount : (user.salary_amount / 26); %>
        <% const grossSalary = totalPresent * dailyRate; %>
        <% const netSalary = grossSalary - totalAdvance; %>
        <div style="display:flex;flex-direction:column;gap:0.75rem">
          <div style="display:flex;justify-content:space-between;padding:0.6rem;background:#f8fafc;border-radius:8px">
            <span style="font-size:0.82rem">Salary Type</span><strong><%= user.salary_type %></strong>
          </div>
          <div style="display:flex;justify-content:space-between;padding:0.6rem;background:#f8fafc;border-radius:8px">
            <span style="font-size:0.82rem">Rate</span><strong>₹<%= user.salary_amount %>/<%= user.salary_type==='daily'?'day':'month' %></strong>
          </div>
          <div style="display:flex;justify-content:space-between;padding:0.6rem;background:#f8fafc;border-radius:8px">
            <span style="font-size:0.82rem">Daily Rate</span><strong>₹<%= parseFloat(dailyRate).toFixed(2) %></strong>
          </div>
          <div style="display:flex;justify-content:space-between;padding:0.6rem;background:#f8fafc;border-radius:8px">
            <span style="font-size:0.82rem">Days Present</span><strong style="color:#16a34a"><%= totalPresent %></strong>
          </div>
          <div style="display:flex;justify-content:space-between;padding:0.6rem;background:#dcfce7;border-radius:8px">
            <span style="font-size:0.82rem;font-weight:600">Gross Salary</span><strong style="color:#16a34a">₹<%= grossSalary.toFixed(2) %></strong>
          </div>
          <div style="display:flex;justify-content:space-between;padding:0.6rem;background:#fee2e2;border-radius:8px">
            <span style="font-size:0.82rem;font-weight:600">Advance Deduction</span><strong style="color:#dc2626">- ₹<%= totalAdvance.toFixed(2) %></strong>
          </div>
          <div style="display:flex;justify-content:space-between;padding:1rem;background:var(--primary);border-radius:8px;color:#fff">
            <span style="font-size:0.95rem;font-weight:700">Net Salary</span><strong style="font-size:1.2rem">₹<%= netSalary.toFixed(2) %></strong>
          </div>
        </div>
        <button class="btn btn-success w-100 mt-3" onclick="openModal('payModal')"><i class="bi bi-cash-coin"></i> Mark as Paid</button>
      </div>
    </div>

    <!-- ATTENDANCE CHART -->
    <div class="card">
      <div class="card-header"><div class="card-title"><i class="bi bi-pie-chart"></i> Month Overview</div></div>
      <div class="card-body"><canvas id="attChart" height="200"></canvas></div>
    </div>
  </div>
</div>

<!-- Pay Modal -->
<div class="modal-overlay" id="payModal">
  <div class="modal" style="max-width:420px">
    <div class="modal-header"><div class="modal-title">Mark Salary Paid</div><button class="modal-close" onclick="closeModal('payModal')"><i class="bi bi-x"></i></button></div>
    <div class="modal-body">
      <form method="POST" action="/admin/attendance/mark">
        <div class="form-group"><label>Payment Date</label><input type="date" name="payment_date" class="form-control" value="<%= new Date().toISOString().split('T')[0] %>"></div>
        <div class="form-group"><label>Payment Method</label>
          <select name="payment_method" class="form-control">
            <option value="cash">Cash</option><option value="bank">Bank Transfer</option><option value="upi">UPI</option>
          </select>
        </div>
        <div class="form-group"><label>Notes</label><input type="text" name="notes" class="form-control" placeholder="Payment remarks..."></div>
        <button type="submit" class="btn btn-success w-100"><i class="bi bi-check"></i> Confirm Payment</button>
      </form>
    </div>
  </div>
</div>

<script>
new Chart(document.getElementById('attChart'),{
  type:'doughnut',
  data:{
    labels:['Present','Absent','Overtime'],
    datasets:[{
      data:[<%= totalPresent %>,<%= totalAbsent %>,<%= totalOT %>],
      backgroundColor:['#16a34a','#dc2626','#7c3aed'],
      borderWidth:0
    }]
  },
  options:{ responsive:true, plugins:{ legend:{ position:'bottom' } } }
});
</script>
<%- include('../partials/scripts') %>
</body></html>
