<!DOCTYPE html>
<html lang="en"><head><meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1.0">
<title><%= title %> – Dreams Admin</title>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
<%- include('../partials/head') %>
</head><body>
<%- include('../partials/sidebar', { currentRoute: '/admin/profile' }) %>
<div class="main-content" id="mainContent">
<%- include('../partials/topbar') %>
<main class="page-content">
<%- include('../partials/flash') %>

<div class="page-header">
  <div>
    <div class="page-title">My Profile</div>
    <div class="page-subtitle">Manage your account information and security settings</div>
  </div>
</div>

<div style="display:grid;grid-template-columns:300px 1fr;gap:1.5rem;align-items:start;max-width:1100px">

  <!-- ─── LEFT: PROFILE CARD ─── -->
  <div style="display:flex;flex-direction:column;gap:1.25rem">

    <!-- Avatar + Info -->
    <div class="card" style="overflow:hidden">
      <!-- Cover Banner -->
      <div style="height:80px;background:linear-gradient(135deg,var(--primary),var(--accent-dark));position:relative"></div>

      <div style="padding:0 1.5rem 1.5rem;text-align:center">
        <!-- Avatar Circle -->
        <div style="position:relative;display:inline-block;margin-top:-44px">
          <% if (authUser && authUser.avatar) { %>
            <img src="<%= authUser.avatar %>" id="avatarPreview"
              style="width:88px;height:88px;border-radius:50%;object-fit:cover;border:4px solid #fff;box-shadow:0 4px 16px rgba(0,0,0,0.15)"
              onerror="this.style.display='none';document.getElementById('avatarInitial').style.display='flex'">
            <div id="avatarInitial"
              style="display:none;width:88px;height:88px;border-radius:50%;background:var(--primary);color:#fff;font-size:2rem;font-weight:800;align-items:center;justify-content:center;border:4px solid #fff;box-shadow:0 4px 16px rgba(0,0,0,0.15)">
              <%= authUser ? authUser.name.charAt(0).toUpperCase() : 'U' %>
            </div>
          <% } else { %>
            <div id="avatarInitial"
              style="width:88px;height:88px;border-radius:50%;background:var(--primary);color:#fff;font-size:2rem;font-weight:800;display:flex;align-items:center;justify-content:center;border:4px solid #fff;box-shadow:0 4px 16px rgba(0,0,0,0.15)">
              <%= authUser ? authUser.name.charAt(0).toUpperCase() : 'U' %>
            </div>
            <img id="avatarPreview" style="display:none;width:88px;height:88px;border-radius:50%;object-fit:cover;border:4px solid #fff;box-shadow:0 4px 16px rgba(0,0,0,0.15)">
          <% } %>

          <!-- Camera icon overlay -->
          <label for="avatarInput" style="position:absolute;bottom:2px;right:2px;width:26px;height:26px;border-radius:50%;background:var(--primary);color:#fff;display:flex;align-items:center;justify-content:center;cursor:pointer;font-size:0.75rem;box-shadow:0 2px 6px rgba(0,0,0,0.25);transition:transform 0.2s" title="Change photo">
            <i class="bi bi-camera-fill"></i>
          </label>
          <input type="file" id="avatarInput" accept="image/*" style="display:none" onchange="previewAvatar(this)">
        </div>

        <div style="margin-top:0.75rem">
          <div style="font-size:1.15rem;font-weight:800;color:var(--text)"><%= authUser ? authUser.name : '' %></div>
          <div style="color:var(--text3);font-size:0.8rem;margin:0.2rem 0"><%= authUser ? authUser.email : '' %></div>
          <span class="badge badge-primary" style="font-size:0.72rem;padding:0.3rem 0.8rem;text-transform:capitalize"><%= authUser ? authUser.role_slug.replace('_',' ') : '' %></span>
        </div>
      </div>

      <!-- Quick Info -->
      <div style="border-top:1px solid var(--border);padding:1rem 1.5rem;display:flex;flex-direction:column;gap:0.6rem">
        <div style="display:flex;align-items:center;gap:0.6rem;font-size:0.8rem;color:var(--text2)">
          <i class="bi bi-envelope" style="color:var(--primary);width:16px"></i>
          <span style="overflow:hidden;text-overflow:ellipsis;white-space:nowrap"><%= authUser ? authUser.email : '' %></span>
        </div>
        <div style="display:flex;align-items:center;gap:0.6rem;font-size:0.8rem;color:var(--text2)">
          <i class="bi bi-shield-check" style="color:var(--primary);width:16px"></i>
          <span style="text-transform:capitalize"><%= authUser ? authUser.role_slug.replace('_',' ') : '' %></span>
        </div>
        <div style="display:flex;align-items:center;gap:0.6rem;font-size:0.8rem;color:var(--text2)">
          <i class="bi bi-circle-fill" style="color:#16a34a;font-size:0.5rem;width:16px;text-align:center"></i>
          <span style="color:#16a34a;font-weight:600">Active</span>
        </div>
      </div>
    </div>

    <!-- Account Stats -->
    <div class="card">
      <div class="card-header"><div class="card-title"><i class="bi bi-bar-chart"></i> Account Info</div></div>
      <div class="card-body" style="padding:1rem">
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:0.75rem">
          <div style="background:var(--accent-light);border-radius:10px;padding:0.85rem;text-align:center">
            <div style="font-size:1.4rem;font-weight:800;color:var(--primary)">1</div>
            <div style="font-size:0.68rem;color:var(--text3);font-weight:600;text-transform:uppercase">Role</div>
          </div>
          <div style="background:#e0f2fe;border-radius:10px;padding:0.85rem;text-align:center">
            <div style="font-size:1.4rem;font-weight:800;color:#0891b2"><i class="bi bi-check2-circle" style="font-size:1.3rem"></i></div>
            <div style="font-size:0.68rem;color:var(--text3);font-weight:600;text-transform:uppercase">Active</div>
          </div>
        </div>
      </div>
    </div>

  </div><!-- end left -->

  <!-- ─── RIGHT: EDIT FORMS ─── -->
  <div style="display:flex;flex-direction:column;gap:1.25rem">

    <!-- Tab Nav -->
    <div style="display:flex;border-bottom:2px solid var(--border);gap:0">
      <button class="prof-tab-btn active" onclick="switchProfTab(this,'tab-info')" style="padding:0.7rem 1.3rem;font-size:0.83rem;font-weight:600;border:none;background:none;cursor:pointer;color:var(--text2);border-bottom:2px solid transparent;margin-bottom:-2px;transition:all 0.2s;display:flex;align-items:center;gap:0.4rem">
        <i class="bi bi-person"></i> Personal Info
      </button>
      <button class="prof-tab-btn" onclick="switchProfTab(this,'tab-security')" style="padding:0.7rem 1.3rem;font-size:0.83rem;font-weight:600;border:none;background:none;cursor:pointer;color:var(--text2);border-bottom:2px solid transparent;margin-bottom:-2px;transition:all 0.2s;display:flex;align-items:center;gap:0.4rem">
        <i class="bi bi-lock"></i> Security
      </button>
      <button class="prof-tab-btn" onclick="switchProfTab(this,'tab-photo')" style="padding:0.7rem 1.3rem;font-size:0.83rem;font-weight:600;border:none;background:none;cursor:pointer;color:var(--text2);border-bottom:2px solid transparent;margin-bottom:-2px;transition:all 0.2s;display:flex;align-items:center;gap:0.4rem">
        <i class="bi bi-image"></i> Profile Photo
      </button>
    </div>

    <!-- Tab: Personal Info -->
    <div id="tab-info" class="prof-tab-content" style="display:block">
      <div class="card">
        <div class="card-header">
          <div class="card-title"><i class="bi bi-person-lines-fill"></i> Personal Information</div>
        </div>
        <div class="card-body">
          <form method="POST" action="/admin/profile" enctype="multipart/form-data">
            <!-- hidden avatar field so form still works even without photo upload -->
            <div class="grid grid-2">
              <div class="form-group">
                <label>Full Name <span style="color:#dc2626">*</span></label>
                <div style="position:relative">
                  <i class="bi bi-person" style="position:absolute;left:0.75rem;top:50%;transform:translateY(-50%);color:var(--text3)"></i>
                  <input type="text" name="name" class="form-control" style="padding-left:2.2rem" value="<%= authUser ? authUser.name : '' %>" required>
                </div>
              </div>
              <div class="form-group">
                <label>Phone Number</label>
                <div style="position:relative">
                  <i class="bi bi-telephone" style="position:absolute;left:0.75rem;top:50%;transform:translateY(-50%);color:var(--text3)"></i>
                  <input type="text" name="phone" class="form-control" style="padding-left:2.2rem" value="<%= authUser && authUser.phone ? authUser.phone : '' %>" placeholder="98765 43210">
                </div>
              </div>
            </div>

            <div class="form-group">
              <label>Email Address</label>
              <div style="position:relative">
                <i class="bi bi-envelope" style="position:absolute;left:0.75rem;top:50%;transform:translateY(-50%);color:var(--text3)"></i>
                <input type="email" class="form-control" style="padding-left:2.2rem;background:#f8fafc;color:var(--text3)" value="<%= authUser ? authUser.email : '' %>" disabled>
              </div>
              <small style="color:var(--text3);font-size:0.72rem">Email cannot be changed. Contact super admin.</small>
            </div>

            <div class="form-group">
              <label>Role</label>
              <div style="display:flex;align-items:center;gap:0.6rem;padding:0.55rem 0.9rem;border:1.5px solid var(--border);border-radius:8px;background:#f8fafc">
                <i class="bi bi-shield-check" style="color:var(--primary)"></i>
                <span style="font-size:0.83rem;color:var(--text2);text-transform:capitalize"><%= authUser ? authUser.role_slug.replace('_',' ') : '' %></span>
                <span class="badge badge-primary" style="margin-left:auto">Read Only</span>
              </div>
            </div>

            <div style="display:flex;justify-content:flex-end;gap:0.75rem;margin-top:0.5rem">
              <button type="reset" class="btn btn-secondary"><i class="bi bi-arrow-counterclockwise"></i> Reset</button>
              <button type="submit" class="btn btn-primary"><i class="bi bi-save"></i> Save Changes</button>
            </div>
          </form>
        </div>
      </div>
    </div>

    <!-- Tab: Security -->
    <div id="tab-security" class="prof-tab-content" style="display:none">
      <div class="card">
        <div class="card-header">
          <div class="card-title"><i class="bi bi-lock-fill"></i> Change Password</div>
        </div>
        <div class="card-body">
          <form method="POST" action="/admin/profile" enctype="multipart/form-data" onsubmit="return validatePw(this)">
            <div style="background:var(--accent-light);border-radius:10px;padding:1rem;margin-bottom:1.25rem;display:flex;gap:0.75rem;align-items:flex-start">
              <i class="bi bi-info-circle-fill" style="color:var(--primary);font-size:1.1rem;margin-top:0.1rem;flex-shrink:0"></i>
              <div style="font-size:0.78rem;color:var(--text2)">
                Use a strong password with at least 8 characters, including uppercase, lowercase, numbers and symbols.
              </div>
            </div>

            <!-- keep name/phone so POST handler works -->
            <input type="hidden" name="name" value="<%= authUser ? authUser.name : '' %>">
            <input type="hidden" name="phone" value="<%= authUser && authUser.phone ? authUser.phone : '' %>">

            <div class="form-group">
              <label>New Password</label>
              <div style="position:relative">
                <i class="bi bi-lock" style="position:absolute;left:0.75rem;top:50%;transform:translateY(-50%);color:var(--text3)"></i>
                <input type="password" name="password" id="pwField" class="form-control" style="padding-left:2.2rem;padding-right:2.5rem" placeholder="Enter new password (min 8 chars)" minlength="8">
                <button type="button" onclick="togglePw('pwField','eyePw')" style="position:absolute;right:0.75rem;top:50%;transform:translateY(-50%);background:none;border:none;cursor:pointer;color:var(--text3)">
                  <i id="eyePw" class="bi bi-eye"></i>
                </button>
              </div>
            </div>

            <div class="form-group">
              <label>Confirm New Password</label>
              <div style="position:relative">
                <i class="bi bi-lock-fill" style="position:absolute;left:0.75rem;top:50%;transform:translateY(-50%);color:var(--text3)"></i>
                <input type="password" name="confirm_password" id="cpwField" class="form-control" style="padding-left:2.2rem;padding-right:2.5rem" placeholder="Repeat new password">
                <button type="button" onclick="togglePw('cpwField','eyeCpw')" style="position:absolute;right:0.75rem;top:50%;transform:translateY(-50%);background:none;border:none;cursor:pointer;color:var(--text3)">
                  <i id="eyeCpw" class="bi bi-eye"></i>
                </button>
              </div>
            </div>

            <!-- Password strength indicator -->
            <div style="margin-bottom:1rem">
              <div style="height:4px;background:var(--border);border-radius:4px;overflow:hidden">
                <div id="pwStrengthBar" style="height:100%;width:0%;border-radius:4px;transition:all 0.3s;background:#dc2626"></div>
              </div>
              <div id="pwStrengthText" style="font-size:0.72rem;color:var(--text3);margin-top:0.3rem"></div>
            </div>

            <div style="display:flex;justify-content:flex-end">
              <button type="submit" class="btn btn-primary"><i class="bi bi-shield-lock"></i> Update Password</button>
            </div>
          </form>
        </div>
      </div>

      <!-- Session / Security Info -->
      <div class="card">
        <div class="card-header"><div class="card-title"><i class="bi bi-activity"></i> Security Activity</div></div>
        <div class="card-body">
          <div style="display:flex;align-items:center;gap:0.75rem;padding:0.85rem;background:#f8fafc;border-radius:10px;border:1px solid var(--border)">
            <div style="width:40px;height:40px;border-radius:10px;background:#dcfce7;display:flex;align-items:center;justify-content:center">
              <i class="bi bi-laptop" style="color:#16a34a;font-size:1.1rem"></i>
            </div>
            <div style="flex:1">
              <div style="font-size:0.82rem;font-weight:600">Current Session</div>
              <div style="font-size:0.72rem;color:var(--text3)">Active now · Web browser</div>
            </div>
            <span class="badge badge-success">Active</span>
          </div>
        </div>
      </div>
    </div>

    <!-- Tab: Profile Photo -->
    <div id="tab-photo" class="prof-tab-content" style="display:none">
      <div class="card">
        <div class="card-header">
          <div class="card-title"><i class="bi bi-image-fill"></i> Profile Photo</div>
        </div>
        <div class="card-body">
          <form method="POST" action="/admin/profile" enctype="multipart/form-data">
            <input type="hidden" name="name" value="<%= authUser ? authUser.name : '' %>">
            <input type="hidden" name="phone" value="<%= authUser && authUser.phone ? authUser.phone : '' %>">

            <!-- Drop Zone -->
            <div id="dropZone" onclick="document.getElementById('avatarInputTab').click()"
              style="border:2.5px dashed var(--border);border-radius:14px;padding:2.5rem;text-align:center;cursor:pointer;transition:all 0.2s;background:#fafbfc;position:relative;overflow:hidden">
              <div id="dropHint">
                <i class="bi bi-cloud-upload" style="font-size:2.5rem;color:var(--primary);display:block;margin-bottom:0.75rem"></i>
                <div style="font-weight:700;font-size:0.95rem;margin-bottom:0.25rem">Click to upload or drag & drop</div>
                <div style="font-size:0.78rem;color:var(--text3)">PNG, JPG, WEBP up to 2MB</div>
              </div>
              <div id="dropPreviewWrap" style="display:none">
                <img id="dropPreviewImg" style="max-height:180px;border-radius:10px;margin-bottom:0.75rem">
                <div id="dropFileName" style="font-size:0.78rem;color:var(--text3)"></div>
              </div>
            </div>
            <input type="file" id="avatarInputTab" name="avatar" accept="image/*" style="display:none" onchange="handleDropZone(this)">

            <!-- Current Photo -->
            <% if (authUser && authUser.avatar) { %>
            <div style="display:flex;align-items:center;gap:1rem;padding:0.85rem;border:1px solid var(--border);border-radius:10px;margin-top:1.25rem;background:#f8fafc">
              <img src="<%= authUser.avatar %>" style="width:52px;height:52px;border-radius:50%;object-fit:cover;border:2px solid var(--border)">
              <div style="flex:1">
                <div style="font-size:0.82rem;font-weight:600">Current Photo</div>
                <div style="font-size:0.72rem;color:var(--text3)">Replacing this will update everywhere</div>
              </div>
              <i class="bi bi-check-circle-fill" style="color:#16a34a;font-size:1.2rem"></i>
            </div>
            <% } %>

            <div style="display:flex;justify-content:flex-end;margin-top:1.25rem">
              <button type="submit" class="btn btn-primary"><i class="bi bi-upload"></i> Upload Photo</button>
            </div>
          </form>
        </div>
      </div>
    </div>

  </div><!-- end right -->
</div>

</main></div>

<script>
// Profile tabs
function switchProfTab(btn, tabId) {
  document.querySelectorAll('.prof-tab-btn').forEach(b => {
    b.style.color = 'var(--text2)';
    b.style.borderBottomColor = 'transparent';
  });
  document.querySelectorAll('.prof-tab-content').forEach(t => t.style.display = 'none');
  btn.style.color = 'var(--primary)';
  btn.style.borderBottomColor = 'var(--primary)';
  document.getElementById(tabId).style.display = 'block';
}

// Avatar preview (left card camera icon)
function previewAvatar(input) {
  if (!input.files || !input.files[0]) return;
  const reader = new FileReader();
  reader.onload = e => {
    const prev = document.getElementById('avatarPreview');
    const init = document.getElementById('avatarInitial');
    if (prev) { prev.src = e.target.result; prev.style.display = 'block'; }
    if (init) init.style.display = 'none';
    // Sync to drop zone tab
    const dpImg = document.getElementById('dropPreviewImg');
    const dpWrap = document.getElementById('dropPreviewWrap');
    const dpHint = document.getElementById('dropHint');
    if (dpImg) { dpImg.src = e.target.result; dpWrap.style.display = 'block'; dpHint.style.display = 'none'; }
  };
  reader.readAsDataURL(input.files[0]);
  // Transfer to the tab's input (for form submission)
  const tabInput = document.getElementById('avatarInputTab');
  if (tabInput) {
    const dt = new DataTransfer();
    dt.items.add(input.files[0]);
    tabInput.files = dt.files;
  }
}

// Drop zone preview
function handleDropZone(input) {
  if (!input.files || !input.files[0]) return;
  const reader = new FileReader();
  reader.onload = e => {
    document.getElementById('dropPreviewImg').src = e.target.result;
    document.getElementById('dropFileName').textContent = input.files[0].name + ' (' + (input.files[0].size/1024).toFixed(1) + ' KB)';
    document.getElementById('dropPreviewWrap').style.display = 'block';
    document.getElementById('dropHint').style.display = 'none';
    // Sync to sidebar avatar preview
    const prev = document.getElementById('avatarPreview');
    const init = document.getElementById('avatarInitial');
    if (prev) { prev.src = e.target.result; prev.style.display = 'block'; }
    if (init) init.style.display = 'none';
  };
  reader.readAsDataURL(input.files[0]);
}

// Drag-over styling
const dz = document.getElementById('dropZone');
if (dz) {
  dz.addEventListener('dragover', e => { e.preventDefault(); dz.style.borderColor = 'var(--primary)'; dz.style.background = 'var(--accent-light)'; });
  dz.addEventListener('dragleave', () => { dz.style.borderColor = 'var(--border)'; dz.style.background = '#fafbfc'; });
  dz.addEventListener('drop', e => {
    e.preventDefault(); dz.style.borderColor = 'var(--border)'; dz.style.background = '#fafbfc';
    const input = document.getElementById('avatarInputTab');
    if (e.dataTransfer.files.length && input) { input.files = e.dataTransfer.files; handleDropZone(input); }
  });
}

// Toggle password visibility
function togglePw(fieldId, iconId) {
  const f = document.getElementById(fieldId);
  const i = document.getElementById(iconId);
  if (f.type === 'password') { f.type = 'text'; i.className = 'bi bi-eye-slash'; }
  else { f.type = 'password'; i.className = 'bi bi-eye'; }
}

// Password strength
const pwField = document.getElementById('pwField');
if (pwField) {
  pwField.addEventListener('input', function() {
    const v = this.value;
    let score = 0;
    if (v.length >= 8) score++;
    if (/[A-Z]/.test(v)) score++;
    if (/[0-9]/.test(v)) score++;
    if (/[^A-Za-z0-9]/.test(v)) score++;
    const bar = document.getElementById('pwStrengthBar');
    const txt = document.getElementById('pwStrengthText');
    const colors = ['#dc2626','#f97316','#eab308','#16a34a'];
    const labels = ['Weak','Fair','Good','Strong'];
    if (v.length === 0) { bar.style.width = '0%'; txt.textContent = ''; return; }
    bar.style.width = (score * 25) + '%';
    bar.style.background = colors[score - 1] || '#dc2626';
    txt.textContent = labels[score - 1] || 'Very Weak';
    txt.style.color = colors[score - 1] || '#dc2626';
  });
}

// Validate passwords match
function validatePw(form) {
  const pw = form.querySelector('[name="password"]').value;
  const cpw = form.querySelector('[name="confirm_password"]').value;
  if (pw && pw !== cpw) { alert('Passwords do not match!'); return false; }
  return true;
}
</script>

<%- include('../partials/scripts') %>
</body></html>
