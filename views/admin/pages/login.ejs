<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin Login – Dreams Technology</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
  <style>
    :root { --primary:#1a7a4a; --secondary:#e8a020; }
    * { margin:0; padding:0; box-sizing:border-box; }
    body { font-family:'Poppins',sans-serif; background:linear-gradient(135deg,#0f1b2d 0%,#1a2332 50%,#0f3825 100%); min-height:100vh; display:flex; align-items:center; justify-content:center; padding:1rem; }
    .login-wrap { width:100%; max-width:420px; }
    .login-logo { text-align:center; margin-bottom:2rem; }
    .logo-circle { width:70px; height:70px; background:var(--primary); border-radius:18px; display:flex; align-items:center; justify-content:center; font-size:2rem; font-weight:800; color:#fff; margin:0 auto 1rem; box-shadow:0 8px 30px rgba(26,122,74,0.4); }
    .login-logo h1 { font-size:1.5rem; font-weight:800; color:#fff; }
    .login-logo p { font-size:0.8rem; color:rgba(255,255,255,0.5); margin-top:0.25rem; }
    .login-card { background:#fff; border-radius:20px; padding:2rem; box-shadow:0 20px 60px rgba(0,0,0,0.3); }
    .login-card h2 { font-size:1.25rem; font-weight:700; margin-bottom:0.3rem; }
    .login-card p { font-size:0.8rem; color:#6b7280; margin-bottom:1.5rem; }
    .form-group { margin-bottom:1rem; }
    label { display:block; font-size:0.78rem; font-weight:600; color:#374151; margin-bottom:0.35rem; }
    .input-wrap { position:relative; }
    .input-wrap i { position:absolute; left:0.9rem; top:50%; transform:translateY(-50%); color:#9ca3af; font-size:1rem; }
    input { width:100%; padding:0.65rem 0.9rem 0.65rem 2.5rem; border:1.5px solid #e5e7eb; border-radius:10px; font-size:0.85rem; font-family:inherit; transition:border 0.2s; }
    input:focus { outline:none; border-color:var(--primary); }
    .pw-toggle { position:absolute; right:0.9rem; top:50%; transform:translateY(-50%); cursor:pointer; color:#9ca3af; }
    .btn-login { width:100%; background:var(--primary); color:#fff; border:none; padding:0.75rem; border-radius:10px; font-size:0.9rem; font-weight:700; cursor:pointer; transition:all 0.2s; font-family:inherit; margin-top:0.5rem; }
    .btn-login:hover { background:#125c36; transform:translateY(-1px); box-shadow:0 4px 15px rgba(26,122,74,0.4); }
    .alert { padding:0.75rem 1rem; border-radius:8px; font-size:0.82rem; margin-bottom:1rem; display:flex; align-items:center; gap:0.5rem; }
    .alert-danger { background:#fee2e2; color:#991b1b; border:1px solid #fecaca; }
    .alert-success { background:#dcfce7; color:#166534; border:1px solid #bbf7d0; }
    .demo-creds { background:#f8fafc; border-radius:10px; padding:1rem; margin-top:1rem; font-size:0.75rem; color:#6b7280; }
    .demo-creds strong { color:#374151; display:block; margin-bottom:0.5rem; }
    .cred-item { display:flex; justify-content:space-between; padding:0.2rem 0; border-bottom:1px solid #e5e7eb; }
    .cred-item:last-child { border:none; }
    .view-site { text-align:center; margin-top:1rem; font-size:0.78rem; color:rgba(255,255,255,0.5); }
    .view-site a { color:var(--secondary); font-weight:600; }
  </style>
</head>
<body>
  <div class="login-wrap">
    <div class="login-logo">
      <div class="logo-circle">DT</div>
      <h1>Dreams Technology</h1>
      <p>Content Management System</p>
    </div>
    <div class="login-card">
      <h2>Welcome Back! 👋</h2>
      <p>Sign in to access your admin panel</p>
      <% if (typeof flash !== 'undefined' && flash) { %>
        <% if (flash.error) { %><div class="alert alert-danger"><i class="bi bi-exclamation-triangle"></i> <%= flash.error %></div><% } %>
        <% if (flash.success) { %><div class="alert alert-success"><i class="bi bi-check-circle"></i> <%= flash.success %></div><% } %>
      <% } %>
      <form method="POST" action="/admin/login">
        <div class="form-group">
          <label>Email Address</label>
          <div class="input-wrap">
            <i class="bi bi-envelope"></i>
            <input type="email" name="email" placeholder="admin@dreams.com" required autofocus>
          </div>
        </div>
        <div class="form-group">
          <label>Password</label>
          <div class="input-wrap">
            <i class="bi bi-lock"></i>
            <input type="password" name="password" id="password" placeholder="••••••••" required>
            <i class="bi bi-eye pw-toggle" onclick="togglePw()"></i>
          </div>
        </div>
        <button type="submit" class="btn-login"><i class="bi bi-box-arrow-in-right"></i> Sign In</button>
      </form>
      <div class="demo-creds">
        <strong>🔑 Demo Credentials:</strong>
        <div class="cred-item"><span>Super Admin:</span><span>superadmin@dreams.com / Admin@123</span></div>
        <div class="cred-item"><span>Admin:</span><span>admin@dreams.com / Admin@123</span></div>
        <div class="cred-item"><span>Developer:</span><span>dev@dreams.com / Admin@123</span></div>
        <div class="cred-item"><span>User:</span><span>naresh@dreams.com / User@123</span></div>
      </div>
    </div>
    <div class="view-site"><a href="/" target="_blank"><i class="bi bi-globe"></i> View Website</a></div>
  </div>
  <script>
    function togglePw() {
      const inp = document.getElementById('password');
      inp.type = inp.type === 'password' ? 'text' : 'password';
    }
  </script>
</body>
</html>
