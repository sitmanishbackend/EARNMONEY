    <div class="dp-card-bd" style="display:flex;flex-direction:column;gap:8px;">
      <% [
        ['/admin/posts/create','bi-plus-circle','Create Post'],
        ['/admin/categories','bi-grid','Categories'],
        ['/admin/themes','bi-palette','Theme Manager'],
        ['/admin/seo','bi-rocket','Blog Booster / SEO'],
        ['/admin/database','bi-database','Database Manager'],
        ['/','bi-globe','View Live Site'],
      ].forEach(([href,icon,label]) => { %>
      <a href="<%= href %>" <%= href==='/'?'target="_blank"':'' %>
        style="display:flex;align-items:center;gap:10px;padding:10px 14px;background:var(--dp-bg);border:1px solid var(--dp-border);border-radius:10px;text-decoration:none;color:var(--dp-text-b);font-size:.8rem;font-weight:600;transition:all .2s;">
        <i class="bi <%= icon %>" style="color:var(--dp-primary);font-size:1rem;"></i> <%= label %>
        <i class="bi bi-chevron-right" style="margin-left:auto;opacity:.4;font-size:.7rem;"></i>
      </a>
      <% }) %>
      <div style="display:flex;align-items:center;gap:8px;margin-top:4px;">
        <span class="dp-dev-pill"><i class="bi bi-circle-fill" style="font-size:.5rem;color:#10b981;"></i> Node.js Online</span>
        <span class="dp-dev-pill" style="background:#1e3a5f;color:#60a5fa;"><i class="bi bi-database-check" style="font-size:.75rem;"></i> DB Connected</span>
      </div>
    </div>
  </div>
</div>

<!-- ════════════════════════════════
     USER (Basic Staff)
════════════════════════════════ -->
<% }else{ %>

<div style="background:linear-gradient(135deg,var(--dp-primary-d),var(--dp-primary));border-radius:16px;padding:24px 28px;margin-bottom:20px;display:flex;justify-content:space-between;align-items:center;box-shadow:0 8px 28px rgba(0,0,0,.15);" class="a2">
  <div>
    <div style="font-size:1.25rem;font-weight:800;color:#fff;margin-bottom:4px;">Hey <%= userName %>! 👋</div>
    <div style="font-size:.82rem;color:rgba(255,255,255,.75);"><%= new Date().toLocaleDateString('en-IN',{weekday:'long',day:'numeric',month:'long'}) %> — Have a great day!</div>
  </div>
  <div style="font-size:52px;opacity:.18;">💼</div>
</div>

<div class="dp-sg">
  <div class="dp-sc c-theme a2">
    <div class="dp-sc-top">
      <div class="dp-sc-ico"><i class="bi bi-calendar-check"></i></div>
      <span class="dp-sc-trend t-up"><i class="bi bi-arrow-up"></i> This Month</span>
    </div>
    <div class="dp-sc-lbl">Present Days</div>
    <div class="dp-sc-val"><%= myAttendanceSummary ? myAttendanceSummary.present : 0 %></div>
    <div class="dp-sc-sub">Days attended</div>
    <div class="dp-sc-bar"><div class="dp-sc-fill" data-w="<%= myAttendanceSummary ? Math.min(100,myAttendanceSummary.present*4) : 0 %>"></div></div>
  </div>
  <div class="dp-sc c-rose a3">
    <div class="dp-sc-top">
      <div class="dp-sc-ico"><i class="bi bi-calendar-x"></i></div>
      <span class="dp-sc-trend t-dn"><i class="bi bi-arrow-down"></i> Absent</span>
    </div>
    <div class="dp-sc-lbl">Absent Days</div>
    <div class="dp-sc-val"><%= myAttendanceSummary ? myAttendanceSummary.absent : 0 %></div>
    <div class="dp-sc-sub">Days missed</div>
    <div class="dp-sc-bar"><div class="dp-sc-fill" data-w="<%= myAttendanceSummary ? Math.min(100,myAttendanceSummary.absent*10) : 0 %>"></div></div>
  </div>
  <div class="dp-sc c-amber a4">
    <div class="dp-sc-top">
      <div class="dp-sc-ico"><i class="bi bi-cash-stack"></i></div>
      <span class="dp-sc-trend t-up"><i class="bi bi-arrow-up"></i> Advance</span>
    </div>
    <div class="dp-sc-lbl">Advance Taken</div>
    <div class="dp-sc-val">₹<%= myAttendanceSummary ? Number(myAttendanceSummary.advance||0).toLocaleString('en-IN') : 0 %></div>
    <div class="dp-sc-sub">This month</div>
    <div class="dp-sc-bar"><div class="dp-sc-fill" data-w="40"></div></div>
  </div>
  <div class="dp-sc c-green a5">
    <div class="dp-sc-top">
      <div class="dp-sc-ico"><i class="bi bi-wallet2"></i></div>
      <span class="dp-sc-trend t-up"><i class="bi bi-arrow-up"></i> Salary</span>
    </div>
    <div class="dp-sc-lbl">My Salary</div>
    <div class="dp-sc-val">₹<%= mySalary ? Number(mySalary).toLocaleString('en-IN') : '—' %></div>
    <div class="dp-sc-sub"><%= mySalaryType || 'monthly' %> rate</div>
    <div class="dp-sc-bar"><div class="dp-sc-fill" data-w="100"></div></div>
  </div>
</div>

<div class="dp-g66 a4">
  <div class="dp-card">
    <div class="dp-card-hd"><h5><i class="bi bi-calendar3"></i> My Attendance — This Month</h5></div>
    <div class="dp-card-bd">
      <% if(myAttendanceRecords && myAttendanceRecords.length){ %>
        <% const statusColors={'P':'var(--green)','A':'var(--rose)','P+H':'var(--amber)','OT':'var(--blue)','PA':'var(--purple)','P+P':'var(--teal)'}; %>
        <div style="display:flex;flex-wrap:wrap;gap:6px;">
          <% myAttendanceRecords.forEach(r => { const col=statusColors[r.status]||'var(--dp-text-m)'; %>
          <div title="<%= r.attendance_date %> — <%= r.status %>"
            style="width:36px;height:36px;border-radius:8px;background:<%= col %>22;border:1.5px solid <%= col %>;display:flex;align-items:center;justify-content:center;font-size:.65rem;font-weight:800;color:<%= col %>;">
            <%= new Date(r.attendance_date).getDate() %>
          </div>
          <% }) %>
        </div>
        <div style="display:flex;flex-wrap:wrap;gap:10px;margin-top:16px;">
          <% [['var(--green)','Present'],['var(--rose)','Absent'],['var(--amber)','Half'],['var(--blue)','OT']].forEach(([c,l]) => { %>
          <div style="display:flex;align-items:center;gap:5px;font-size:.71rem;color:var(--dp-text-m);">
            <span style="width:10px;height:10px;border-radius:3px;background:<%= c %>;flex-shrink:0;"></span><%= l %>
          </div>
          <% }) %>
        </div>
      <% }else{ %>
        <div class="dp-empty"><i class="bi bi-calendar2-x"></i><p>No attendance records this month</p></div>
      <% } %>
    </div>
  </div>
  <div class="dp-card">
    <div class="dp-card-hd"><h5><i class="bi bi-person-badge"></i> My Info</h5></div>
    <div class="dp-card-bd" style="display:flex;flex-direction:column;gap:12px;">
      <% [
        ['bi-person','Name', userName],
        ['bi-envelope','Email', authUser ? authUser.email : '—'],
        ['bi-briefcase','Role', roleLabel],
        ['bi-cash','Salary', (mySalary ? '₹'+Number(mySalary).toLocaleString('en-IN') : '—') + ' / ' + (mySalaryType||'monthly')],
      ].forEach(([icon, label, val]) => { %>
      <div style="display:flex;align-items:center;gap:12px;padding:10px 14px;background:var(--dp-bg);border-radius:10px;">
        <i class="bi <%= icon %>" style="color:var(--dp-primary);font-size:1rem;width:20px;text-align:center;"></i>
        <div>
          <div style="font-size:.68rem;color:var(--dp-text-m);text-transform:uppercase;letter-spacing:.06em;font-weight:700;"><%= label %></div>
          <div style="font-size:.84rem;font-weight:600;color:var(--dp-text-h);"><%= val %></div>
        </div>
      </div>
      <% }) %>
      <a href="/admin/profile" style="display:flex;align-items:center;justify-content:center;gap:7px;padding:10px;background:var(--dp-primary);color:#fff;border-radius:10px;text-decoration:none;font-size:.82rem;font-weight:700;">
        <i class="bi bi-pencil-square"></i> Edit Profile
      </a>
    </div>
  </div>
</div>

<% } %>

</div><!-- /dp -->

<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
<script>
document.addEventListener('DOMContentLoaded', function () {

  // ── Animate progress bars
  setTimeout(function () {
    document.querySelectorAll('.dp-sc-fill[data-w]').forEach(function (el) {
      el.style.width = (el.dataset.w || 0) + '%';
    });
  }, 400);

  // ── Get theme primary color from CSS variable
  const themeColor = getComputedStyle(document.documentElement)
    .getPropertyValue('--primary').trim() || '#1a7a4a';
  const themeSecondary = getComputedStyle(document.documentElement)
    .getPropertyValue('--secondary').trim() || '#e8a020';

  const months = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];

  const monthlyData = <%- JSON.stringify(monthlyData || []) %>;

  const incomeByMonth  = Array(12).fill(0);
  const expenseByMonth = Array(12).fill(0);
  monthlyData.forEach(function(d) {
    const idx = parseInt(d.month) - 1;
    if (d.type === 'income')  incomeByMonth[idx]  = parseFloat(d.total) || 0;
    if (d.type === 'expense') expenseByMonth[idx] = parseFloat(d.total) || 0;
  });

  const chartDefaults = {
    responsive: true,
    plugins: { legend: { position: 'top', labels: { boxWidth: 10, padding: 14, font: { size: 11 } } } },
    scales: {
      x: { grid: { display: false } },
      y: { grid: { color: '#f0f2f8' }, ticks: { callback: v => '₹' + Math.round(v/1000) + 'K' } }
    }
  };

  <% if(isSuperAdmin){ %>
  // Finance Chart
  const finCtx = document.getElementById('financeChart');
  if (finCtx) {
    new Chart(finCtx, {
      type: 'bar',
      data: {
        labels: months,
        datasets: [
          { label: 'Income',  data: incomeByMonth,  backgroundColor: themeColor + '99', borderColor: themeColor, borderWidth: 2, borderRadius: 7 },
          { label: 'Expense', data: expenseByMonth, backgroundColor: '#e0313199',       borderColor: '#e03131',  borderWidth: 2, borderRadius: 7 }
        ]
      },
      options: chartDefaults
    });
  }

  // Role Donut
  const roleCtx = document.getElementById('roleChart');
  const roleLabels = <%- JSON.stringify((safeRoleDistribution||[]).map(r=>r.name)) %>;
  const roleData   = <%- JSON.stringify((safeRoleDistribution||[]).map(r=>r.total)) %>;
  if (roleCtx) {
    new Chart(roleCtx, {
      type: 'doughnut',
      data: {
        labels: roleLabels.length ? roleLabels : ['Super Admin','Admin','Developer','User'],
        datasets: [{ data: roleData.length ? roleData : [1,1,1,3], backgroundColor: [themeColor,'#0ca678','#7048e8','#f59f00'], borderWidth: 0, hoverOffset: 8 }]
      },
      options: { cutout: '68%', plugins: { legend: { position: 'bottom', labels: { boxWidth: 10, padding: 14, font: { size: 11 } } } } }
    });
  }
  <% } %>

  <% if(isAdmin){ %>
  const adminFinCtx = document.getElementById('adminFinChart');
  if (adminFinCtx) {
    new Chart(adminFinCtx, {
      type: 'line',
      data: {
        labels: months,
        datasets: [
          { label: 'Income',  data: incomeByMonth,  borderColor: themeColor, backgroundColor: themeColor+'22', borderWidth: 2.5, tension: 0.4, fill: true, pointBackgroundColor: themeColor, pointRadius: 4 },
          { label: 'Expense', data: expenseByMonth, borderColor: '#e03131',  backgroundColor: '#e0313122', borderWidth: 2.5, tension: 0.4, fill: true, pointBackgroundColor: '#e03131', pointRadius: 4 }
        ]
      },
      options: chartDefaults
    });
  }
  <% } %>

});
</script>
<%- include('../partials/scripts') %>
</body></html>