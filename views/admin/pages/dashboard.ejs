<!DOCTYPE html>
<html lang="en"><head><meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1.0">
<title><%= title %> – Dreams Admin</title>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800&family=Noto+Sans+Devanagari:wght@400;500;600;700&display=swap" rel="stylesheet">
<%- include('../partials/head') %>
</head><body>
<%- include('../partials/sidebar', { currentRoute: '/admin/categories' }) %>
<div class="main-content" id="mainContent">
<%- include('../partials/topbar') %>
<main class="page-content">
<%- include('../partials/flash') %>

<%
  const role_slug = authUser ? authUser.role_slug : 'user';
  const isSuperAdmin = role_slug === 'super_admin';
  const isAdmin      = role_slug === 'admin';
  const isDeveloper  = role_slug === 'developer';
  const isUser       = role_slug === 'user';
  const userName     = authUser ? authUser.name : 'User';
  const roleLabel    = isSuperAdmin ? 'Super Admin' : isAdmin ? 'Admin' : isDeveloper ? 'Developer' : 'User';
  const roleEmoji    = isSuperAdmin ? '👑' : isAdmin ? '🛡️' : isDeveloper ? '⚙️' : '👤';
%>
<%
const safeRecentTransactions =
  typeof recentTransactions !== 'undefined' ? recentTransactions : [];

const safeBankAccounts =
  typeof bankAccounts !== 'undefined' ? bankAccounts : [];

const safeRecentPosts =
  typeof recentPosts !== 'undefined' ? recentPosts : [];

const safeTopPosts =
  typeof topPosts !== 'undefined' ? topPosts : [];

const safeRoleDistribution =
  typeof roleDistribution !== 'undefined' ? roleDistribution : [];

const safeMonthlyData =
  typeof monthlyData !== 'undefined' ? monthlyData : [];
%>
<style>
@import url('https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap');

/* ══ THEME BRIDGE — picks up whatever theme is active ══ */
:root {
  --dp-primary:    var(--primary, #1a7a4a);
  --dp-primary-d:  var(--accent-dark, #125c36);
  --dp-primary-l:  var(--accent-light, #e8f5ee);
  --dp-secondary:  var(--secondary, #e8a020);
  --dp-sidebar-bg: var(--sidebar-bg, #1a2332);
  --dp-text-h:     #0f172a;
  --dp-text-b:     #334155;
  --dp-text-m:     #64748b;
  --dp-border:     #e8eaf2;
  --dp-bg:         #f4f6fb;
  --dp-card:       #ffffff;
  --dp-radius:     14px;
  --dp-radius-sm:  10px;
  --dp-shadow:     0 2px 12px rgba(0,0,0,.06);
  --dp-shadow-h:   0 8px 30px rgba(0,0,0,.12);
  --dp-trans:      .2s cubic-bezier(.4,0,.2,1);

  /* fixed palette for badges/charts */
  --green:   #0ca678; --green-s:  #e6f7f3;
  --amber:   #f59f00; --amber-s:  #fff8e1;
  --rose:    #e03131; --rose-s:   #ffeaea;
  --blue:    #4361ee; --blue-s:   #eef1fd;
  --purple:  #7048e8; --purple-s: #f0ebff;
  --teal:    #0891b2; --teal-s:   #e0f5fa;
  --orange:  #ea580c; --orange-s: #fff7ed;
}

*, *::before, *::after { box-sizing: border-box; }

.dp {
  font-family: 'Plus Jakarta Sans', sans-serif;
  color: var(--dp-text-b);
  background: var(--dp-bg);
  padding: 4px 0 40px;
}

/* ── Animations ── */
@keyframes fadeUp { from{opacity:0;transform:translateY(18px)} to{opacity:1;transform:none} }
.a1{animation:fadeUp .35s ease .04s both}
.a2{animation:fadeUp .35s ease .09s both}
.a3{animation:fadeUp .35s ease .14s both}
.a4{animation:fadeUp .35s ease .19s both}
.a5{animation:fadeUp .35s ease .24s both}
.a6{animation:fadeUp .35s ease .29s both}
@keyframes blink{0%,100%{opacity:1}50%{opacity:.3}}
@keyframes countUp{from{opacity:0;transform:scale(.8)}to{opacity:1;transform:none}}

/* ══ BANNER ══ */
.dp-banner {
  background: linear-gradient(118deg, var(--dp-sidebar-bg) 0%, var(--dp-primary-d) 60%, var(--dp-primary) 100%);
  border-radius: 20px;
  padding: 28px 32px;
  margin-bottom: 22px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  flex-wrap: wrap;
  gap: 16px;
  position: relative;
  overflow: hidden;
  box-shadow: 0 10px 40px rgba(0,0,0,.2);
}
.dp-banner::before {
  content:'';
  position:absolute; inset:0;
  background:
    radial-gradient(ellipse 320px 200px at 95% 60%, rgba(255,255,255,.08) 0%, transparent 70%),
    radial-gradient(ellipse 200px 200px at 4% -10%, rgba(255,255,255,.06) 0%, transparent 55%);
  pointer-events:none;
}
.dp-banner::after {
  content:'';
  position:absolute; right:-80px; top:-80px;
  width:280px; height:280px; border-radius:50%;
  border:54px solid rgba(255,255,255,.04);
  pointer-events:none;
}
.dp-banner-left  { position:relative; z-index:1; }
.dp-banner-right { position:relative; z-index:1; display:flex; gap:8px; flex-wrap:wrap; align-items:center; }
.dp-bn-title { font-size:1.5rem; font-weight:800; color:#fff; margin:0 0 5px; }
.dp-bn-sub   { color:rgba(255,255,255,.68); font-size:.82rem; margin:0; }
.dp-bn-badge {
  display:inline-flex; align-items:center; gap:6px;
  border-radius:50px; padding:5px 15px;
  font-size:.72rem; font-weight:700; letter-spacing:.04em;
}
.dp-bn-role { background:rgba(255,255,255,.16); border:1px solid rgba(255,255,255,.26); color:#fff; }
.dp-bn-date { background:rgba(255,255,255,.08); border:1px solid rgba(255,255,255,.14); color:rgba(255,255,255,.85); }
.dp-live    { width:7px; height:7px; border-radius:50%; background:#4ade80; animation:blink 1.6s infinite; flex-shrink:0; }

/* ══ QUICK ACTION BAR ══ */
.dp-qa { display:flex; gap:8px; flex-wrap:wrap; margin-bottom:22px; }
.dp-qa a {
  display:inline-flex; align-items:center; gap:7px;
  background:var(--dp-card); border:1px solid var(--dp-border);
  border-radius:50px; padding:7px 16px;
  font-size:.78rem; font-weight:600; color:var(--dp-text-b);
  text-decoration:none; box-shadow:var(--dp-shadow);
  transition:all var(--dp-trans); white-space:nowrap;
}
.dp-qa a i { font-size:.9rem; color:var(--dp-primary); }
.dp-qa a:hover {
  background:var(--dp-primary); color:#fff;
  border-color:var(--dp-primary);
  transform:translateY(-2px);
  box-shadow:0 6px 20px rgba(0,0,0,.15);
}
.dp-qa a:hover i { color:#fff; }

/* ══ STAT GRID ══ */
.dp-sg {
  display:grid;
  grid-template-columns:repeat(4,1fr);
  gap:14px;
  margin-bottom:22px;
}
@media(max-width:1100px){.dp-sg{grid-template-columns:repeat(2,1fr)}}
@media(max-width:540px) {.dp-sg{grid-template-columns:1fr}}

/* ══ STAT CARD ══ */
.dp-sc {
  background:var(--dp-card); border:1px solid var(--dp-border);
  border-radius:var(--dp-radius); padding:20px 18px 16px;
  position:relative; overflow:hidden;
  box-shadow:var(--dp-shadow);
  transition:transform var(--dp-trans), box-shadow var(--dp-trans);
  cursor:default;
}
.dp-sc:hover { transform:translateY(-4px); box-shadow:var(--dp-shadow-h); }
.dp-sc::before {
  content:''; position:absolute; top:0; right:0;
  width:110px; height:110px; border-radius:0 var(--dp-radius) 0 110%;
  opacity:.5; pointer-events:none;
}
/* accent-top bar using theme primary */
.dp-sc.c-theme  { border-top:3px solid var(--dp-primary);   } .dp-sc.c-theme::before   { background:var(--dp-primary-l); }
.dp-sc.c-green  { border-top:3px solid var(--green);  } .dp-sc.c-green::before  { background:var(--green-s); }
.dp-sc.c-amber  { border-top:3px solid var(--amber);  } .dp-sc.c-amber::before  { background:var(--amber-s); }
.dp-sc.c-blue   { border-top:3px solid var(--blue);   } .dp-sc.c-blue::before   { background:var(--blue-s); }
.dp-sc.c-purple { border-top:3px solid var(--purple); } .dp-sc.c-purple::before { background:var(--purple-s); }
.dp-sc.c-rose   { border-top:3px solid var(--rose);   } .dp-sc.c-rose::before   { background:var(--rose-s); }
.dp-sc.c-teal   { border-top:3px solid var(--teal);   } .dp-sc.c-teal::before   { background:var(--teal-s); }
.dp-sc.c-orange { border-top:3px solid var(--orange); } .dp-sc.c-orange::before { background:var(--orange-s); }

.dp-sc-top  { display:flex; align-items:flex-start; justify-content:space-between; margin-bottom:12px; }
.dp-sc-ico  {
  width:44px; height:44px; border-radius:12px;
  display:flex; align-items:center; justify-content:center;
  font-size:1.15rem; flex-shrink:0; position:relative; z-index:1;
}
.c-theme  .dp-sc-ico { background:var(--dp-primary-l); color:var(--dp-primary); }
.c-green  .dp-sc-ico { background:var(--green-s);  color:var(--green); }
.c-amber  .dp-sc-ico { background:var(--amber-s);  color:var(--amber); }
.c-blue   .dp-sc-ico { background:var(--blue-s);   color:var(--blue); }
.c-purple .dp-sc-ico { background:var(--purple-s); color:var(--purple); }
.c-rose   .dp-sc-ico { background:var(--rose-s);   color:var(--rose); }
.c-teal   .dp-sc-ico { background:var(--teal-s);   color:var(--teal); }
.c-orange .dp-sc-ico { background:var(--orange-s); color:var(--orange); }

.dp-sc-trend {
  font-size:.68rem; font-weight:700; padding:3px 9px; border-radius:50px;
  position:relative; z-index:1; display:inline-flex; align-items:center; gap:3px;
}
.t-up  { background:var(--green-s);  color:var(--green); }
.t-dn  { background:var(--rose-s);   color:var(--rose);  }
.t-neu { background:var(--amber-s);  color:var(--amber); }

.dp-sc-lbl  { font-size:.69rem; font-weight:700; text-transform:uppercase; letter-spacing:.07em; color:var(--dp-text-m); margin-bottom:5px; }
.dp-sc-val  { font-size:1.95rem; font-weight:800; color:var(--dp-text-h); line-height:1; margin-bottom:3px; animation:countUp .5s ease; }
.dp-sc-sub  { font-size:.73rem; color:var(--dp-text-m); }
.dp-sc-bar  { height:4px; background:var(--dp-border); border-radius:4px; margin-top:13px; overflow:hidden; }
.dp-sc-fill { height:100%; border-radius:4px; width:0; transition:width 1.4s cubic-bezier(.4,0,.2,1); }
.c-theme  .dp-sc-fill { background:linear-gradient(90deg, var(--dp-primary), var(--dp-secondary)); }
.c-green  .dp-sc-fill { background:linear-gradient(90deg, var(--green), #34d399); }
.c-amber  .dp-sc-fill { background:linear-gradient(90deg, var(--amber), #fbbf24); }
.c-blue   .dp-sc-fill { background:linear-gradient(90deg, var(--blue),  #818cf8); }
.c-purple .dp-sc-fill { background:linear-gradient(90deg, var(--purple),#a78bfa); }
.c-rose   .dp-sc-fill { background:linear-gradient(90deg, var(--rose),  #f87171); }
.c-teal   .dp-sc-fill { background:linear-gradient(90deg, var(--teal),  #22d3ee); }
.c-orange .dp-sc-fill { background:linear-gradient(90deg, var(--orange),#fb923c); }

/* ══ CARD SHELL ══ */
.dp-card {
  background:var(--dp-card); border:1px solid var(--dp-border);
  border-radius:var(--dp-radius); box-shadow:var(--dp-shadow);
  overflow:hidden; transition:box-shadow var(--dp-trans);
}
.dp-card:hover { box-shadow:var(--dp-shadow-h); }
.dp-card-hd {
  display:flex; align-items:center; justify-content:space-between;
  padding:15px 20px 13px; border-bottom:1px solid var(--dp-border);
}
.dp-card-hd h5 {
  font-size:.92rem; font-weight:700; color:var(--dp-text-h);
  margin:0; display:flex; align-items:center; gap:7px;
}
.dp-card-hd h5 i { color:var(--dp-primary); font-size:.95rem; }
.dp-card-bd  { padding:18px 20px; }
.dp-card-bd0 { padding:0; }

.dp-vlink {
  font-size:.74rem; color:var(--dp-primary); text-decoration:none;
  font-weight:600; display:inline-flex; align-items:center; gap:3px;
  transition:gap var(--dp-trans);
}
.dp-vlink:hover { gap:7px; color:var(--dp-primary-d); }

/* ══ LAYOUT GRIDS ══ */
.dp-g84   { display:grid; grid-template-columns:1fr 360px; gap:18px; margin-bottom:18px; }
.dp-g64   { display:grid; grid-template-columns:1.5fr 1fr;  gap:18px; margin-bottom:18px; }
.dp-g66   { display:grid; grid-template-columns:1fr 1fr;    gap:18px; margin-bottom:18px; }
.dp-g333  { display:grid; grid-template-columns:1fr 1fr 1fr; gap:18px; margin-bottom:18px; }
@media(max-width:1100px){ .dp-g84{grid-template-columns:1fr} .dp-g64{grid-template-columns:1fr} .dp-g333{grid-template-columns:1fr 1fr} }
@media(max-width:780px) { .dp-g66{grid-template-columns:1fr} .dp-g333{grid-template-columns:1fr} }

/* ══ TABLE ══ */
.dp-table { width:100%; border-collapse:collapse; font-size:.82rem; }
.dp-table thead th {
  background:#f8f9fe; color:var(--dp-text-m);
  font-size:.68rem; text-transform:uppercase; letter-spacing:.07em;
  font-weight:700; padding:10px 16px;
  border-bottom:1px solid var(--dp-border); white-space:nowrap;
}
.dp-table tbody tr { border-bottom:1px solid #f0f2f8; transition:background var(--dp-trans); }
.dp-table tbody tr:last-child { border-bottom:none; }
.dp-table tbody tr:hover { background:#f5f7ff; }
.dp-table tbody td { padding:11px 16px; color:var(--dp-text-b); vertical-align:middle; }

/* ══ BADGES ══ */
.dp-bd { display:inline-flex; align-items:center; padding:3px 10px; border-radius:6px; font-size:.72rem; font-weight:600; gap:4px; }
.dp-bd-ok     { background:var(--green-s);  color:var(--green); }
.dp-bd-pend   { background:var(--amber-s);  color:var(--amber); }
.dp-bd-rej    { background:var(--rose-s);   color:var(--rose);  }
.dp-bd-blue   { background:var(--blue-s);   color:var(--blue);  }
.dp-bd-purple { background:var(--purple-s); color:var(--purple);}
.dp-bd-teal   { background:var(--teal-s);   color:var(--teal);  }
.dp-bd-theme  { background:var(--dp-primary-l); color:var(--dp-primary); }

/* ══ AVATAR ══ */
.dp-ava {
  width:34px; height:34px; border-radius:10px;
  display:inline-flex; align-items:center; justify-content:center;
  font-weight:800; font-size:.72rem; color:#fff;
  flex-shrink:0;
}
.av1 { background:linear-gradient(135deg,var(--dp-primary),var(--dp-secondary)); }
.av2 { background:linear-gradient(135deg,#0ca678,#34d399); }
.av3 { background:linear-gradient(135deg,#f59f00,#fbbf24); }
.av4 { background:linear-gradient(135deg,#7048e8,#a78bfa); }
.av5 { background:linear-gradient(135deg,#e03131,#f87171); }
.av6 { background:linear-gradient(135deg,#0891b2,#22d3ee); }

/* ══ LIST ITEM ══ */
.dp-li {
  display:flex; align-items:center; gap:12px;
  padding:11px 20px; border-bottom:1px solid #f0f2f8;
  transition:background var(--dp-trans);
}
.dp-li:last-child { border-bottom:none; }
.dp-li:hover { background:#f5f7ff; }
.dp-li-name { font-size:.83rem; font-weight:600; color:var(--dp-text-h); }
.dp-li-meta { font-size:.71rem; color:var(--dp-text-m); margin-top:1px; }
.dp-li-right { margin-left:auto; text-align:right; }
.dp-li-val   { font-size:.82rem; font-weight:700; color:var(--dp-primary); }
.dp-li-date  { font-size:.7rem;  color:var(--dp-text-m); margin-top:1px; }

/* ══ ACTIVITY FEED ══ */
.dp-af { display:flex; gap:11px; padding:12px 20px; border-bottom:1px solid #f0f2f8; align-items:flex-start; transition:background var(--dp-trans); }
.dp-af:last-child { border-bottom:none; }
.dp-af:hover { background:#f5f7ff; }
.dp-af-ico { width:36px; height:36px; border-radius:10px; display:flex; align-items:center; justify-content:center; font-size:.9rem; flex-shrink:0; }
.dp-af-ttl { font-size:.81rem; font-weight:600; color:var(--dp-text-h); margin-bottom:2px; }
.dp-af-meta { font-size:.71rem; color:var(--dp-text-m); }

/* ══ HEALTH BAR ══ */
.dp-hb-item { margin-bottom:14px; }
.dp-hb-top  { display:flex; justify-content:space-between; font-size:.78rem; margin-bottom:5px; font-weight:600; color:var(--dp-text-b); }
.dp-hb-bar  { height:7px; background:var(--dp-border); border-radius:99px; overflow:hidden; }
.dp-hb-fill { height:100%; border-radius:99px; transition:width 1.2s cubic-bezier(.4,0,.2,1); }

/* ══ MINI METRIC BOXES ══ */
.dp-metric-grid { display:grid; grid-template-columns:repeat(3,1fr); gap:10px; margin-top:16px; }
.dp-metric {
  border-radius:10px; padding:13px; text-align:center;
}
.dp-metric-val { font-size:1.2rem; font-weight:800; }
.dp-metric-lbl { font-size:.68rem; color:var(--dp-text-m); text-transform:uppercase; letter-spacing:.06em; margin-top:2px; }

/* ══ POST ROW ══ */
.dp-post-row { display:flex; align-items:center; gap:12px; padding:11px 20px; border-bottom:1px solid #f0f2f8; transition:background var(--dp-trans); }
.dp-post-row:last-child { border-bottom:none; }
.dp-post-row:hover { background:#f5f7ff; }
.dp-post-num { width:28px; height:28px; border-radius:8px; background:var(--dp-primary-l); color:var(--dp-primary); display:flex; align-items:center; justify-content:center; font-size:.75rem; font-weight:800; flex-shrink:0; }
.dp-post-title { font-size:.8rem; font-weight:600; color:var(--dp-text-h); white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }
.dp-post-meta  { font-size:.7rem;  color:var(--dp-text-m); }

/* ══ FINANCE ROW ══ */
.dp-fin-row { display:flex; align-items:center; gap:12px; padding:11px 20px; border-bottom:1px solid #f0f2f8; transition:background var(--dp-trans); }
.dp-fin-row:last-child { border-bottom:none; }
.dp-fin-row:hover { background:#f5f7ff; }
.dp-fin-ico { width:36px; height:36px; border-radius:10px; display:flex; align-items:center; justify-content:center; font-size:.88rem; flex-shrink:0; }
.dp-fin-desc { font-size:.81rem; font-weight:600; color:var(--dp-text-h); }
.dp-fin-meta { font-size:.7rem;  color:var(--dp-text-m); }
.dp-fin-amt  { margin-left:auto; font-size:.85rem; font-weight:800; }
.dp-fin-amt.inc { color:var(--green); }
.dp-fin-amt.exp { color:var(--rose);  }

/* ══ QUICK ACTION BUTTONS ══ */
.dp-qa-grid { display:grid; grid-template-columns:1fr 1fr; gap:10px; }
.dp-qa-btn {
  display:flex; flex-direction:column; align-items:center; justify-content:center;
  gap:8px; padding:16px 10px;
  background:var(--dp-bg); border:1px solid var(--dp-border);
  border-radius:12px; text-decoration:none; color:var(--dp-text-b);
  font-size:.78rem; font-weight:600; transition:all var(--dp-trans); text-align:center;
}
.dp-qa-btn i { font-size:1.3rem; color:var(--dp-primary); }
.dp-qa-btn:hover { background:var(--dp-primary); color:#fff; border-color:var(--dp-primary); transform:scale(1.03); }
.dp-qa-btn:hover i { color:#fff; }

/* ══ ACCOUNT CARD ══ */
.dp-account { display:flex; align-items:center; gap:12px; padding:13px 20px; border-bottom:1px solid #f0f2f8; transition:background var(--dp-trans); }
.dp-account:last-child { border-bottom:none; }
.dp-account:hover { background:#f5f7ff; }
.dp-account-ico { width:40px; height:40px; border-radius:11px; display:flex; align-items:center; justify-content:center; font-size:1.1rem; flex-shrink:0; }
.dp-account-name { font-size:.83rem; font-weight:700; color:var(--dp-text-h); }
.dp-account-bank { font-size:.71rem; color:var(--dp-text-m); }
.dp-account-bal  { margin-left:auto; font-size:.9rem; font-weight:800; color:var(--dp-primary); }

/* ══ EMPTY STATE ══ */
.dp-empty { padding:40px; text-align:center; color:var(--dp-text-m); }
.dp-empty i { font-size:2.2rem; display:block; margin-bottom:10px; color:var(--dp-border); }
.dp-empty p { font-size:.82rem; margin:0; }

/* ══ RING CHART WRAPPER ══ */
.dp-ring-wrap { display:flex; flex-direction:column; align-items:center; justify-content:center; padding:20px 0 10px; }
.dp-ring-val  { font-size:1.9rem; font-weight:800; color:var(--dp-primary); margin-top:-4px; }
.dp-ring-lbl  { font-size:.75rem; color:var(--dp-text-m); margin-top:2px; }

/* ══ INSIGHT STRIP (Super Admin) ══ */
.dp-insight-strip {
  display:grid; grid-template-columns:repeat(4,1fr); gap:0;
  border:1px solid var(--dp-border); border-radius:var(--dp-radius);
  overflow:hidden; margin-bottom:18px; background:var(--dp-card);
  box-shadow:var(--dp-shadow);
}
.dp-insight-item {
  padding:16px 18px; border-right:1px solid var(--dp-border);
  transition:background var(--dp-trans);
}
.dp-insight-item:last-child { border-right:none; }
