<!DOCTYPE html>
<html lang="en"><head><meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1.0">
<title><%= title %> – Dreams Admin</title>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
<%- include('../partials/head') %>
</head><body>
<%- include('../partials/sidebar', { currentRoute: '/admin/menus' }) %>
<div class="main-content" id="mainContent">
<%- include('../partials/topbar') %>
<main class="page-content">
<%- include('../partials/flash') %>

<%
  const parentMenus = menuItems.filter(m => !m.parent_id);
  const subMenus = menuItems.filter(m => m.parent_id);
  const getChildren = (id) => menuItems.filter(m => m.parent_id === id);
%>

<div class="page-header">
  <div><div class="page-title">Menu Management</div><div class="page-subtitle">Manage sidebar navigation – labels, icons, routes & ordering</div></div>
  <div class="d-flex gap-2">
    <button class="btn btn-primary" onclick="openModal('addMenuModal')"><i class="bi bi-plus-lg"></i> Add Menu Item</button>
  </div>
</div>

<!-- STATS / OVERVIEW -->
<div class="card mb-4">
  <div class="card-header"><div class="card-title"><i class="bi bi-list-tree"></i> Menu Overview</div></div>
  <div class="card-body">
    <div class="grid" style="grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:1rem">
      <div style="padding:1rem;background:var(--bg);border-radius:10px;border:1.5px solid var(--border);text-align:center">
        <div style="font-size:1.5rem;margin-bottom:0.5rem">📋</div>
        <div style="font-weight:700;font-size:0.85rem">Total Items</div>
        <div style="font-size:0.7rem;color:var(--text3);margin:0.25rem 0"><%= menuItems.length %> menu entries</div>
        <span class="badge badge-info"><%= menuItems.length %></span>
      </div>
      <div style="padding:1rem;background:var(--bg);border-radius:10px;border:1.5px solid var(--border);text-align:center">
        <div style="font-size:1.5rem;margin-bottom:0.5rem">📁</div>
        <div style="font-weight:700;font-size:0.85rem">Parent Menus</div>
        <div style="font-size:0.7rem;color:var(--text3);margin:0.25rem 0">Top-level entries</div>
        <span class="badge badge-primary"><%= parentMenus.length %></span>
      </div>
      <div style="padding:1rem;background:var(--bg);border-radius:10px;border:1.5px solid var(--border);text-align:center">
        <div style="font-size:1.5rem;margin-bottom:0.5rem">📄</div>
        <div style="font-weight:700;font-size:0.85rem">Submenus</div>
        <div style="font-size:0.7rem;color:var(--text3);margin:0.25rem 0">Nested under parents</div>
        <span class="badge badge-secondary"><%= subMenus.length %></span>
      </div>
      <div style="padding:1rem;background:var(--bg);border-radius:10px;border:1.5px solid var(--border);text-align:center">
        <div style="font-size:1.5rem;margin-bottom:0.5rem">✅</div>
        <div style="font-weight:700;font-size:0.85rem">Active</div>
        <div style="font-size:0.7rem;color:var(--text3);margin:0.25rem 0">Currently visible</div>
        <span class="badge badge-success"><%= menuItems.filter(m=>m.is_active).length %></span>
      </div>
    </div>
  </div>
</div>

<!-- TABBED MENU TABLE -->
<style>
  .mtabs{display:flex;gap:0.5rem;border-bottom:1.5px solid var(--border);margin-bottom:1rem;flex-wrap:wrap}
  .mtab-btn{display:flex;align-items:center;gap:0.4rem;padding:0.65rem 1.1rem;background:transparent;border:none;border-bottom:2.5px solid transparent;font-weight:600;font-size:0.85rem;color:var(--text3);cursor:pointer;margin-bottom:-1.5px;transition:all .15s}
  .mtab-btn:hover{color:var(--primary)}
  .mtab-btn.active{color:var(--primary);border-bottom-color:var(--primary)}
  .mtab-pane{display:none}
  .mtab-pane.active{display:block}
</style>

<div class="mtabs" id="menuTabs">
  <button type="button" class="mtab-btn active" data-target="all-menus">
    <i class="bi bi-list-ul"></i> All Menu Items
  </button>
  <button type="button" class="mtab-btn" data-target="parent-menus">
    <i class="bi bi-folder"></i> Parent Menus
  </button>
  <button type="button" class="mtab-btn" data-target="sub-menus">
    <i class="bi bi-diagram-2"></i> Submenus
  </button>
</div>

<div id="menuTabContent">

  <!-- ALL MENU ITEMS -->
  <div class="mtab-pane active" id="all-menus">
    <div class="card">
      <div class="card-header">
        <div class="card-title"><i class="bi bi-list-ul"></i> All Menu Items (<%= menuItems.length %>)</div>
      </div>
      <div class="table-wrap">
        <table>
          <thead><tr><th>Order</th><th>Label</th><th>Hindi Label</th><th>Icon</th><th>Route</th><th>Type</th>
            <!-- <th>Parent</th> -->
            <th>Badge</th>
            <th>Status</th><th>Actions</th></tr></thead>
          <tbody>
            <% menuItems.forEach(m=>{ %>
            <% const parent = m.parent_id ? menuItems.find(p=>p.id===m.parent_id) : null; %>
            <tr>
              <td style="font-size:0.8rem;color:var(--text3)"><%= m.sort_order %></td>
              <td>
                <div style="font-weight:600;font-size:0.82rem"><i class="bi <%= m.icon||'bi-dot' %>"></i> <%= m.label %></div>
              </td>
              <td style="font-size:0.75rem;color:var(--text3)"><%= m.label_hi || '—' %></td>
              <td style="font-size:0.75rem"><code><%= m.icon || '—' %></code></td>
              <td style="font-size:0.75rem;color:var(--text3)"><%= m.route || '—' %></td>
              <td><span class="badge badge-<%= m.menu_type==='admin'?'warning':m.menu_type==='vendor'?'info':'secondary' %>"><%= m.menu_type || 'default' %></span></td>
              <td>
                <% if(m.badge){ %><span class="badge badge-<%= m.badge_color||'success' %>"><%= m.badge %></span><% } else { %><span style="color:var(--text3)">—</span><% } %>
              </td>
              <td>
                <form method="POST" action="/admin/menus/<%= m.id %>?_method=PUT" style="display:inline">
                  <input type="hidden" name="label" value="<%= m.label %>">
                  <input type="hidden" name="label_hi" value="<%= m.label_hi||'' %>">
                  <input type="hidden" name="icon" value="<%= m.icon||'' %>">
                  <input type="hidden" name="route" value="<%= m.route||'' %>">
                  <input type="hidden" name="sort_order" value="<%= m.sort_order %>">
                  <input type="hidden" name="is_active" value="<%= m.is_active ? '0' : '1' %>">
                  <button class="btn btn-xs btn-<%= m.is_active?'success':'secondary' %>">
                    <i class="bi bi-<%= m.is_active?'check-circle':'pause-circle' %>"></i> <%= m.is_active?'Active':'Inactive' %>
                  </button>
                </form>
              </td>
              <td style="display:flex;gap:0.35rem">
                <button class="btn btn-xs btn-secondary" onclick='openEditMenu(<%- JSON.stringify(m) %>)'><i class="bi bi-pencil"></i></button>
                <form method="POST" action="/admin/menus/<%= m.id %>?_method=DELETE" onsubmit="return confirm('Delete this menu item?')">
                  <button class="btn btn-xs btn-danger"><i class="bi bi-trash"></i></button>
                </form>
              </td>
            </tr>
            <% }) %>
            <% if(!menuItems.length){ %>
            <tr><td colspan="10"><div class="empty-state"><i class="bi bi-list-tree"></i><h3>No menu items yet</h3><button class="btn btn-primary mt-2" onclick="openModal('addMenuModal')">Add First Menu Item</button></div></td></tr>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>
  </div>

  <!-- PARENT MENUS -->
  <div class="mtab-pane" id="parent-menus">
    <div class="card mb-0">
      <div class="card-header">
        <div class="card-title"><i class="bi bi-folder"></i> Parent Menus (<%= parentMenus.length %>)</div>
      </div>
      <div class="table-wrap">
        <table>
          <thead><tr><th>Order</th><th>Label</th><th>Icon</th><th>Route</th><th>Submenus</th><th>Status</th><th>Actions</th></tr></thead>
          <tbody>
            <% parentMenus.forEach(m=>{ %>
            <tr>
              <td style="font-size:0.8rem;color:var(--text3)"><%= m.sort_order %></td>
              <td style="font-weight:600;font-size:0.82rem"><i class="bi <%= m.icon||'bi-dot' %>"></i> <%= m.label %></td>
              <td style="font-size:0.75rem"><code><%= m.icon || '—' %></code></td>
              <td style="font-size:0.75rem;color:var(--text3)"><%= m.route || '—' %></td>
              <td><span class="badge badge-info"><%= getChildren(m.id).length %> items</span></td>
              <td><span class="badge badge-<%= m.is_active?'success':'secondary' %>"><%= m.is_active?'Active':'Inactive' %></span></td>
              <td>
                <button class="btn btn-xs btn-secondary" onclick='openEditMenu(<%- JSON.stringify(m) %>)'><i class="bi bi-pencil"></i></button>
              </td>
            </tr>
            <% }) %>
            <% if(!parentMenus.length){ %><tr><td colspan="7"><div class="empty-state"><i class="bi bi-folder"></i><h3>No parent menus</h3></div></td></tr><% } %>
          </tbody>
        </table>
      </div>
    </div>
  </div>

  <!-- SUBMENUS -->
  <div class="mtab-pane" id="sub-menus">
    <div class="card mb-0">
      <div class="card-header">
        <div class="card-title"><i class="bi bi-diagram-2"></i> Submenus (<%= subMenus.length %>)</div>
      </div>
      <div class="table-wrap">
        <table>
          <thead><tr><th>Order</th><th>Label</th><th>Parent</th><th>Route</th><th>Status</th><th>Actions</th></tr></thead>
          <tbody>
            <% subMenus.forEach(m=>{ %>
            <% const parent = menuItems.find(p=>p.id===m.parent_id); %>
            <tr>
              <td style="font-size:0.8rem;color:var(--text3)"><%= m.sort_order %></td>
              <td style="font-weight:600;font-size:0.82rem"><i class="bi <%= m.icon||'bi-dot' %>"></i> <%= m.label %></td>
              <td><% if(parent){ %><span class="badge badge-primary"><%= parent.label %></span><% } else { %>—<% } %></td>
              <td style="font-size:0.75rem;color:var(--text3)"><%= m.route || '—' %></td>
              <td><span class="badge badge-<%= m.is_active?'success':'secondary' %>"><%= m.is_active?'Active':'Inactive' %></span></td>
              <td>
                <button class="btn btn-xs btn-secondary" onclick='openEditMenu(<%- JSON.stringify(m) %>)'><i class="bi bi-pencil"></i></button>
              </td>
            </tr>
            <% }) %>
            <% if(!subMenus.length){ %><tr><td colspan="6"><div class="empty-state"><i class="bi bi-diagram-2"></i><h3>No submenus</h3></div></td></tr><% } %>
          </tbody>
        </table>
      </div>
    </div>
  </div>

</div>

<!-- ADD MENU MODAL -->
<div class="modal-overlay" id="addMenuModal">
  <div class="modal" style="max-width:650px">
    <div class="modal-header"><div class="modal-title"><i class="bi bi-list-ul"></i> Add Menu Item</div><button class="modal-close" onclick="closeModal('addMenuModal')"><i class="bi bi-x"></i></button></div>
    <div class="modal-body">
      <form method="POST" action="/admin/menus">
        <div class="grid grid-2">
          <div class="form-group"><label>Label (English) *</label><input type="text" name="label" class="form-control" placeholder="Dashboard" required></div>
          <div class="form-group"><label>Label (Hindi)</label><input type="text" name="label_hi" class="form-control" placeholder="डैशबोर्ड"></div>
          <div class="form-group"><label>Icon (Bootstrap Icon class)</label><input type="text" name="icon" class="form-control" placeholder="bi-speedometer2"></div>
          <div class="form-group"><label>Route / URL</label><input type="text" name="route" class="form-control" placeholder="/admin/dashboard"></div>
          <div class="form-group"><label>Menu Type</label>
            <select name="menu_type" class="form-control">
              <option value="default">Default</option>
              <option value="admin">Admin</option>
              <option value="vendor">Vendor</option>
            </select>
          </div>
          <div class="form-group"><label>Parent Menu</label>
            <select name="parent_id" class="form-control">
              <option value="">— None (Top Level) —</option>
              <% parentMenus.forEach(p=>{ %><option value="<%= p.id %>"><%= p.label %></option><% }) %>
            </select>
          </div>
          <div class="form-group"><label>Sort Order</label><input type="number" name="sort_order" class="form-control" value="0"></div>
          <div class="form-group"><label>Badge Text</label><input type="text" name="badge" class="form-control" placeholder="New"></div>
          <div class="form-group"><label>Badge Color</label>
            <select name="badge_color" class="form-control">
              <option value="success">Success</option>
              <option value="primary">Primary</option>
              <option value="warning">Warning</option>
              <option value="danger">Danger</option>
              <option value="info">Info</option>
              <option value="secondary">Secondary</option>
            </select>
          </div>
        </div>
        <div class="modal-footer" style="padding:0;border:none">
          <button type="button" class="btn btn-secondary" onclick="closeModal('addMenuModal')">Cancel</button>
          <button type="submit" class="btn btn-primary"><i class="bi bi-plus"></i> Create Menu Item</button>
        </div>
      </form>
    </div>
  </div>
</div>

<!-- EDIT MENU MODAL -->
<div class="modal-overlay" id="editMenuModal">
  <div class="modal" style="max-width:650px">
    <div class="modal-header"><div class="modal-title"><i class="bi bi-pencil"></i> Edit Menu Item</div><button class="modal-close" onclick="closeModal('editMenuModal')"><i class="bi bi-x"></i></button></div>
    <div class="modal-body">
      <form method="POST" id="editMenuForm" action="">
        <div class="grid grid-2">
          <div class="form-group"><label>Label (English) *</label><input type="text" name="label" id="edit_label" class="form-control" required></div>
          <div class="form-group"><label>Label (Hindi)</label><input type="text" name="label_hi" id="edit_label_hi" class="form-control"></div>
          <div class="form-group"><label>Icon (Bootstrap Icon class)</label><input type="text" name="icon" id="edit_icon" class="form-control"></div>
          <div class="form-group"><label>Route / URL</label><input type="text" name="route" id="edit_route" class="form-control"></div>
          <div class="form-group"><label>Sort Order</label><input type="number" name="sort_order" id="edit_sort_order" class="form-control"></div>
          <div class="form-group"><label>Status</label>
            <select name="is_active" id="edit_is_active" class="form-control">
              <option value="1">Active</option>
              <option value="0">Inactive</option>
            </select>
          </div>
        </div>
        <div class="modal-footer" style="padding:0;border:none">
          <button type="button" class="btn btn-secondary" onclick="closeModal('editMenuModal')">Cancel</button>
          <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg"></i> Save Changes</button>
        </div>
      </form>
    </div>
  </div>
</div>

<script>
function openEditMenu(m){
  document.getElementById('editMenuForm').action = '/admin/menus/' + m.id + '?_method=PUT';
  document.getElementById('edit_label').value = m.label || '';
  document.getElementById('edit_label_hi').value = m.label_hi || '';
  document.getElementById('edit_icon').value = m.icon || '';
  document.getElementById('edit_route').value = m.route || '';
  document.getElementById('edit_sort_order').value = m.sort_order || 0;
  document.getElementById('edit_is_active').value = m.is_active ? '1' : '0';
  openModal('editMenuModal');
}

// Tab switching (self-contained, no Bootstrap JS dependency)
document.querySelectorAll('#menuTabs .mtab-btn').forEach(btn => {
  btn.addEventListener('click', function () {
    const target = this.getAttribute('data-target');

    document.querySelectorAll('#menuTabs .mtab-btn').forEach(b => b.classList.remove('active'));
    this.classList.add('active');

    document.querySelectorAll('#menuTabContent .mtab-pane').forEach(pane => pane.classList.remove('active'));
    document.getElementById(target).classList.add('active');
  });
});
</script>
<%- include('../partials/scripts') %>
</body></html>
