// ── BUILDER STATE ──
let currentPageId = null, selectedBlockId = null, blockCounter = 0;
let undoStack = [], redoStack = [], draggedBlockType = null;
let ckEditorInstance = null, ckEditorTargetId = null;
let autoSaveTimer = null;

// ── OPEN/CLOSE ──
function openBuilderNew() {
  currentPageId = null;
  document.getElementById('builderPageTitle').textContent = 'New Page';
  ['metaTitle','metaSlug','metaSeoTitle','metaDesc'].forEach(id => document.getElementById(id).value = '');
  document.getElementById('metaActive').checked = true;
  document.getElementById('templateSelect').value = 'default';
  clearCanvasSilent();
  document.getElementById('builderModal').classList.add('show');
}
function openBuilderEdit(page) {
  currentPageId = page.id;
  document.getElementById('builderPageTitle').textContent = 'Edit: ' + page.title;
  document.getElementById('builderPageId').value = page.id;
  document.getElementById('metaTitle').value = page.title || '';
  document.getElementById('metaSlug').value = page.slug || '';
  document.getElementById('metaSeoTitle').value = page.meta_title || '';
  document.getElementById('metaDesc').value = page.meta_desc || '';
  document.getElementById('metaActive').checked = !!page.is_active;
  document.getElementById('templateSelect').value = page.template || 'default';
  clearCanvasSilent();
  if (page.content) {
    const tmp = document.createElement('div');
    tmp.innerHTML = page.content;
    Array.from(tmp.children).length > 0
      ? Array.from(tmp.children).forEach(c => insertRawHTMLBlock(c.outerHTML))
      : insertRawHTMLBlock(page.content);
  }
  document.getElementById('builderModal').classList.add('show');
}
function closeBuilder() { document.getElementById('builderModal').classList.remove('show'); }

// ── INSERT BLOCK ──
function insertBlock(type) {
  insertRawHTMLBlock(BLOCK_TEMPLATES[type] || `<div style="padding:1rem;text-align:center;color:#8a97a8;">Block: ${type}</div>`, type);
}
function insertRawHTMLBlock(html, type) {
  const id = 'block_' + (++blockCounter);
  const wrap = document.createElement('div');
  wrap.className = 'canvas-section'; wrap.id = id; wrap.dataset.type = type || 'raw';
  wrap.innerHTML = `<div class="section-controls">
    <button class="sc-btn" onclick="openCKEditor('${id}')" title="Edit"><i class="bi bi-pencil"></i></button>
    <button class="sc-btn" onclick="moveBlockUp('${id}')" title="Up"><i class="bi bi-arrow-up"></i></button>
    <button class="sc-btn" onclick="moveBlockDown('${id}')" title="Down"><i class="bi bi-arrow-down"></i></button>
    <button class="sc-btn" onclick="duplicateBlock('${id}')" title="Duplicate"><i class="bi bi-copy"></i></button>
    <button class="sc-btn" onclick="deleteBlock('${id}')" title="Delete" style="color:#fca5a5;"><i class="bi bi-trash"></i></button>
  </div><div class="block-content" id="content_${id}">${html}</div>`;
  wrap.addEventListener('click', () => selectBlock(id));
  document.getElementById('canvasBlocks').appendChild(wrap);
  document.getElementById('canvasEmpty').style.display = 'none';
  selectBlock(id); pushUndo(); triggerAutoSave();
}
function selectBlock(id) {
  document.querySelectorAll('.canvas-section').forEach(s => s.classList.remove('selected'));
  const b = document.getElementById(id); if(!b) return;
  b.classList.add('selected'); selectedBlockId = id;
  showPropsFor(id, b.dataset.type);
}
function showPropsFor(id, type) {
  document.getElementById('selectedBlockLabel').textContent = type || 'block';
  document.getElementById('propsBody').innerHTML = `
    <div class="prop-group">
      <div class="prop-group-title"><i class="bi bi-palette2"></i> Background</div>
      <div class="prop-row"><span class="prop-label">Color</span><input type="color" class="prop-color" value="#ffffff" oninput="applyBgColor('${id}',this.value)"></div>
      <div class="prop-row"><span class="prop-label">Opacity</span><input type="range" class="prop-range" min="0" max="100" value="100" oninput="applyOpacity('${id}',this.value);document.getElementById('opV_${id}').textContent=this.value+'%'"><span class="prop-range-val" id="opV_${id}">100%</span></div>
    </div>
    <div class="prop-group">
      <div class="prop-group-title"><i class="bi bi-arrows-angle-expand"></i> Spacing</div>
      <div class="prop-row"><span class="prop-label">Pad Top</span><input type="range" class="prop-range" min="0" max="200" value="0" oninput="applyPaddingTop('${id}',this.value)"><span class="prop-range-val">px</span></div>
      <div class="prop-row"><span class="prop-label">Pad Bot</span><input type="range" class="prop-range" min="0" max="200" value="0" oninput="applyPaddingBottom('${id}',this.value)"><span class="prop-range-val">px</span></div>
    </div>
    <div class="prop-group">
      <div class="prop-group-title"><i class="bi bi-border-all"></i> Border & Shadow</div>
      <div class="prop-row"><span class="prop-label">Radius</span><input type="range" class="prop-range" min="0" max="40" value="0" oninput="applyBorderRadius('${id}',this.value)"><span class="prop-range-val">px</span></div>
      <div class="prop-row"><span class="prop-label">Shadow</span>
        <select class="prop-input" onchange="applyShadow('${id}',this.value)">
          <option value="">None</option>
          <option value="0 2px 8px rgba(0,0,0,0.08)">Light</option>
          <option value="0 4px 20px rgba(0,0,0,0.12)">Medium</option>
          <option value="0 8px 40px rgba(0,0,0,0.2)">Heavy</option>
        </select>
      </div>
    </div>
    <div class="prop-group">
      <div class="prop-group-title"><i class="bi bi-pencil-square"></i> Content</div>
      <button class="btn btn-outline btn-sm" onclick="openCKEditor('${id}')" style="width:100%;justify-content:center;"><i class="bi bi-pencil"></i> Open Rich Text Editor</button>
    </div>
    <div class="prop-group">
      <div class="prop-group-title"><i class="bi bi-code-slash"></i> HTML</div>
      <button onclick="openBlockHTMLEdit('${id}')" style="width:100%;justify-content:center;padding:0.4rem;border-radius:6px;border:none;background:#1a2332;color:#a8ff78;cursor:pointer;font-size:0.75rem;font-family:inherit;"><i class="bi bi-code"></i> Edit Raw HTML</button>
    </div>`;
}

function applyBgColor(id,v){const c=document.getElementById('content_'+id);if(c&&c.firstElementChild)c.firstElementChild.style.background=v;}
function applyOpacity(id,v){const b=document.getElementById(id);if(b)b.style.opacity=v/100;}
function applyPaddingTop(id,v){const c=document.getElementById('content_'+id);if(c&&c.firstElementChild)c.firstElementChild.style.paddingTop=v+'px';}
function applyPaddingBottom(id,v){const c=document.getElementById('content_'+id);if(c&&c.firstElementChild)c.firstElementChild.style.paddingBottom=v+'px';}
function applyBorderRadius(id,v){const b=document.getElementById(id);if(b)b.style.borderRadius=v+'px';}
function applyShadow(id,v){const b=document.getElementById(id);if(b)b.style.boxShadow=v;}

// ── CKEDITOR ──
function openCKEditor(blockId) {
  ckEditorTargetId = blockId;
  const el = document.getElementById('content_' + blockId);
  const cur = el ? el.innerHTML : '';
  document.getElementById('ckEditorContainer').innerHTML = '<div id="ckEditorTarget"></div>';
  document.getElementById('ckEditorModal').classList.add('show');
  if (ckEditorInstance) { try { ckEditorInstance.destroy(); } catch(e){} ckEditorInstance = null; }
  if (typeof CKEDITOR !== 'undefined' && CKEDITOR.ClassicEditor) {
    CKEDITOR.ClassicEditor.create(document.getElementById('ckEditorTarget'), { initialData: removeControls(cur) })
      .then(ed => { ckEditorInstance = ed; })
      .catch(() => { fallbackTextarea(removeControls(cur)); });
  } else { fallbackTextarea(removeControls(cur)); }
}
function fallbackTextarea(html) {
  document.getElementById('ckEditorContainer').innerHTML = `<textarea id="ckFallback" style="width:100%;min-height:300px;font-family:inherit;font-size:0.85rem;border:1.5px solid var(--border);border-radius:8px;padding:1rem;color:var(--text1);background:var(--bg);">${html}</textarea>`;
}
function removeControls(html) {
  const t = document.createElement('div'); t.innerHTML = html;
  const sc = t.querySelector('.section-controls'); if(sc) sc.remove();
  return t.innerHTML;
}
function closeCKEditor() {
  document.getElementById('ckEditorModal').classList.remove('show');
  if (ckEditorInstance) { try { ckEditorInstance.destroy(); } catch(e){} ckEditorInstance = null; }
}
function applyCKEditorContent() {
  if (!ckEditorTargetId) return;
  const content = ckEditorInstance ? ckEditorInstance.getData() : (document.getElementById('ckFallback')?.value || '');
  const el = document.getElementById('content_' + ckEditorTargetId);
  if (el) el.innerHTML = content;
  closeCKEditor(); pushUndo(); triggerAutoSave();
}
function openBlockHTMLEdit(blockId) {
  const el = document.getElementById('content_' + blockId);
  document.getElementById('htmlViewTextarea').value = el ? removeControls(el.innerHTML) : '';
  document.getElementById('htmlViewTextarea').dataset.blockId = blockId;
  document.getElementById('htmlViewModal').classList.add('show');
}

// ── BLOCK CONTROLS ──
function deleteBlock(id) {
  const el = document.getElementById(id); if(el) el.remove();
  if (!document.getElementById('canvasBlocks').children.length) document.getElementById('canvasEmpty').style.display = '';
  selectedBlockId = null;
  document.getElementById('propsBody').innerHTML = '<div style="text-align:center;padding:2rem;color:var(--text3);"><i class="bi bi-mouse" style="font-size:2rem;opacity:0.3;display:block;margin-bottom:0.75rem;"></i><div style="font-size:0.78rem;">Click a block to edit its properties</div></div>';
  document.getElementById('selectedBlockLabel').textContent = 'No selection';
  pushUndo();
}
function deleteSelected(){if(selectedBlockId)deleteBlock(selectedBlockId);}
function moveBlockUp(id){const el=document.getElementById(id);if(el&&el.previousElementSibling)el.parentNode.insertBefore(el,el.previousElementSibling);pushUndo();}
function moveBlockDown(id){const el=document.getElementById(id);if(el&&el.nextElementSibling)el.parentNode.insertBefore(el.nextElementSibling,el);pushUndo();}
function moveSelectedUp(){if(selectedBlockId)moveBlockUp(selectedBlockId);}
function moveSelectedDown(){if(selectedBlockId)moveBlockDown(selectedBlockId);}
function duplicateBlock(id) {
  const el = document.getElementById(id); if(!el) return;
  const clone = el.cloneNode(true);
  const newId = 'block_' + (++blockCounter);
  clone.id = newId;
  clone.querySelectorAll('[onclick]').forEach(b => b.setAttribute('onclick', b.getAttribute('onclick').replace(new RegExp(id,'g'), newId)));
  clone.querySelector('.block-content').id = 'content_' + newId;
  clone.addEventListener('click', () => selectBlock(newId));
  el.parentNode.insertBefore(clone, el.nextSibling);
  selectBlock(newId); pushUndo();
}
function duplicateSelected(){if(selectedBlockId)duplicateBlock(selectedBlockId);}

// ── DRAG & DROP ──
function dragBlock(event, type) { draggedBlockType = type; event.dataTransfer.effectAllowed = 'copy'; }
function handleCanvasDrop(event) {
  event.preventDefault();
  document.getElementById('canvasDropZone').classList.remove('drag-over');
  if (draggedBlockType) { insertBlock(draggedBlockType); draggedBlockType = null; }
}

// ── UNDO/REDO ──
function getSnap(){return document.getElementById('canvasBlocks').innerHTML;}
function pushUndo(){undoStack.push(getSnap());if(undoStack.length>50)undoStack.shift();redoStack=[];}
function builderUndo(){if(undoStack.length<2)return;redoStack.push(undoStack.pop());document.getElementById('canvasBlocks').innerHTML=undoStack[undoStack.length-1]||'';if(!document.getElementById('canvasBlocks').children.length)document.getElementById('canvasEmpty').style.display='';}
function builderRedo(){if(!redoStack.length)return;const s=redoStack.pop();undoStack.push(s);document.getElementById('canvasBlocks').innerHTML=s;if(!document.getElementById('canvasBlocks').children.length)document.getElementById('canvasEmpty').style.display='';}

// ── CANVAS UTILS ──
function clearCanvas(){if(!confirm('Clear all blocks?'))return;clearCanvasSilent();}
function clearCanvasSilent(){document.getElementById('canvasBlocks').innerHTML='';document.getElementById('canvasEmpty').style.display='';selectedBlockId=null;undoStack=[];redoStack=[];}
function setPreviewSize(size,btn){['desktop','tablet','mobile'].forEach(s=>{document.getElementById('canvasFrame').classList.remove(s);document.getElementById('btn-'+s).classList.remove('active');});document.getElementById('canvasFrame').classList.add(size);btn.classList.add('active');}
function changeTemplate(val){document.getElementById('formTemplate').value=val;}

// ── HTML VIEW ──
function getPageHTML() {
  const blocks = document.getElementById('canvasBlocks');
  const tmp = blocks.cloneNode(true);
  tmp.querySelectorAll('.section-controls').forEach(c => c.remove());
  tmp.querySelectorAll('.canvas-section').forEach(s => {
    const inner = s.querySelector('.block-content');
    if (inner) { while(inner.firstChild) s.parentNode.insertBefore(inner.firstChild, s); s.remove(); }
  });
  return tmp.innerHTML.trim();
}
function toggleHTMLView(){document.getElementById('htmlViewTextarea').value=getPageHTML();delete document.getElementById('htmlViewTextarea').dataset.blockId;document.getElementById('htmlViewModal').classList.add('show');}
function copyHTML(){navigator.clipboard.writeText(document.getElementById('htmlViewTextarea').value);}
function applyHTMLEdit() {
  const ta = document.getElementById('htmlViewTextarea');
  if (ta.dataset.blockId) {
    const el = document.getElementById('content_' + ta.dataset.blockId);
    if (el) el.innerHTML = ta.value;
  } else { clearCanvasSilent(); if(ta.value.trim()) insertRawHTMLBlock(ta.value.trim()); }
  document.getElementById('htmlViewModal').classList.remove('show');
  pushUndo();
}

// ── SAVE / PUBLISH ──
function saveBuilderPage() {
  const title = document.getElementById('metaTitle').value.trim();
  if (!title) { alert('Please enter a page title.'); return; }
  document.getElementById('formTitle').value = title;
  document.getElementById('formSlug').value = document.getElementById('metaSlug').value.trim() || title.toLowerCase().replace(/[^a-z0-9]+/g,'-');
  document.getElementById('formContent').value = getPageHTML();
  document.getElementById('formMetaTitle').value = document.getElementById('metaSeoTitle').value;
  document.getElementById('formMetaDesc').value = document.getElementById('metaDesc').value;
  document.getElementById('formIsActive').value = document.getElementById('metaActive').checked ? '1' : '0';
  document.getElementById('formTemplate').value = document.getElementById('templateSelect').value;
  const form = document.getElementById('builderForm');
  form.action = currentPageId ? '/admin/pages/' + currentPageId + '?_method=PUT' : '/admin/pages';
  form.submit();
}
function saveBuilderDraft() {
  try { localStorage.setItem('page_draft_'+(currentPageId||'new'), JSON.stringify({title:document.getElementById('metaTitle').value,content:getPageHTML(),ts:Date.now()})); } catch(e){}
  document.getElementById('saveStatusText').textContent = 'Draft saved';
}
function triggerAutoSave() {
  clearTimeout(autoSaveTimer);
  document.getElementById('autoSaveStatus').innerHTML = '<span style="font-size:0.7rem;color:rgba(255,255,255,0.4);">Saving…</span>';
  autoSaveTimer = setTimeout(() => {
    document.getElementById('autoSaveStatus').innerHTML = '<span class="publish-status"><span class="dot"></span></span><span style="font-size:0.7rem;color:rgba(255,255,255,0.5);"> Auto-saved</span>';
  }, 1500);
}

// ── PREVIEW ──
function previewPage() {
  const w = window.open('', '_blank');
  w.document.write(`<!DOCTYPE html><html><head><meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1.0"><title>Preview</title><style>body{font-family:'Poppins',sans-serif;margin:0;}*{box-sizing:border-box;}</style></head><body>${getPageHTML()}</body></html>`);
  w.document.close();
}

// ── BLOCKS FILTER ──
function filterBlocks(q) { document.querySelectorAll('.block-item').forEach(b => { b.style.display = !q || b.querySelector('span').textContent.toLowerCase().includes(q.toLowerCase()) ? '' : 'none'; }); }
function switchBlocksTab(btn, cat) {
  document.querySelectorAll('.blocks-tab').forEach(t => t.classList.remove('active'));
  btn.classList.add('active');
  document.querySelectorAll('.block-item').forEach(b => { b.style.display = b.dataset.cat === cat ? '' : 'none'; });
}

// ── PAGES LIST UTILS ──
function filterPages(q) { document.querySelectorAll('#pagesTable tbody tr').forEach(r => { r.style.display = r.innerText.toLowerCase().includes(q.toLowerCase()) ? '' : 'none'; }); }
function filterByTemplate(val) { document.querySelectorAll('#pagesTable tbody tr').forEach(r => { r.style.display = !val || r.dataset.template === val ? '' : 'none'; }); }
function duplicatePage(id) { if(confirm('Duplicate this page?')){const f=document.createElement('form');f.method='POST';f.action='/admin/pages/'+id+'/duplicate';document.body.appendChild(f);f.submit();} }

// Init
document.querySelectorAll('.block-item').forEach(b => { if(b.dataset.cat !== 'layout') b.style.display = 'none'; });
pushUndo();
</script>

<%- include('../partials/scripts') %>
</body>
</html>
