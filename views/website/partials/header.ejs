<script>
/* =========================================================
   1) SCROLL PROGRESS BAR
   ========================================================= */
(function(){
  const bar = document.getElementById('scrollProgress');
  function updateProgress(){
    const h = document.documentElement;
    const scrolled = (h.scrollTop) / (h.scrollHeight - h.clientHeight) * 100;
    bar.style.width = (isFinite(scrolled) ? scrolled : 0) + '%';
  }
  window.addEventListener('scroll', updateProgress, { passive:true });
  updateProgress();
})();

/* =========================================================
   2) DARK MODE TOGGLE (persisted in localStorage)
   ========================================================= */
function applyDarkModeIcon(isDark){
  const icon = document.getElementById('darkModeIcon');
  icon.className = isDark ? 'bi bi-sun' : 'bi bi-moon-stars';
}
function toggleDarkMode(){
  const html = document.documentElement;
  const isDark = html.getAttribute('data-theme') === 'dark';
  const next = isDark ? 'light' : 'dark';
  html.setAttribute('data-theme', next);
  localStorage.setItem('em_theme', next);
  applyDarkModeIcon(next === 'dark');
}
(function(){
  const saved = localStorage.getItem('em_theme');
  const prefersDark = window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches;
  const theme = saved || (prefersDark ? 'dark' : 'light');
  document.documentElement.setAttribute('data-theme', theme);
  applyDarkModeIcon(theme === 'dark');
})();

/* =========================================================
   3) NOTIFICATION DROPDOWN
   TODO (backend): replace demo notifList markup with a fetch to
   GET /api/notifications and POST /api/notifications/read-all
   ========================================================= */
function toggleNotifDropdown(e){
  e.stopPropagation();
  document.getElementById('notifDropdown').classList.toggle('open');
}
function markAllNotifRead(){
  document.getElementById('notifBadge').style.display = 'none';
  document.getElementById('notifDropdown').classList.remove('open');
}
document.addEventListener('click', function(e){
  const dd = document.getElementById('notifDropdown');
  if(dd.classList.contains('open') && !dd.contains(e.target) && e.target.id !== 'notifBtn'){
    dd.classList.remove('open');
  }
});

/* =========================================================
   4) AI SMART SEARCH — live dropdown
   TODO (backend): replace SAMPLE_INDEX with a real endpoint, e.g.
   fetch('/api/search/suggest?q=' + encodeURIComponent(query))
     .then(r => r.json()).then(renderResults)
   For now this filters a small in-memory sample index so the UI
   is fully functional and demo-able without a server change.
   ========================================================= */
const SAMPLE_INDEX = {
  posts: [
    { title: 'SIP से रिटायरमेंट तक ₹1 करोड़ कैसे बनाएं', slug: 'sip-1-crore-plan', cat: 'Investing' },
    { title: 'घर बैठे पैसे कमाने के 15 तरीके (2026)', slug: 'ghar-baithe-paisa-kamaye', cat: 'Online Earning' },
    { title: 'Freelancing शुरू करने की पूरी गाइड', slug: 'freelancing-guide', cat: 'Freelancing' },
    { title: 'YouTube Shorts से कमाई कैसे करें', slug: 'youtube-shorts-earning', cat: 'YouTube' },
    { title: 'GST रिटर्न फाइल करने का तरीका', slug: 'gst-return-filing', cat: 'Tax' },
  ],
  categories: [
    { name: 'Online Earning', slug: 'online-earning' },
    { name: 'Freelancing', slug: 'freelancing' },
    { name: 'Investing', slug: 'investing' },
    { name: 'Govt Jobs', slug: 'govt-jobs' },
  ],
  faqs: [
    { q: 'SIP में निवेश कैसे शुरू करें?', slug: 'faq-sip-start' },
    { q: 'Freelancing के लिए कौन सी स्किल सीखें?', slug: 'faq-freelance-skill' },
  ]
};

const searchInput = document.getElementById('smartSearchInput');
const searchDropdown = document.getElementById('searchDropdown');

function renderSearchResults(query){
  if(!query || query.trim().length < 2){
    searchDropdown.classList.remove('open');
    searchDropdown.innerHTML = '';
    return;
  }
  const q = query.trim().toLowerCase();
  const posts = SAMPLE_INDEX.posts.filter(p => p.title.toLowerCase().includes(q));
  const cats = SAMPLE_INDEX.categories.filter(c => c.name.toLowerCase().includes(q));
  const faqs = SAMPLE_INDEX.faqs.filter(f => f.q.toLowerCase().includes(q));

  if(!posts.length && !cats.length && !faqs.length){
    searchDropdown.innerHTML = '<div class="sd-empty">कोई परिणाम नहीं मिला "' + query + '" के लिए</div>';
    searchDropdown.classList.add('open');
    return;
  }

  let html = '';
  if(posts.length){
    html += '<div class="sd-section-label">Posts</div>';
    posts.forEach(p => {
      html += `<a href="/blog/${p.slug}" class="sd-item"><div class="sd-icon"><i class="bi bi-file-text"></i></div><div class="sd-text">${p.title}<small>${p.cat}</small></div></a>`;
    });
  }
  if(cats.length){
    html += '<div class="sd-section-label">Categories</div>';
    cats.forEach(c => {
      html += `<a href="/category/${c.slug}" class="sd-item"><div class="sd-icon"><i class="bi bi-grid"></i></div><div class="sd-text">${c.name}</div></a>`;
    });
  }
  if(faqs.length){
    html += '<div class="sd-section-label">FAQs</div>';
    faqs.forEach(f => {
      html += `<a href="/faq/${f.slug}" class="sd-item"><div class="sd-icon"><i class="bi bi-question-circle"></i></div><div class="sd-text">${f.q}</div></a>`;
    });
  }
  searchDropdown.innerHTML = html;
  searchDropdown.classList.add('open');
}

let searchDebounce;
searchInput.addEventListener('input', function(){
  clearTimeout(searchDebounce);
  const val = this.value;
  searchDebounce = setTimeout(() => renderSearchResults(val), 150);
});
searchInput.addEventListener('focus', function(){ renderSearchResults(this.value); });
document.addEventListener('click', function(e){
  if(!e.target.closest('.nav-search-bar')) searchDropdown.classList.remove('open');
});

/* =========================================================
   5) LIVE MARKET MINI-TICKER — REAL DATA
   Pulls from our own cached backend endpoint GET /api/market
   (see routes/market.js). The backend refreshes its cache every
   15s in the background, so this fetch is cheap and rate-limit-safe
   no matter how many visitors hit the page at once.
   ========================================================= */
async function loadMarketData(){
  try {
    const res = await fetch('/api/market');
    const json = await res.json();
    const items = json.data || [];

    const track = document.getElementById('marketTrack');
    if(!items.length){
      track.innerHTML = '<span class="market-item" style="color:var(--text3)">Market data unavailable</span>';
      return;
    }

    const doubled = [...items, ...items];
    track.innerHTML = doubled.map(m => `
      <span class="market-item">
        ${m.label} <strong>${m.value}</strong>
        ${m.change ? `<span class="${m.up ? 'mi-up' : 'mi-down'}"><i class="bi bi-caret-${m.up ? 'up' : 'down'}-fill"></i> ${m.change}</span>` : ''}
      </span>
    `).join('');
  } catch(e){
    console.error('Market data load failed:', e);
  }
}
loadMarketData();
setInterval(loadMarketData, 10000);

/* =========================================================
   6) HINDI ⇄ ENGLISH FULL-PAGE TRANSLATE
   Uses Google's free Website Translator widget (no API key).
   Clicking "हिं" restores the original page language.
   Clicking "EN" auto-translates the whole page to English.
   ========================================================= */
function googleTranslateElementInit(){
  new google.translate.TranslateElement({
    pageLanguage: '<%= typeof currentLang !== "undefined" ? currentLang : "hi" %>',
    includedLanguages: 'hi,en',
    autoDisplay: false
  }, 'google_translate_element');
}

function setGoogTransCookie(lang){
  const pageLang = '<%= typeof currentLang !== "undefined" ? currentLang : "hi" %>';
  const value = (lang === pageLang) ? '' : '/' + pageLang + '/' + lang;
  document.cookie = 'googtrans=' + value + ';path=/';
  document.cookie = 'googtrans=' + value + ';path=/;domain=.' + window.location.hostname.replace(/^www\./,'');
}

function setLang(lang){
  setGoogTransCookie(lang);
  localStorage.setItem('em_lang', lang);
  window.location.reload();
}

(function(){
  const pageLang = '<%= typeof currentLang !== "undefined" ? currentLang : "hi" %>';
  const saved = localStorage.getItem('em_lang') || pageLang;
  document.getElementById('langBtnHi').classList.toggle('active', saved === 'hi');
  document.getElementById('langBtnEn').classList.toggle('active', saved === 'en');
})();
</script>
<script src="https://translate.google.com/translate_a/element.js?cb=googleTranslateElementInit"></script>
