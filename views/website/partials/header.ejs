<!DOCTYPE html>
<html lang="<%= typeof currentLang !== 'undefined' ? currentLang : 'hi' %>" data-theme="light">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= typeof title !== 'undefined' ? title : siteName %></title>
  <meta name="description" content="<%= typeof metaDesc !== 'undefined' ? metaDesc : (siteSettings.site_description||'') %>">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
  <link href="https://fonts.googleapis.com/css2?family=Hind:wght@300;400;500;600;700&family=Poppins:wght@400;500;600;700;800&family=Noto+Sans+Devanagari:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <style>
    :root {
      --accent: <%= theme.primary_color || '#1a7a4a' %>;
      --accent2: <%= theme.secondary_color || '#e8a020' %>;
      --accent-light: <%= theme.accent_light || '#e8f5ee' %>;
      --accent-dark: <%= theme.accent_dark || '#125c36' %>;
      --bg: #f7f9fc; --bg2: #ffffff; --bg3: #eef2f7;
      --nav-bg: <%= theme.nav_bg || '#ffffff' %>;
      --card-bg: #ffffff; --border: #e0e6ed;
      --text: #1a2332; --text2: #4a5568; --text3: #8a97a8;
      --radius: 10px; --shadow: 0 2px 12px rgba(0,0,0,0.09);
      --font-hi: 'Noto Sans Devanagari','Hind',sans-serif;
      --font-en: 'Poppins','Hind',sans-serif;
    }

    /* ---- DARK MODE TOKENS ---- */
    html[data-theme="dark"] {
      --bg: #0d1420; --bg2: #131c2b; --bg3: #1a2536;
      --nav-bg: #131c2b;
      --card-bg: #131c2b; --border: #233047;
      --text: #eef2f7; --text2: #b8c2d4; --text3: #6f7d93;
      --accent-light: #16301f;
    }

    * { margin:0; padding:0; box-sizing:border-box; }
    html { scroll-behavior:smooth; }
    body { background:var(--bg); color:var(--text); font-family:var(--font-en); line-height:1.7; overflow-x:hidden; transition:background .25s,color .25s; }
    a { text-decoration:none; color:inherit; }
    img { max-width:100%; display:block; }
    ::-webkit-scrollbar { width:5px; } ::-webkit-scrollbar-thumb { background:var(--accent); border-radius:3px; }
    button { font-family:inherit; }

    /* ---- SCROLL PROGRESS BAR ---- */
    .scroll-progress { position:fixed; top:0; left:0; height:3px; background:linear-gradient(90deg,var(--accent),var(--accent2)); width:0%; z-index:9999; transition:width .1s linear; }

    /* TICKER */
    .ticker-bar { background:var(--accent); padding:0.35rem 0; overflow:hidden; position:relative; }
    .ticker-label { position:absolute; left:0; top:0; bottom:0; background:var(--accent2); padding:0 1rem; display:flex; align-items:center; font-size:0.72rem; font-weight:700; color:#fff; z-index:2; white-space:nowrap; }
    .ticker-track { display:flex; white-space:nowrap; animation:tickscroll 40s linear infinite; padding-left:160px; }
    .ticker-track:hover { animation-play-state:paused; }
    .ticker-item { font-size:0.78rem; color:#fff; padding:0 2rem; font-family:var(--font-hi); }
    @keyframes tickscroll { 0%{transform:translateX(0)} 100%{transform:translateX(-50%)} }

    /* ---- MARKET TICKER (mini, sample data) ---- */
    .market-bar { background:var(--bg3); border-bottom:1px solid var(--border); overflow:hidden; }
    .market-track { display:flex; white-space:nowrap; animation:tickscroll 28s linear infinite; padding:0.32rem 0; }
    .market-track:hover { animation-play-state:paused; }
    .market-item { font-size:0.72rem; font-weight:600; color:var(--text2); padding:0 1.4rem; display:inline-flex; align-items:center; gap:0.3rem; border-right:1px solid var(--border); }
    .market-item .mi-up { color:#16a34a; } .market-item .mi-down { color:#dc2626; }

    /* NAVBAR */
    .navbar { background:var(--nav-bg); border-bottom:2px solid var(--accent); position:sticky; top:0; z-index:500; box-shadow:0 2px 8px rgba(0,0,0,0.07); }
    .nav-top { max-width:1300px; margin:0 auto; padding:0 1.25rem; display:flex; align-items:center; justify-content:space-between; height:64px; gap:1rem; }
    .nav-logo { display:flex; align-items:center; gap:0.6rem; cursor:pointer; flex-shrink:0; }
    .nav-logo-icon { width:38px; height:38px; background:var(--accent); border-radius:8px; display:flex; align-items:center; justify-content:center; font-size:1.1rem; color:#fff; font-weight:800; }
    .nav-logo-text { font-family:var(--font-en); font-weight:800; font-size:1.25rem; line-height:1; }
    .nav-logo-text .em { color:var(--accent); }
    .nav-logo-text .sub { display:block; font-size:0.6rem; font-weight:400; color:var(--text3); letter-spacing:0.04em; }

    /* ---- AI SMART SEARCH ---- */
    .nav-search-bar { flex:1; max-width:440px; position:relative; }
    .nav-search-bar input { width:100%; background:var(--bg3); border:1.5px solid var(--border); color:var(--text); padding:0.5rem 1rem 0.5rem 2.5rem; border-radius:24px; font-size:0.85rem; font-family:var(--font-hi); transition:border 0.2s; }
    .nav-search-bar input:focus { outline:none; border-color:var(--accent); background:var(--card-bg); }
    .nav-search-bar .si { position:absolute; left:0.8rem; top:50%; transform:translateY(-50%); color:var(--text3); pointer-events:none; }
    .search-dropdown { position:absolute; top:calc(100% + 8px); left:0; right:0; background:var(--card-bg); border:1px solid var(--border); border-radius:12px; box-shadow:0 12px 36px rgba(0,0,0,0.18); max-height:420px; overflow-y:auto; display:none; z-index:600; }
    .search-dropdown.open { display:block; }
    .sd-section-label { font-size:0.66rem; font-weight:800; text-transform:uppercase; letter-spacing:0.06em; color:var(--text3); padding:0.7rem 1rem 0.3rem; }
    .sd-item { display:flex; align-items:center; gap:0.6rem; padding:0.55rem 1rem; cursor:pointer; transition:background .15s; }
    .sd-item:hover { background:var(--accent-light); }
    .sd-item .sd-icon { width:30px; height:30px; border-radius:7px; background:var(--bg3); display:flex; align-items:center; justify-content:center; font-size:0.9rem; color:var(--accent); flex-shrink:0; }
    .sd-item .sd-text { font-size:0.82rem; font-family:var(--font-hi); color:var(--text); line-height:1.3; }
    .sd-item .sd-text small { display:block; font-size:0.68rem; color:var(--text3); font-family:var(--font-en); margin-top:0.1rem; }
    .sd-empty { padding:1.2rem 1rem; text-align:center; font-size:0.8rem; color:var(--text3); font-family:var(--font-hi); }

    .nav-actions { display:flex; align-items:center; gap:0.55rem; }

    /* ---- LANG TOGGLE (Google Translate powered) ---- */
    .lang-toggle { display:flex; border:1.5px solid var(--border); border-radius:20px; overflow:hidden; font-size:0.75rem; }
    .lang-btn { padding:0.3rem 0.7rem; background:transparent; border:none; color:var(--text2); cursor:pointer; font-weight:600; font-family:var(--font-en); transition:all 0.2s; }
    .lang-btn.active { background:var(--accent); color:#fff; }

    /* ---- DARK MODE TOGGLE ---- */
    .icon-toggle { width:36px; height:36px; border-radius:50%; border:1.5px solid var(--border); background:var(--bg3); color:var(--text2); display:flex; align-items:center; justify-content:center; cursor:pointer; font-size:1rem; position:relative; transition:all .2s; flex-shrink:0; }
    .icon-toggle:hover { border-color:var(--accent); color:var(--accent); }

    /* ---- NOTIFICATION BELL ---- */
    .notif-wrap { position:relative; }
    .notif-badge { position:absolute; top:-2px; right:-2px; width:16px; height:16px; background:#dc2626; color:#fff; border-radius:50%; font-size:0.6rem; font-weight:700; display:flex; align-items:center; justify-content:center; border:2px solid var(--nav-bg); }
    .notif-dropdown { position:absolute; top:calc(100% + 10px); right:0; width:320px; background:var(--card-bg); border:1px solid var(--border); border-radius:12px; box-shadow:0 12px 36px rgba(0,0,0,0.18); display:none; z-index:600; overflow:hidden; }
    .notif-dropdown.open { display:block; }
    .notif-head { padding:0.85rem 1rem; border-bottom:1px solid var(--border); font-weight:700; font-size:0.85rem; display:flex; justify-content:space-between; align-items:center; }
    .notif-head a { font-size:0.7rem; color:var(--accent); font-weight:600; }
    .notif-item { display:flex; gap:0.6rem; padding:0.7rem 1rem; border-bottom:1px solid var(--border); cursor:pointer; transition:background .15s; }
    .notif-item:last-child { border-bottom:none; }
    .notif-item:hover { background:var(--accent-light); }
    .notif-dot { width:8px; height:8px; border-radius:50%; background:var(--accent); margin-top:0.4rem; flex-shrink:0; }
    .notif-text { font-size:0.78rem; font-family:var(--font-hi); color:var(--text2); line-height:1.4; }
    .notif-text strong { color:var(--text); }
    .notif-time { font-size:0.66rem; color:var(--text3); margin-top:0.2rem; font-family:var(--font-en); }
    .notif-empty-state { padding:1.5rem 1rem; text-align:center; color:var(--text3); font-size:0.8rem; font-family:var(--font-hi); }

    .subscribe-btn { background:var(--accent2); color:#fff; border:none; padding:0.45rem 1.1rem; border-radius:20px; font-size:0.8rem; font-weight:700; cursor:pointer; font-family:var(--font-en); transition:all 0.2s; white-space:nowrap; }
    .subscribe-btn:hover { background:#c87d10; }

    /* ---- MEGA MENU NAV ---- */
    .nav-menu { background:var(--nav-bg); border-bottom:1px solid var(--border); position:relative; }
    .nav-menu-inner { max-width:1300px; margin:0 auto; padding:0 1.25rem; display:flex; align-items:center; gap:0.15rem; height:42px; overflow-x:auto; scrollbar-width:none; }
    .nav-menu-inner::-webkit-scrollbar { display:none; }
    .nav-item { padding:0.35rem 0.85rem; border-radius:6px; font-size:0.82rem; font-weight:600; color:var(--text2); cursor:pointer; white-space:nowrap; transition:all 0.2s; font-family:var(--font-hi); border:none; background:transparent; display:inline-flex; align-items:center; gap:0.25rem; }
    .nav-item:hover, .nav-item.active { color:var(--accent); background:var(--accent-light); }
    .nav-item .chev { font-size:0.6rem; transition:transform .2s; }
    .nav-has-mega:hover .chev { transform:rotate(180deg); }

    .mega-panel { position:absolute; top:100%; left:0; right:0; background:var(--card-bg); border-bottom:1px solid var(--border); box-shadow:0 16px 40px rgba(0,0,0,0.16); opacity:0; visibility:hidden; transform:translateY(-8px); transition:all .2s ease; z-index:550; }
    .nav-has-mega:hover .mega-panel { opacity:1; visibility:visible; transform:translateY(0); }
    .mega-inner { max-width:1300px; margin:0 auto; padding:1.5rem 1.25rem; display:grid; grid-template-columns:repeat(5,1fr); gap:1.25rem; }
    .mega-col h5 { font-size:0.72rem; font-weight:800; text-transform:uppercase; letter-spacing:0.05em; color:var(--accent); margin-bottom:0.65rem; font-family:var(--font-en); }
    .mega-col a { display:block; font-size:0.8rem; color:var(--text2); padding:0.3rem 0; font-family:var(--font-hi); transition:color .15s; }
    .mega-col a:hover { color:var(--accent); }
    .mega-feature { grid-column:span 1; border-radius:10px; overflow:hidden; background:var(--bg3); cursor:pointer; }
    .mega-feature img { width:100%; height:90px; object-fit:cover; }
    .mega-feature .mf-body { padding:0.65rem 0.75rem; }
    .mega-feature .mf-cat { font-size:0.62rem; font-weight:700; color:var(--accent); text-transform:uppercase; }
    .mega-feature .mf-title { font-size:0.76rem; font-weight:700; font-family:var(--font-hi); margin-top:0.2rem; line-height:1.35; }

    /* ---- TRENDING DROPDOWN ---- */
    .trend-dropdown { position:absolute; top:calc(100% + 0px); left:0; width:300px; background:var(--card-bg); border:1px solid var(--border); border-radius:0 0 10px 10px; box-shadow:0 16px 40px rgba(0,0,0,0.16); opacity:0; visibility:hidden; transform:translateY(-8px); transition:all .2s ease; z-index:550; }
    .nav-has-trend:hover .trend-dropdown { opacity:1; visibility:visible; transform:translateY(0); }
    .trend-row { display:flex; align-items:center; gap:0.6rem; padding:0.6rem 1rem; border-bottom:1px solid var(--border); }
    .trend-row:last-child { border-bottom:none; }
    .trend-rank { font-size:0.85rem; font-weight:800; color:var(--accent2); width:18px; flex-shrink:0; }
    .trend-row .tr-text { font-size:0.78rem; font-family:var(--font-hi); color:var(--text2); line-height:1.3; }
    .trend-row .tr-meta { font-size:0.65rem; color:var(--text3); margin-top:0.15rem; font-family:var(--font-en); }

    /* ---- TOOLS DROPDOWN ---- */
    .tools-dropdown { position:absolute; top:calc(100% + 0px); left:0; width:230px; background:var(--card-bg); border:1px solid var(--border); border-radius:0 0 10px 10px; box-shadow:0 16px 40px rgba(0,0,0,0.16); opacity:0; visibility:hidden; transform:translateY(-8px); transition:all .2s ease; z-index:550; padding:0.5rem; }
    .nav-has-tools:hover .tools-dropdown { opacity:1; visibility:visible; transform:translateY(0); }
    .tool-row { display:flex; align-items:center; gap:0.6rem; padding:0.55rem 0.6rem; border-radius:8px; font-size:0.8rem; font-family:var(--font-hi); color:var(--text2); transition:background .15s; }
    .tool-row:hover { background:var(--accent-light); color:var(--accent); }
    .tool-row i { font-size:1rem; width:20px; text-align:center; color:var(--accent); }

    /* ---- QUICK ACTION BAR ---- */
    .quick-actions { background:var(--accent-light); border-bottom:1px solid var(--border); }
    .qa-inner { max-width:1300px; margin:0 auto; padding:0.5rem 1.25rem; display:flex; gap:0.5rem; overflow-x:auto; scrollbar-width:none; }
    .qa-inner::-webkit-scrollbar { display:none; }
    .qa-chip { display:inline-flex; align-items:center; gap:0.35rem; padding:0.35rem 0.85rem; background:var(--card-bg); border:1px solid var(--border); border-radius:18px; font-size:0.74rem; font-weight:600; color:var(--text2); white-space:nowrap; transition:all .15s; font-family:var(--font-hi); }
    .qa-chip:hover { border-color:var(--accent); color:var(--accent); transform:translateY(-1px); }

    /* WRAPPER */
    .wrapper { max-width:1300px; margin:0 auto; padding:0 1.25rem; }
    .main-layout { display:grid; grid-template-columns:1fr 320px; gap:2rem; padding:2rem 0; align-items:start; }
    .sidebar-section { display:flex; flex-direction:column; gap:1.5rem; position:sticky; top:120px; }

    /* CARDS */
    .post-card { background:var(--card-bg); border:1px solid var(--border); border-radius:var(--radius); overflow:hidden; cursor:pointer; transition:all 0.25s; display:flex; flex-direction:column; }
    .post-card:hover { box-shadow:0 8px 30px rgba(0,0,0,0.14); transform:translateY(-3px); border-color:var(--accent); }
    .pc-thumb { height:175px; display:flex; align-items:center; justify-content:center; font-size:3rem; overflow:hidden; }
    .pc-thumb img { width:100%; height:100%; object-fit:cover; }
    .pc-body { padding:1rem; flex:1; display:flex; flex-direction:column; }
    .pc-cat { font-size:0.67rem; font-weight:700; color:var(--accent); text-transform:uppercase; letter-spacing:0.05em; margin-bottom:0.4rem; }
    .pc-title { font-size:0.95rem; font-weight:700; line-height:1.4; color:var(--text); margin-bottom:0.5rem; font-family:var(--font-hi); }
    .pc-title:hover { color:var(--accent); }
    .pc-desc { font-size:0.78rem; color:var(--text2); line-height:1.6; font-family:var(--font-hi); flex:1; }
    .pc-meta { display:flex; align-items:center; gap:0.75rem; margin-top:0.75rem; font-size:0.68rem; color:var(--text3); }
    .cards-grid { display:grid; grid-template-columns:repeat(auto-fill,minmax(300px,1fr)); gap:1.25rem; }

    /* SECTION HEADER */
    .section-head { display:flex; align-items:center; justify-content:space-between; margin-bottom:1.25rem; }
    .section-title { font-size:1.15rem; font-weight:800; position:relative; padding-left:0.9rem; }
    .section-title::before { content:''; position:absolute; left:0; top:50%; transform:translateY(-50%); width:4px; height:70%; background:var(--accent); border-radius:2px; }
    .view-all { font-size:0.78rem; font-weight:600; color:var(--accent); }
    .view-all:hover { text-decoration:underline; }

    /* WIDGET */
    .widget { background:var(--card-bg); border:1px solid var(--border); border-radius:var(--radius); overflow:hidden; }
    .widget-head { background:var(--accent); color:#fff; padding:0.7rem 1.1rem; display:flex; align-items:center; gap:0.5rem; font-size:0.85rem; font-weight:700; font-family:var(--font-hi); }
    .widget-body { padding:1rem; }
    .rp-item { display:flex; gap:0.75rem; padding:0.65rem 0; border-bottom:1px solid var(--border); cursor:pointer; }
    .rp-item:last-child { border-bottom:none; }
    .rp-thumb { width:58px; height:58px; border-radius:8px; background:var(--bg3); display:flex; align-items:center; justify-content:center; font-size:1.5rem; flex-shrink:0; overflow:hidden; }
    .rp-thumb img { width:100%; height:100%; object-fit:cover; }
    .rp-cat { font-size:0.67rem; font-weight:700; color:var(--accent); text-transform:uppercase; }
    .rp-title { font-size:0.82rem; font-weight:600; color:var(--text); font-family:var(--font-hi); line-height:1.35; margin:0.1rem 0 0.2rem; }
    .rp-item:hover .rp-title { color:var(--accent); }
    .rp-date { font-size:0.68rem; color:var(--text3); }
    .tag-cloud { display:flex; flex-wrap:wrap; gap:0.4rem; padding:1rem; }
    .tag { padding:0.3rem 0.75rem; border-radius:16px; font-size:0.75rem; font-weight:600; background:var(--bg3); color:var(--text2); border:1px solid var(--border); cursor:pointer; transition:all 0.2s; font-family:var(--font-hi); }
    .tag:hover { background:var(--accent); color:#fff; border-color:var(--accent); }
    .nl-widget { background:linear-gradient(135deg,var(--accent),var(--accent-dark)); border-radius:var(--radius); padding:1.25rem; color:#fff; }
    .nl-widget h4 { font-size:0.95rem; font-weight:700; margin-bottom:0.4rem; font-family:var(--font-hi); }
    .nl-widget p { font-size:0.78rem; opacity:0.85; margin-bottom:1rem; font-family:var(--font-hi); }
    .nl-widget input { width:100%; background:rgba(255,255,255,0.2); border:1px solid rgba(255,255,255,0.3); color:#fff; padding:0.6rem 0.9rem; border-radius:7px; font-size:0.82rem; margin-bottom:0.6rem; font-family:var(--font-hi); }
    .nl-widget input::placeholder { color:rgba(255,255,255,0.6); }
    .nl-widget button { width:100%; background:#fff; color:var(--accent); border:none; padding:0.6rem; border-radius:7px; font-size:0.82rem; font-weight:700; cursor:pointer; transition:all 0.2s; }
    .nl-widget button:hover { background:var(--accent2); color:#fff; }

    /* BADGE */
    .cat-badge { display:inline-block; padding:0.2rem 0.75rem; border-radius:4px; font-size:0.7rem; font-weight:700; text-transform:uppercase; letter-spacing:0.05em; }
    .cb-green { background:#e8f5ee; color:#1a7a4a; }
    .cb-blue { background:#e8f0ff; color:#2563eb; }
    .cb-orange { background:#fff7ed; color:#ea580c; }
    .cb-purple { background:#f5f3ff; color:#7c3aed; }
    .cb-red { background:#fef2f2; color:#dc2626; }

    /* HERO */
    .hero-grid { display:grid; grid-template-columns:2fr 1fr; gap:1rem; margin-bottom:2rem; }
    .hero-card { border-radius:14px; overflow:hidden; position:relative; cursor:pointer; }
    .hero-card img { width:100%; height:100%; object-fit:cover; }
    .hero-main { height:400px; }
    .hero-side { display:flex; flex-direction:column; gap:1rem; }
    .hero-side .hero-card { height:190px; }
    .hero-overlay { position:absolute; bottom:0; left:0; right:0; background:linear-gradient(transparent,rgba(0,0,0,0.85)); padding:1.25rem; color:#fff; }
    .hero-overlay .ho-cat { font-size:0.68rem; font-weight:700; text-transform:uppercase; opacity:0.85; margin-bottom:0.3rem; }
    .hero-overlay .ho-title { font-weight:700; line-height:1.35; font-family:var(--font-hi); }
    .hero-main .ho-title { font-size:1.2rem; }
    .hero-side .ho-title { font-size:0.88rem; }

    /* FOOTER */
    .footer { background:#0f1b2d; color:rgba(255,255,255,0.7); padding:3rem 0 1.5rem; margin-top:3rem; }
    .footer-grid { display:grid; grid-template-columns:2fr 1fr 1fr 1fr; gap:2rem; margin-bottom:2rem; }
    .footer-brand h3 { font-size:1.2rem; font-weight:800; color:#fff; margin-bottom:0.75rem; }
    .footer-brand p { font-size:0.78rem; line-height:1.8; font-family:var(--font-hi); }
    .footer-col h4 { font-size:0.85rem; font-weight:700; color:#fff; margin-bottom:0.75rem; font-family:var(--font-hi); }
    .footer-col ul li { margin-bottom:0.4rem; }
    .footer-col ul li a { font-size:0.78rem; transition:color 0.2s; font-family:var(--font-hi); }
    .footer-col ul li a:hover { color:var(--accent2); }
    .footer-bottom { border-top:1px solid rgba(255,255,255,0.1); padding-top:1.5rem; display:flex; align-items:center; justify-content:space-between; flex-wrap:wrap; gap:1rem; font-size:0.75rem; }
    .social-links { display:flex; gap:0.5rem; }
    .social-btn { width:32px; height:32px; border-radius:50%; display:flex; align-items:center; justify-content:center; font-size:0.85rem; color:#fff; transition:all 0.2s; }
    .social-btn:hover { transform:translateY(-2px); }

    /* PAGINATION */
    .pagination { display:flex; gap:0.4rem; justify-content:center; padding:2rem 0; flex-wrap:wrap; }
