<%- include('../partials/header', { breaking: [], categories: [] }) %>

<div class="wrapper">
  <div class="breadcrumb">
    <a href="/">Home</a><span class="sep">/</span>
    <a href="/blog">Blog</a><span class="sep">/</span>
    <% if(post.category){ %><a href="/category/<%= post.category.slug %>"><%= post.category.name_hi||post.category.name %></a><span class="sep">/</span><% } %>
    <span><%= (post.title_hi||post.title).substring(0,40) %>...</span>
  </div>

  <div class="main-layout">
    <!-- POST CONTENT -->
    <article>
      <!-- POST HEADER -->
      <div style="margin-bottom:1.5rem">
        <% if(post.category){ %>
        <a href="/category/<%= post.category.slug %>" style="display:inline-block;padding:0.25rem 0.85rem;border-radius:20px;font-size:0.72rem;font-weight:700;background:var(--accent-light);color:var(--accent);text-transform:uppercase;letter-spacing:0.05em;margin-bottom:0.75rem">
          <%= post.category.icon||'' %> <%= post.category.name_hi||post.category.name %>
        </a>
        <% } %>
        <h1 style="font-size:1.8rem;font-weight:800;line-height:1.3;font-family:var(--font-hi);color:var(--heading,var(--text));margin-bottom:0.75rem">
          <%= post.title_hi||post.title %>
        </h1>
        <% if(post.title_hi && post.title){ %>
        <h2 style="font-size:1.1rem;font-weight:500;color:var(--text2);margin-bottom:0.75rem"><%= post.title %></h2>
        <% } %>
        <div style="display:flex;align-items:center;gap:1rem;font-size:0.78rem;color:var(--text3);flex-wrap:wrap">
          <span><i class="bi bi-person-circle"></i> <%= post.author ? post.author.name : 'Dreams Team' %></span>
          <span><i class="bi bi-calendar3"></i> <%= post.published_at ? new Date(post.published_at).toLocaleDateString('en-IN',{day:'numeric',month:'long',year:'numeric'}) : '' %></span>
          <span><i class="bi bi-eye"></i> <%= (post.views||0).toLocaleString() %> views</span>
          <% if(post.is_breaking){ %><span style="background:#fee2e2;color:#dc2626;padding:2px 8px;border-radius:4px;font-weight:700;font-size:0.68rem">🔴 BREAKING</span><% } %>
        </div>
      </div>

      <!-- FEATURED IMAGE -->
      <% if(post.featured_image){ %>
      <div style="margin-bottom:1.5rem;border-radius:12px;overflow:hidden;max-height:450px">
        <img src="<%= post.featured_image %>" alt="<%= post.title %>" style="width:100%;height:450px;object-fit:cover">
      </div>
      <% } %>

      <!-- SHORT DESCRIPTION -->
      <% if(post.short_description_hi || post.short_description){ %>
      <div style="background:var(--accent-light);border-left:4px solid var(--accent);padding:1rem 1.25rem;border-radius:0 8px 8px 0;margin-bottom:1.5rem;font-family:var(--font-hi);font-size:0.9rem;color:var(--text2);line-height:1.8">
        <strong>Summary:</strong> <%= post.short_description_hi||post.short_description %>
      </div>
      <% } %>

      <!-- CONTENT -->
      <div class="post-content" style="font-family:var(--font-hi);line-height:1.9;color:var(--text);font-size:0.95rem">
        <%- post.content_hi||post.content||'<p>Content coming soon...</p>' %>
      </div>

      <!-- CUSTOM FIELDS TABLE -->
      <% if(post.customFields && post.customFields.length){ %>
      <div style="margin-top:2rem;background:var(--bg3);border-radius:12px;overflow:hidden">
        <div style="background:var(--accent);color:#fff;padding:0.75rem 1.25rem;font-weight:700;font-size:0.88rem">
          <i class="bi bi-info-circle"></i> Additional Information
        </div>
        <table style="width:100%;border-collapse:collapse">
          <% post.customFields.forEach(f=>{ %>
          <tr style="border-bottom:1px solid var(--border)">
            <td style="padding:0.65rem 1.25rem;font-weight:600;font-size:0.82rem;width:40%;background:var(--bg3)"><%= f.field_label %></td>
            <td style="padding:0.65rem 1.25rem;font-size:0.82rem">
              <% if(f.field_type==='url'){ %><a href="<%= f.field_value %>" target="_blank" style="color:var(--accent)"><%= f.field_value %></a>
              <% } else { %><%= f.field_value %><% } %>
            </td>
          </tr>
          <% }) %>
        </table>
      </div>
      <% } %>

      <!-- TAGS -->
      <% if(post.tags){ %>
      <div style="margin-top:2rem;padding-top:1.5rem;border-top:1px solid var(--border)">
        <strong style="font-size:0.82rem;color:var(--text2)"><i class="bi bi-tags"></i> Tags:</strong>
        <div style="display:flex;flex-wrap:wrap;gap:0.4rem;margin-top:0.5rem">
          <% post.tags.split(',').forEach(t=>{ %>
          <a href="/blog?tag=<%= t.trim() %>" class="tag"><%= t.trim() %></a>
          <% }) %>
        </div>
      </div>
      <% } %>

      <!-- SHARE -->
      <div style="margin-top:2rem;padding:1.25rem;background:var(--bg3);border-radius:12px">
        <div style="font-weight:700;margin-bottom:0.75rem;font-size:0.88rem"><i class="bi bi-share"></i> Share this post:</div>
        <div style="display:flex;gap:0.5rem;flex-wrap:wrap">
          <a href="https://www.facebook.com/sharer/sharer.php?u=<%= encodeURIComponent((siteSettings.site_url||'') + '/blog/' + post.slug) %>" target="_blank" style="padding:0.4rem 1rem;background:#1877f2;color:#fff;border-radius:6px;font-size:0.78rem;font-weight:600;display:flex;align-items:center;gap:0.4rem"><i class="bi bi-facebook"></i> Facebook</a>
          <a href="https://wa.me/?text=<%= encodeURIComponent((post.title_hi||post.title) + ' ' + (siteSettings.site_url||'') + '/blog/' + post.slug) %>" target="_blank" style="padding:0.4rem 1rem;background:#25d366;color:#fff;border-radius:6px;font-size:0.78rem;font-weight:600;display:flex;align-items:center;gap:0.4rem"><i class="bi bi-whatsapp"></i> WhatsApp</a>
          <a href="https://t.me/share/url?url=<%= encodeURIComponent((siteSettings.site_url||'') + '/blog/' + post.slug) %>&text=<%= encodeURIComponent(post.title_hi||post.title) %>" target="_blank" style="padding:0.4rem 1rem;background:#0088cc;color:#fff;border-radius:6px;font-size:0.78rem;font-weight:600;display:flex;align-items:center;gap:0.4rem"><i class="bi bi-telegram"></i> Telegram</a>
          <button onclick="navigator.clipboard.writeText(window.location.href);alert('Link copied!')" style="padding:0.4rem 1rem;background:#64748b;color:#fff;border:none;border-radius:6px;font-size:0.78rem;font-weight:600;cursor:pointer;display:flex;align-items:center;gap:0.4rem"><i class="bi bi-clipboard"></i> Copy Link</button>
        </div>
      </div>
    </article>

    <!-- SIDEBAR -->
    <div class="sidebar-section">
      <div class="ad-slot" style="min-height:250px;flex-direction:column;gap:0.5rem">
        <i class="bi bi-megaphone" style="font-size:2rem;opacity:0.3"></i>Advertisement 300×250
      </div>

      <!-- TABLE OF CONTENTS (if content has h2/h3) -->
      <div class="widget" id="toc-widget" style="display:none">
        <div class="widget-head"><i class="bi bi-list-ul"></i> Table of Contents</div>
        <div class="widget-body" id="toc-list" style="padding:0.5rem 0"></div>
      </div>

      <!-- RELATED POSTS -->
      <% if(related && related.length){ %>
      <div class="widget">
        <div class="widget-head"><i class="bi bi-link-45deg"></i> Related Posts</div>
        <div class="widget-body">
          <% related.forEach(rp=>{ %>
          <a href="/blog/<%= rp.slug %>" class="rp-item" style="display:flex">
            <div class="rp-thumb">
              <% if(rp.featured_image){ %><img src="<%= rp.featured_image %>" alt=""><% } else { %>
              <span><%= rp.category ? rp.category.icon||'📰' : '📰' %></span><% } %>
            </div>
            <div>
              <div class="rp-cat"><%= rp.category ? (rp.category.name_hi||rp.category.name) : '' %></div>
              <div class="rp-title"><%= (rp.title_hi||rp.title).substring(0,60) %>...</div>
              <div class="rp-date"><i class="bi bi-eye"></i> <%= (rp.views||0).toLocaleString() %></div>
            </div>
          </a>
          <% }) %>
        </div>
      </div>
      <% } %>

      <div class="nl-widget">
        <h4>📬 Newsletter</h4>
        <p>नई पोस्ट Email पर पाएं</p>
        <input type="email" placeholder="Email Address...">
        <button>Subscribe Free!</button>
      </div>
    </div>
  </div>

  <!-- RELATED POSTS GRID BELOW -->
  <% if(related && related.length){ %>
  <div style="margin-top:3rem;padding-top:2rem;border-top:2px solid var(--border)">
    <div class="section-head">
      <div class="section-title">📖 और पढ़ें – Related Posts</div>
    </div>
    <div class="cards-grid">
      <% related.forEach(rp=>{ %>
      <a href="/blog/<%= rp.slug %>" class="post-card">
        <div class="pc-thumb" style="background:linear-gradient(135deg,var(--accent-light),#c8e6c9)">
          <% if(rp.featured_image){ %><img src="<%= rp.featured_image %>" alt="<%= rp.title %>"><% } else { %>
          <span style="font-size:3rem"><%= rp.category ? rp.category.icon||'📰' : '📰' %></span><% } %>
        </div>
        <div class="pc-body">
          <div class="pc-cat"><%= rp.category ? (rp.category.name_hi||rp.category.name) : '' %></div>
          <div class="pc-title"><%= rp.title_hi||rp.title %></div>
          <div class="pc-meta"><span><i class="bi bi-eye"></i> <%= (rp.views||0).toLocaleString() %></span></div>
        </div>
      </a>
      <% }) %>
    </div>
  </div>
  <% } %>
</div>

<style>
.post-content h1,.post-content h2,.post-content h3,.post-content h4 { font-family:var(--font-hi); font-weight:800; margin:1.5rem 0 0.75rem; color:var(--text); line-height:1.3; }
.post-content h2 { font-size:1.3rem; border-bottom:2px solid var(--accent-light); padding-bottom:0.4rem; }
.post-content h3 { font-size:1.1rem; color:var(--accent); }
.post-content p { margin-bottom:1rem; }
.post-content ul,.post-content ol { padding-left:1.5rem; margin-bottom:1rem; }
.post-content li { margin-bottom:0.4rem; }
.post-content a { color:var(--accent); font-weight:600; }
.post-content a:hover { text-decoration:underline; }
.post-content blockquote { border-left:4px solid var(--accent); padding:1rem 1.25rem; background:var(--accent-light); border-radius:0 8px 8px 0; margin:1.5rem 0; font-style:italic; }
.post-content img { border-radius:10px; margin:1rem 0; max-width:100%; }
.post-content table { width:100%; border-collapse:collapse; margin:1rem 0; }
.post-content th,.post-content td { padding:0.6rem 0.85rem; border:1px solid var(--border); font-size:0.85rem; }
.post-content th { background:var(--accent); color:#fff; }
.post-content code { background:#f0f4f8; padding:2px 6px; border-radius:4px; font-size:0.85em; font-family:monospace; }
.post-content pre { background:#1a2332; color:#a8ff78; padding:1rem; border-radius:8px; overflow-x:auto; margin:1rem 0; }
</style>

<script>
// Auto generate TOC
const content = document.querySelector('.post-content');
if(content){
  const headings = content.querySelectorAll('h2,h3');
  if(headings.length > 2){
    const toc = document.getElementById('toc-list');
    const widget = document.getElementById('toc-widget');
    widget.style.display='block';
    headings.forEach((h,i)=>{
      h.id='heading-'+i;
      const a=document.createElement('a');
      a.href='#heading-'+i;
      a.textContent=(h.tagName==='H3'?'  ↳ ':'')+h.textContent;
      a.style.cssText='display:block;padding:0.4rem 1rem 0.4rem '+(h.tagName==='H3'?'2rem':'1rem')+';font-size:0.78rem;color:var(--text2);border-bottom:1px solid var(--border);transition:all 0.2s';
      a.addEventListener('mouseover',()=>a.style.color='var(--accent)');
      a.addEventListener('mouseout',()=>a.style.color='var(--text2)');
      toc.appendChild(a);
    });
  }
}
</script>

<%- include('../partials/footer', { categories: [] }) %>
